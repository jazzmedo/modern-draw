        <mxCell id="K9E13c2xmPQ5-SIx5Gco-14" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1" value="1" vertex="1">
          <mxGeometry height="20" width="20.32" x="537.64" y="227.57" as="geometry" />
        </mxCell>
        <mxCell id="K9E13c2xmPQ5-SIx5Gco-17" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1" value="2" vertex="1">
          <mxGeometry height="20" width="20.32" x="640" y="229" as="geometry" />
        </mxCell>
        <mxCell id="K9E13c2xmPQ5-SIx5Gco-18" parent="1" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Aviny;fontStyle=0;horizontal=1;direction=west;textDirection=rtl;" value="&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;لو احنا شغالين بنظام ال Even parity المفروض بعد ال ones لو كانو odd يبقي ال parity bit ب 1 لو كان عدد ال ones ب even يبقي ال parity bit ب 0، انما لو شغال بنظام ال Odd parity لو عدد ال ones كان odd يبقي ال parity bit ب 0 ولو كان عدد ال&amp;nbsp;ones ب even يبقي ال parity bit ب 1 بس لو الدكتور ماذكرتش اشتغل بال even&lt;/blockquote&gt;" vertex="1">
          <mxGeometry height="48.57" width="546.14" x="270" y="389" as="geometry" />
        </mxCell>
        <mxCell id="K9E13c2xmPQ5-SIx5Gco-20" parent="1" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Aviny;fontStyle=0;horizontal=1;direction=west;textDirection=rtl;" value="&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;هنا عددهم &lt;font style=&quot;color: rgb(255, 0, 0);&quot;&gt;9&lt;/font&gt; وال parity bit ب &lt;font style=&quot;color: rgb(255, 0, 0);&quot;&gt;0&lt;/font&gt; يبقي ال data مش سليمة&lt;/blockquote&gt;" vertex="1">
          <mxGeometry height="48.57" width="311.14" x="500" y="329" as="geometry" />
