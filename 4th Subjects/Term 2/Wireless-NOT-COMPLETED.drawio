        </mxCell>
        <mxCell id="K9E13c2xmPQ5-SIx5Gco-48" parent="K9E13c2xmPQ5-SIx5Gco-44" style="text;whiteSpace=wrap;fontFamily=Mina;fontStyle=1;align=right;fontColor=#FFFFFF;fontSize=9;" value="Parity&#xa;Mode" vertex="1">
          <mxGeometry height="42.5" width="42.5" x="49" y="-4" as="geometry" />
        </mxCell>
        <mxCell id="K9E13c2xmPQ5-SIx5Gco-50" parent="1" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Aviny;fontStyle=0;horizontal=1;direction=west;textDirection=rtl;" value="&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;هنا في مشكلتين في الطريقة دي اني مش بعرف انه bit اللي فيه ال error ولو في عدد من ال errors even مش هعرف ان في bits مش سليمة يعني مثلا لو غيرت 2 bits فكدا ال parity bit مش هينغير بس ال bits اتغيرت وهنا ييجي الطريقة الأفضل وهو ال Two Dimentional bit.&lt;/blockquote&gt;" vertex="1">
          <mxGeometry height="48.57" width="781.14" x="30" y="459" as="geometry" />
        </mxCell>
        <mxCell id="K9E13c2xmPQ5-SIx5Gco-56" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="40" width="218" x="20" y="509" as="geometry" />
        </mxCell>
        <mxCell id="K9E13c2xmPQ5-SIx5Gco-52" parent="K9E13c2xmPQ5-SIx5Gco-56" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;strokeWidth=2;fontFamily=Mina;arcSize=0;hachureGap=4;align=right;spacingRight=5;fontStyle=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=default;container=0;" value="Bit" vertex="1">
          <mxGeometry height="40" width="110" x="108" as="geometry" />
        </mxCell>
        <mxCell id="K9E13c2xmPQ5-SIx5Gco-53" parent="K9E13c2xmPQ5-SIx5Gco-56" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fillColor=#333333;strokeColor=#000000;strokeWidth=2;fontFamily=Mina;arcSize=0;hachureGap=4;align=center;spacingRight=0;fontStyle=1;fontColor=#ffffff;" value="Two Dimentional" vertex="1">
          <mxGeometry height="40" width="178" as="geometry" />
        </mxCell>
        <mxCell id="K9E13c2xmPQ5-SIx5Gco-57" parent="1" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Aviny;fontStyle=0;horizontal=1;direction=west;textDirection=rtl;" value="&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;الموضوع سهل وبسيط، انا فوق كان هو row واحد بعد ال ones وبشوف علي اساسه ال parity bit صح ولا في مشكلة، هنا بقي انا بطبق نفس الكلام بس في ال rows و في ال columns الاتنين، يعني ببتدي احسب مثلا ال Row Parity واشوف هل في مشاكل ظهرت ولا لا لو ظهر في مشكلة انت مش هتعرف فين فلما تحسب ال Column Parity هتعرف انه bit اللي اتغيرت.&amp;nbsp;&lt;/blockquote&gt;" vertex="1">
          <mxGeometry height="48.57" width="781.14" x="38.230000000000004" y="579" as="geometry" />
        </mxCell>
