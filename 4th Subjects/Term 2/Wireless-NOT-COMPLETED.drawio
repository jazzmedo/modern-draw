        <mxCell id="nvSKO4mu5iPOjodS5lKu-9" parent="nvSKO4mu5iPOjodS5lKu-11" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;strokeWidth=2;fontFamily=Mina;arcSize=0;hachureGap=4;align=right;spacingRight=5;fontStyle=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=default;" value="Bit" vertex="1">
          <mxGeometry height="40" width="110" as="geometry" />
        </mxCell>
        <mxCell id="nvSKO4mu5iPOjodS5lKu-10" parent="nvSKO4mu5iPOjodS5lKu-11" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fillColor=#333333;strokeColor=#000000;strokeWidth=2;fontFamily=Mina;arcSize=0;hachureGap=4;align=center;spacingRight=0;fontStyle=1;fontColor=#ffffff;" value="Single" vertex="1">
          <mxGeometry height="40" width="70" as="geometry" />
        </mxCell>
        <mxCell id="nvSKO4mu5iPOjodS5lKu-12" parent="1" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Aviny;fontStyle=0;horizontal=1;direction=west;textDirection=rtl;" value="&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;دلوقتي عشان اتأكد ان ال data تكون سليمة اثناء اي اتصال في الشبكة كان لازم نعمل طريقة نتأكد منها ان ال data فعلا اتبعتت سليمة وهنا بييجي دور ال parity checking، نبدأ بال single-bit parity وهي طريقة بتعرفني بس هل ال data وصلت سليمة ولا لا عن طريق اني بأعد ال ones لو كانت odd يبقي المفروض اخر bit اللي هو ال parity bit يكون &lt;font style=&quot;color: rgb(255, 0, 0);&quot;&gt;1&lt;/font&gt; لو كان&amp;nbsp;&lt;font style=&quot;color: rgb(255, 0, 0);&quot;&gt;0 &lt;/font&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;يبقي ال data دي مش سليمة، نفس الموضوع لو كان عدد ال ones even يبقي ال المفروض ال parity bit يبقي ب &lt;/font&gt;&lt;font style=&quot;color: rgb(255, 0, 0);&quot;&gt;0&lt;/font&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt; لو كان &lt;/font&gt;&lt;font style=&quot;color: rgb(255, 0, 0);&quot;&gt;1&lt;/font&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt; يبقي ال data دي مش سليمة.&lt;/font&gt;&lt;/blockquote&gt;" vertex="1">
          <mxGeometry height="48.57" width="796.14" x="10" y="170" as="geometry" />
        </mxCell>
        <mxCell id="K9E13c2xmPQ5-SIx5Gco-11" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1" value="3" vertex="1">
          <mxGeometry height="20" width="20.32" x="139.84" y="227.57" as="geometry" />
        </mxCell>
        <mxCell id="K9E13c2xmPQ5-SIx5Gco-12" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1" value="2" vertex="1">
          <mxGeometry height="20" width="20.32" x="360" y="227.57" as="geometry" />
        </mxCell>
        <mxCell id="K9E13c2xmPQ5-SIx5Gco-13" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1" value="1" vertex="1">
          <mxGeometry height="20" width="20.32" x="457.64" y="227.57" as="geometry" />
