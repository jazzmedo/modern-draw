          <mxGeometry x="17" y="1554.55" width="690" height="55.5" as="geometry" />
        </mxCell>
        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-54" value="Analyze the advantages and disadvantages of supervised learning in handling big data, including ethical considerations for labelling." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;arcSize=5;hachureGap=4;align=left;spacingRight=2;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontFamily=Mali;fontSize=15;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;fontStyle=2" parent="dkQl99vo6uP7NWvQIqdY-12" vertex="1">
