        <mxCell id="id8GIDBzt5Ycg5tB8IS--15" value="Learn a &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;mapping&lt;/font&gt; from inputs to outputs to &lt;font style=&quot;color: rgb(0, 0, 204);&quot;&gt;make predictions&lt;/font&gt; on new data" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=10;fontStyle=0;fontFamily=Mali;spacingLeft=2;align=left;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="id8GIDBzt5Ycg5tB8IS--6" vertex="1">
