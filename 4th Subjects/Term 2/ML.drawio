        <mxCell id="id8GIDBzt5Ycg5tB8IS--26" value="An agent learns by &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;interacting with environment&lt;/font&gt;, receiving rewards or penalties for its actions" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#E6D0DE;strokeColor=#36393d;container=0;fontSize=10;fontStyle=0;fontFamily=Mali;spacingLeft=2;align=left;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="id8GIDBzt5Ycg5tB8IS--6" vertex="1">
          <mxGeometry x="565.7994742250494" y="28.629999999999995" width="244.20052577495062" height="36.82" as="geometry" />
        </mxCell>
        <mxCell id="id8GIDBzt5Ycg5tB8IS--27" value="&lt;div&gt;Learn the optimal policy (sequence of actions) to &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;maximize cumulative reward&lt;/font&gt;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;over time&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#E6D0DE;strokeColor=#36393d;container=0;fontSize=10;fontStyle=0;fontFamily=Mali;spacingLeft=2;align=left;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="id8GIDBzt5Ycg5tB8IS--6" vertex="1">
