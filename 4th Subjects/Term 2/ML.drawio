          <mxGeometry x="330" y="2168" width="3" height="153" as="geometry" />
        </mxCell>
        <mxCell id="SqQxqcDdHDEK13gpGspm-115" value="`&quot;Sales&quot; = 50 + 3 \times &quot;Ad Spend&quot; + \epsilon`" style="text;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontFamily=thmanyah serif text;fontSize=14;fillColor=#FFFBF2;rounded=1;arcSize=17;strokeColor=none;" vertex="1" parent="SqQxqcDdHDEK13gpGspm-1">
          <mxGeometry x="50" y="2193" width="228" height="30" as="geometry" />
        </mxCell>
        <mxCell id="SqQxqcDdHDEK13gpGspm-116" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;Single Linear Regression&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;fontFamily=Mali;fillColor=#FFFBF2;strokeColor=#d6b656;align=center;spacingLeft=0;rounded=1;arcSize=9;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" vertex="1" parent="SqQxqcDdHDEK13gpGspm-1">
          <mxGeometry x="53.5" y="2138" width="200.5" height="30" as="geometry" />
        </mxCell>
        <mxCell id="SqQxqcDdHDEK13gpGspm-117" value="&lt;div style=&quot;line-height: 150%;&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;الموديل البسيط ده بيعمل prediction للـ sales بناءً على الـ advertising اللي هيتصرف بس. المثال ده بيوضح إن الـ sales بتزيد 3 أضعاف قيمة الـ advertising اللي اتصرف في المتوسط وما فيش أي عوامل تانية، وده مش منطقي لأن الـ sales بتعتمد على عوامل تانية كتير، وهنا بتكمن مشكلة&amp;nbsp;&amp;nbsp;الـ simple linear regression.&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=tanha;fontStyle=0;textDirection=rtl;fontSize=12;" vertex="1" parent="SqQxqcDdHDEK13gpGspm-1">
          <mxGeometry x="20" y="2232" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="SqQxqcDdHDEK13gpGspm-118" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;Multi Linear Regression&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;fontFamily=Mali;fillColor=#FFFBF2;strokeColor=#d6b656;align=center;spacingLeft=0;rounded=1;arcSize=9;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" vertex="1" parent="SqQxqcDdHDEK13gpGspm-1">
          <mxGeometry x="522.02" y="2138" width="187.98" height="30" as="geometry" />
        </mxCell>
        <mxCell id="SqQxqcDdHDEK13gpGspm-119" value="\begin{aligned} Sales = &amp;amp; 25 + 2.5 \text{ Ad Spend} - 1.8 \text{ Our Price} \\ &amp;amp; + 1.2 \text{ Competitor Price} + 0.4 \text{ Consumer Confidence} + \epsilon \end{aligned}" style="text;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontFamily=thmanyah serif text;fontSize=14;fillColor=#FFFBF2;rounded=1;arcSize=17;strokeColor=none;" vertex="1" parent="SqQxqcDdHDEK13gpGspm-1">
          <mxGeometry x="350.27" y="2184" width="469.73" height="48" as="geometry" />
        </mxCell>
        <mxCell id="SqQxqcDdHDEK13gpGspm-120" value="&lt;div style=&quot;line-height: 150%;&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;الموديل ده بقى بيعتمد على أكتر من عامل؛ بدل ما يعتمد على الـ advertising بس، لا هو دخل في المعادلة سعرنا إحنا وسعر المنافس وثقة العميل. وبكده بعد ما دخلت أكتر من عامل في المعادلة، الـ prediction والـ decision making هيكون أفضل، بس بما إن في أكتر من عامل فالعملية بتبقى أصعب عشان عايزين data أكتر وصحيحة عشان نطلع دقة مظبوطة.&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=tanha;fontStyle=0;textDirection=rtl;fontSize=12;" vertex="1" parent="SqQxqcDdHDEK13gpGspm-1">
          <mxGeometry x="340" y="2238" width="478.25" height="70" as="geometry" />
        </mxCell>
