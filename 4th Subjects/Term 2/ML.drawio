        <mxCell id="id8GIDBzt5Ycg5tB8IS--16" value="&lt;div&gt;&lt;b&gt;Types:&lt;/b&gt; Classification and Regression&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=10;fontStyle=0;fontFamily=Mali;spacingLeft=2;align=left;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="id8GIDBzt5Ycg5tB8IS--6" vertex="1">
          <mxGeometry x="91.80371068508347" y="102.27000000000001" width="244.20052577495062" height="36.82" as="geometry" />
        </mxCell>
        <mxCell id="id8GIDBzt5Ycg5tB8IS--17" value="&lt;div&gt;When you have a &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;clear set of labeled&lt;/font&gt; examples&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=10;fontStyle=0;fontFamily=Mali;spacingLeft=2;align=left;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="id8GIDBzt5Ycg5tB8IS--6" vertex="1">
          <mxGeometry x="91.91605252706101" y="139.08999999999997" width="244.0881839329731" height="36.82" as="geometry" />
        </mxCell>
        <mxCell id="id8GIDBzt5Ycg5tB8IS--18" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;font style=&quot;line-height: 140%;&quot;&gt;&lt;font&gt;1.&lt;/font&gt;Requires large amounts of &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;high-quality labeled&lt;/font&gt; data,&amp;nbsp;&lt;/font&gt;&lt;span&gt;2.&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 204), rgb(255, 255, 255));&quot;&gt;Poor &lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;at handling completely &lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 204), rgb(255, 255, 255));&quot;&gt;new situations&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; outside the training distribution,3&lt;/span&gt;&lt;span&gt;.&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Risk of &lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(204, 0, 0), rgb(255, 255, 255));&quot;&gt;overfitting&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=10;fontStyle=0;fontFamily=Mali;spacingLeft=2;align=left;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="id8GIDBzt5Ycg5tB8IS--6" vertex="1">
          <mxGeometry x="91.91605252706101" y="175.91000000000003" width="244.0881839329731" height="64.09" as="geometry" />
        </mxCell>
        <mxCell id="id8GIDBzt5Ycg5tB8IS--19" value="&lt;font&gt;&lt;span&gt;Un Supervised Learning&lt;/span&gt;&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D2945E;strokeColor=#934900;fontColor=#ffffff;container=0;fontSize=14;fontFamily=Mali;fontStyle=1;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="id8GIDBzt5Ycg5tB8IS--6" vertex="1">
