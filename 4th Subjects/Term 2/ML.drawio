        </mxCell>
        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-55" value="4" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#666666;fontFamily=Mali;fontStyle=1;fontSize=22;spacingTop=3;fontColor=#333333;rounded=1;fillStyle=hachure;align=center;verticalAlign=middle;spacingLeft=0;spacingBottom=3;arcSize=14;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;spacingRight=2;" parent="dkQl99vo6uP7NWvQIqdY-12" vertex="1">
          <mxGeometry width="55.5" height="55.5" as="geometry" />
