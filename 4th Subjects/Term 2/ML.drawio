        </mxCell>
        <mxCell id="id8GIDBzt5Ycg5tB8IS--20" value="&lt;div&gt;The model is trained on &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;un labeled data&lt;/font&gt; and tries to &lt;font style=&quot;color: rgb(0, 0, 204);&quot;&gt;find hidden patterns or&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;structure&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#FFF4C3;strokeColor=#934900;container=0;fontSize=10;fontStyle=0;fontFamily=Mali;spacingLeft=2;align=left;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="id8GIDBzt5Ycg5tB8IS--6" vertex="1">
          <mxGeometry x="336.06551382838546" y="28.629999999999995" width="229.73906684402635" height="36.82" as="geometry" />
        </mxCell>
        <mxCell id="id8GIDBzt5Ycg5tB8IS--21" value="Discover underlying &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;relationships&lt;/font&gt;, groupings, or representations" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#FFF4C3;strokeColor=#934900;container=0;fontSize=10;fontStyle=0;fontFamily=Mali;spacingLeft=2;align=left;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="id8GIDBzt5Ycg5tB8IS--6" vertex="1">
