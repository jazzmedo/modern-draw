        <mxCell id="5cy4-kSeaGVhRb9U9V7c-4" value="`Y = \beta_0 + \beta_1X + \epsilon`" style="text;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontFamily=thmanyah serif text;fontSize=18;fillColor=#FFFBF2;rounded=1;arcSize=17;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="97.75" y="2820" width="180.5" height="50" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-5" value="&lt;div class=&quot;math-block&quot; data-math=&quot;Y = \beta_0 + \beta_1X_1 + \beta_2X_2 + \dots + \beta_kX_k + \epsilon&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;$$Y = \beta_0 + \beta_1X_1 + \beta_2X_2 + \dots + \beta_kX_k + \epsilon$$&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;verticalAlign=middle;align=center;fontSize=17;fontFamily=thmanyah serif text;fillColor=#FFFBF2;rounded=1;strokeColor=none;arcSize=22;" parent="1" vertex="1">
          <mxGeometry x="416.76" y="2820" width="379.99" height="50" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-8" value="" style="group;fontFamily=thmanyah serif text;" parent="1" connectable="0" vertex="1">
          <mxGeometry x="508.255" y="2740" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-6" value="Uses two or more independent variables to predict the same dependent variable." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#FFFBF2;strokeColor=#d6b656;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="5cy4-kSeaGVhRb9U9V7c-8" vertex="1">
          <mxGeometry y="30" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-7" value="Multiple Linear Regression" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="5cy4-kSeaGVhRb9U9V7c-8" vertex="1">
          <mxGeometry x="30" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-9" value="" style="group;fontFamily=thmanyah serif text;" parent="1" connectable="0" vertex="1">
          <mxGeometry x="58" y="2740" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-2" value="&lt;div&gt;Uses one independent variable (predictor) to predict one&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;dependent variable (outcome).&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#FFFBF2;strokeColor=#d6b656;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="5cy4-kSeaGVhRb9U9V7c-9" vertex="1">
          <mxGeometry y="30" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-3" value="Simple Linear Regression" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="5cy4-kSeaGVhRb9U9V7c-9" vertex="1">
          <mxGeometry x="34.625" width="190.75" height="30" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-12" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;`Y`: Dependent variable (what you want to predict)&lt;br&gt;`X_n`: independent variables&lt;br&gt;`\beta_0`: Intercept (value of `Y` when `X=0`)&lt;br&gt;`\beta_1`: Slope (change in `Y` for a one-unit change in `X`)&lt;br&gt;`\epsilon`: Error term&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fontSize=11;verticalAlign=middle;fontFamily=Mali;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=5;rounded=1;arcSize=9;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;textOpacity=50;spacingTop=6;opacity=60;" parent="1" vertex="1">
          <mxGeometry x="269" y="2880" width="285.99" height="90" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-13" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;Sales Prediction&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;fontFamily=Mali;fillColor=#FFF2CC;strokeColor=#d6b656;align=center;spacingLeft=0;rounded=1;arcSize=9;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="1" vertex="1">
          <mxGeometry x="278" y="2990" width="132" height="30" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-14" value="" style="html=1;points=[[0,0,0,0,5],[0,1,0,0,-5],[1,0,0,0,5],[1,1,0,0,-5]];perimeter=orthogonalPerimeter;outlineConnect=0;targetShapes=umlLifeline;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};strokeWidth=1;fillColor=#FFFBF2;strokeColor=#D6B656;fontFamily=thmanyah serif text;rounded=1;arcSize=50;" parent="1" vertex="1">
          <mxGeometry x="330" y="3030" width="3" height="170" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-15" value="`&quot;Sales&quot; = 50 + 3 \times &quot;Ad Spend&quot; + \epsilon`" style="text;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontFamily=thmanyah serif text;fontSize=14;fillColor=#FFFBF2;rounded=1;arcSize=17;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="50" y="3055" width="228" height="30" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-16" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;Single Linear Regression&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;fontFamily=Mali;fillColor=#FFFBF2;strokeColor=#d6b656;align=center;spacingLeft=0;rounded=1;arcSize=9;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="1" vertex="1">
          <mxGeometry x="53.5" y="3000" width="200.5" height="30" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-17" value="&lt;div style=&quot;line-height: 150%;&quot;&gt;الموديل البسيط ده بيعمل prediction للـ sales بناءً على الـ advertising اللي هيتصرف بس. المثال ده بيوضح إن الـ sales بتزيد 3 أضعاف قيمة الـ advertising اللي اتصرف في المتوسط وما فيش أي عوامل تانية، وده مش منطقي لأن الـ sales بتعتمد على عوامل تانية كتير، وهنا بتكمن مشكلة&lt;br&gt;&amp;nbsp;الـ simple linear regression.&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=tanha;fontStyle=0;textDirection=rtl;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="32" y="3100" width="288" height="100" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-19" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;Multi Linear Regression&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;fontFamily=Mali;fillColor=#FFFBF2;strokeColor=#d6b656;align=center;spacingLeft=0;rounded=1;arcSize=9;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="1" vertex="1">
          <mxGeometry x="522.02" y="3000" width="187.98" height="30" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-20" value="\begin{aligned} Sales = &amp;amp; 25 + 2.5 \text{ Ad Spend} - 1.8 \text{ Our Price} \\ &amp;amp; + 1.2 \text{ Competitor Price} + 0.4 \text{ Consumer Confidence} + \epsilon \end{aligned}" style="text;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontFamily=thmanyah serif text;fontSize=14;fillColor=#FFFBF2;rounded=1;arcSize=17;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="350.27" y="3046" width="469.73" height="48" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-21" value="&lt;div style=&quot;line-height: 150%;&quot;&gt;الموديل ده بقى بيعتمد على أكتر من عامل؛ بدل ما يعتمد على الـ advertising بس، لا هو دخل في المعادلة سعرنا إحنا وسعر المنافس وثقة العميل. وبكده بعد ما دخلت أكتر من عامل في المعادلة، الـ prediction والـ decision making هيكون أفضل، بس بما إن في أكتر من عامل فالعملية بتبقى أصعب عشان عايزين data أكتر وصحيحة عشان نطلع دقة مظبوطة.&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=tanha;fontStyle=0;textDirection=rtl;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="340" y="3100" width="478.25" height="70" as="geometry" />
        </mxCell>
        <mxCell id="5cy4-kSeaGVhRb9U9V7c-22" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;rounded=1;imageBorder=default;fontFamily=thmanyah serif text;arcSize=9;" parent="1" vertex="1">
          <mxGeometry x="650" y="2880" width="90" height="90" as="geometry" />
        </mxCell>
