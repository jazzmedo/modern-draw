        <mxCell id="NQuZShNWxpy8CxApDY1Y-235" value="&lt;div&gt;Describe the kernel trick in SVM and how it enables handling non-linear data&lt;/div&gt;&lt;div&gt;without explicit transformation.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;arcSize=5;hachureGap=4;align=left;spacingRight=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=3;fontFamily=Mali;fontSize=15;fontStyle=2;spacingTop=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="NQuZShNWxpy8CxApDY1Y-241" vertex="1">
          <mxGeometry x="26.61" width="603.39" height="55" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-236" value="9" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#666666;fontFamily=Mali;fontStyle=1;fontSize=22;spacingTop=3;fontColor=#333333;rounded=1;fillStyle=hachure;align=center;verticalAlign=middle;spacingLeft=0;spacingBottom=3;arcSize=14;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;spacingRight=2;" parent="NQuZShNWxpy8CxApDY1Y-241" vertex="1">
          <mxGeometry width="55.5" height="55.5" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-286" value="&lt;div style=&quot;line-height: 145%;&quot;&gt;&lt;p data-path-to-node=&quot;0&quot; style=&quot;margin-top: 0px !important;&quot;&gt;الـ SVM في أصله هو موديل تصنيف خطي، فكرته إنه بيدور على أفضل خط أو مستوى يفصل بين مجموعتين من البيانات، وبيحاول يخلي الخط ده في النص بالظبط عشان يسيب أكبر مسافة أمان ممكنة بينه وبين أقرب نقط من الطرفين واللي بنسميها الجيران المؤثرة.&lt;/p&gt;&lt;p data-path-to-node=&quot;0&quot; style=&quot;margin-top: 0px !important;&quot;&gt;الـ Kernel Trick بقى هي صياعة الرياضة في الـ SVM؛ بدل ما تكون البيانات متلغبطة ومعقدة في البعد الحالي ونروح نرفعها فعلياً لأبعاد أعلى بحسابات مكلفة ومعقدة عشان نعرف نفصلها بخط، الـ Kernel بيختصر اللفة دي كلها ويحسب الضرب القياسي المستهدف للبيانات في البعد العالي وهي واقفة في مكانها الأصلي باستخدام دالة ذكية؛ وده بيخلي الموديل يتعلم حدود فصل معقدة وغير خطية بسرعة وكفاءة عالية جداً وبأقل مجهود حسابي، بس عيبه الأساسي إنه بيحتاج تظبيط بارامترات كتير وبيهنج لو حجم البيانات ضخم جداً.&lt;/p&gt;&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fontFamily=tanha;textDirection=rtl;align=right;fontStyle=0" parent="1" vertex="1">
          <mxGeometry x="25.09" y="2520" width="780" height="120" as="geometry" />
        </mxCell>
        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-26" value="Common Techniques" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#cdeb8b;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=0;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="1" vertex="1">
