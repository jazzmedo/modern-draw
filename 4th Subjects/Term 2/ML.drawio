        <mxCell id="SqQxqcDdHDEK13gpGspm-107" value="Uses two or more independent variables to predict the same dependent variable." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#FFFBF2;strokeColor=#d6b656;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" vertex="1" parent="SqQxqcDdHDEK13gpGspm-106">
