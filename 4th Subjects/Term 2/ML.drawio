        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-42" value="&lt;div style=&quot;line-height: 150%;&quot;&gt;Provides guidance by training on the direct mapping from inputs to outputs by minimizing loss functions&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#FFE8E8;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="KX4MmI35KY4r6R5Pd4ZA-51" vertex="1">
