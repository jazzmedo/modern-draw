        <mxCell id="NQuZShNWxpy8CxApDY1Y-109" value="Explain how&amp;nbsp;&lt;span style=&quot;color: rgb(204, 0, 0); font-size: 13px; font-style: normal;&quot;&gt;Distance metrics&lt;/span&gt;&amp;nbsp;and &lt;font style=&quot;color: rgb(0, 0, 204);&quot;&gt;`k`&lt;/font&gt; value selection influence KNN outcomes, with &lt;font style=&quot;color: rgb(0, 153, 153);&quot;&gt;examples of classification vs. regression&lt;/font&gt;." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;arcSize=5;hachureGap=4;align=left;spacingRight=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=3;fontFamily=Mali;fontSize=15;fontStyle=2;spacingTop=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="NQuZShNWxpy8CxApDY1Y-238" vertex="1">
