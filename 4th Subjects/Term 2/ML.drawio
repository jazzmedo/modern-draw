        <mxCell id="NQuZShNWxpy8CxApDY1Y-113" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;Distance metrics&lt;/font&gt; in KNN&amp;nbsp;determine nearest neighbours by finding the&lt;font style=&quot;color: rgb(0, 0, 204);&quot;&gt;&amp;nbsp;`k`&lt;/font&gt; most similar training values (bias-variance tradeoff), examples:&amp;nbsp;Euclidean,&amp;nbsp;Manhattan,&amp;nbsp;Cosine&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=9;" parent="1" vertex="1">
