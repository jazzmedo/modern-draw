        <mxCell id="SqQxqcDdHDEK13gpGspm-105" value="&lt;div class=&quot;math-block&quot; data-math=&quot;Y = \beta_0 + \beta_1X_1 + \beta_2X_2 + \dots + \beta_kX_k + \epsilon&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;$$Y = \beta_0 + \beta_1X_1 + \beta_2X_2 + \dots + \beta_kX_k + \epsilon$$&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;verticalAlign=middle;align=center;fontSize=17;fontFamily=thmanyah serif text;fillColor=#FFFBF2;rounded=1;strokeColor=none;arcSize=22;" vertex="1" parent="SqQxqcDdHDEK13gpGspm-1">
