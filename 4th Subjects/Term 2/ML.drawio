        </mxCell>
        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-47" value="Easy to evaluate test data." style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#FFE8E8;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="KX4MmI35KY4r6R5Pd4ZA-51" vertex="1">
