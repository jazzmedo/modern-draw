        <mxCell id="dxFtP9Y9SaRcnBRwSyjC-34" value="&lt;font face=&quot;Lexend&quot; style=&quot;&quot;&gt;&lt;font size=&quot;1&quot; style=&quot;line-height: 150%;&quot;&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;are built by recursively selecting the best split using impurity measures by Gini Impurity (&lt;/span&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;&lt;font style=&quot;color: rgb(0, 102, 204);&quot;&gt;Faster to compute&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;) or Entropy (&lt;/span&gt;&lt;font style=&quot;color: rgb(0, 102, 204);&quot;&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;Slower due to log calculations,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;the &lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;&lt;font style=&quot;color: rgb(0, 102, 204);&quot;&gt;best split is highest Information Gain&lt;/font&gt;).&lt;/span&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&amp;nbsp;Pruning perform poorly, overfitting that caused from deeply complex trees&lt;/span&gt;&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Handlee;strokeWidth=1;fillColor=#E5F1FF;strokeColor=#000000;fontSize=11;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DHandlee;" vertex="1" parent="1">
