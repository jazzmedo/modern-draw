        </mxCell>
        <mxCell id="id8GIDBzt5Ycg5tB8IS--23" value="&lt;div&gt;When you have lots of&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt; data but no labels&lt;/font&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#FFF4C3;strokeColor=#934900;container=0;fontSize=10;fontStyle=0;fontFamily=Mali;spacingLeft=2;align=left;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="id8GIDBzt5Ycg5tB8IS--6" vertex="1">
          <mxGeometry x="336.11657830201165" y="139.08999999999997" width="229.67778947567496" height="36.82" as="geometry" />
        </mxCell>
        <mxCell id="id8GIDBzt5Ycg5tB8IS--24" value="&lt;font style=&quot;line-height: 140%;&quot;&gt;&lt;span&gt;1.&amp;nbsp;&lt;/span&gt;Results can be &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;hard to evaluate&lt;/font&gt; objectively&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;line-height: 140%;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2.&amp;nbsp;&lt;/span&gt;Clusters or &lt;font style=&quot;color: rgb(0, 0, 204);&quot;&gt;patterns&lt;/font&gt; found may &lt;font style=&quot;color: rgb(0, 0, 204);&quot;&gt;not be useful&lt;/font&gt;&lt;br&gt;&lt;span&gt;3.&amp;nbsp;&lt;/span&gt;Often requires &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;human interpretation&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#FFF4C3;strokeColor=#934900;container=0;fontSize=10;fontStyle=0;fontFamily=Mali;spacingLeft=2;align=left;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="id8GIDBzt5Ycg5tB8IS--6" vertex="1">
          <mxGeometry x="336.11657830201165" y="175.91000000000003" width="229.67778947567496" height="64.09" as="geometry" />
        </mxCell>
