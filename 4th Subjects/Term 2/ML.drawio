        <mxCell id="SqQxqcDdHDEK13gpGspm-110" value="&lt;div&gt;Uses one independent variable (predictor) to predict one&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;dependent variable (outcome).&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#FFFBF2;strokeColor=#d6b656;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" vertex="1" parent="SqQxqcDdHDEK13gpGspm-109">
          <mxGeometry y="30" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="SqQxqcDdHDEK13gpGspm-111" value="Simple Linear Regression" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" vertex="1" parent="SqQxqcDdHDEK13gpGspm-109">
          <mxGeometry x="34.625" width="190.75" height="30" as="geometry" />
        </mxCell>
        <mxCell id="SqQxqcDdHDEK13gpGspm-112" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;`Y`: Dependent variable (what you want to predict)&lt;br&gt;`X_n`: independent variables&lt;br&gt;`\beta_0`: Intercept (value of `Y` when `X=0`)&lt;br&gt;`\beta_1`: Slope (change in `Y` for a one-unit change in `X`)&lt;br&gt;`\epsilon`: Error term&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fontSize=11;verticalAlign=middle;fontFamily=Mali;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=5;rounded=1;arcSize=9;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;textOpacity=50;spacingTop=6;opacity=60;" vertex="1" parent="SqQxqcDdHDEK13gpGspm-1">
          <mxGeometry x="269" y="2018" width="285.99" height="90" as="geometry" />
        </mxCell>
        <mxCell id="SqQxqcDdHDEK13gpGspm-113" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;Sales Prediction&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;fontFamily=Mali;fillColor=#FFF2CC;strokeColor=#d6b656;align=center;spacingLeft=0;rounded=1;arcSize=9;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" vertex="1" parent="SqQxqcDdHDEK13gpGspm-1">
