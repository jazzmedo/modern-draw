        </mxCell>
        <mxCell id="xSRcWVKo4n5UiK_yiS4F-13" value="&lt;div&gt;&lt;b&gt;Types:&lt;/b&gt; Classification and Regression&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" parent="g9hKPX_Nhj4qqDtB2use-4" vertex="1">
          <mxGeometry x="89.88999999999999" y="102.27000000000001" width="239.11" height="36.82" as="geometry" />
        </mxCell>
        <mxCell id="xSRcWVKo4n5UiK_yiS4F-14" value="&lt;div&gt;When you have a &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;clear set of labelled&lt;/font&gt; examples&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" parent="g9hKPX_Nhj4qqDtB2use-4" vertex="1">
          <mxGeometry x="90" y="139.08999999999997" width="239" height="36.82" as="geometry" />
        </mxCell>
        <mxCell id="xSRcWVKo4n5UiK_yiS4F-15" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;font style=&quot;font-size: 10px; line-height: 140%;&quot;&gt;&lt;font face=&quot;Home Candy&quot;&gt;1.&lt;/font&gt;Requires large amounts of &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;high-quality labelled&lt;/font&gt; data,&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-family: &amp;quot;Home Candy&amp;quot;; font-size: 10px;&quot;&gt;2.&lt;/span&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 204), rgb(255, 255, 255));&quot;&gt;Poor &lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;at handling completely &lt;/span&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 204), rgb(255, 255, 255));&quot;&gt;new situations&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; outside the training distribution,3&lt;/span&gt;&lt;span style=&quot;font-family: &amp;quot;Home Candy&amp;quot;; font-size: 10px;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Risk of &lt;/span&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(204, 0, 0), rgb(255, 255, 255));&quot;&gt;overfitting&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" parent="g9hKPX_Nhj4qqDtB2use-4" vertex="1">
          <mxGeometry x="90" y="175.91000000000003" width="239" height="64.09" as="geometry" />
        </mxCell>
        <mxCell id="xSRcWVKo4n5UiK_yiS4F-31" value="&lt;font&gt;&lt;span&gt;Un Supervised Learning&lt;/span&gt;&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D2945E;strokeColor=#934900;fontColor=#ffffff;container=0;fontSize=12;fontFamily=Fustat;fontStyle=1" parent="g9hKPX_Nhj4qqDtB2use-4" vertex="1">
          <mxGeometry x="329.06" width="224.94" height="28.63" as="geometry" />
        </mxCell>
        <mxCell id="xSRcWVKo4n5UiK_yiS4F-32" value="&lt;div&gt;The model is trained on &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;un labelled data&lt;/font&gt; and tries to &lt;font style=&quot;color: rgb(0, 0, 204);&quot;&gt;find hidden patterns or&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;structure&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#FFF4C3;strokeColor=#934900;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" parent="g9hKPX_Nhj4qqDtB2use-4" vertex="1">
          <mxGeometry x="329.06" y="28.629999999999995" width="224.95" height="36.82" as="geometry" />
        </mxCell>
        <mxCell id="xSRcWVKo4n5UiK_yiS4F-33" value="Discover underlying &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;relationships&lt;/font&gt;, groupings, or representations" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#FFF4C3;strokeColor=#934900;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" parent="g9hKPX_Nhj4qqDtB2use-4" vertex="1">
          <mxGeometry x="329.06" y="65.44999999999999" width="224.95" height="36.82" as="geometry" />
        </mxCell>
        <mxCell id="xSRcWVKo4n5UiK_yiS4F-34" value="&lt;div&gt;&lt;b&gt;Tasks:&lt;/b&gt; Clustering, dimensionality reduction, anomaly detection, generative models.&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#FFF4C3;strokeColor=#934900;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" parent="g9hKPX_Nhj4qqDtB2use-4" vertex="1">
          <mxGeometry x="329.06" y="102.27000000000001" width="224.94" height="36.82" as="geometry" />
        </mxCell>
        <mxCell id="xSRcWVKo4n5UiK_yiS4F-35" value="&lt;div&gt;When you have lots of&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt; data but no labels&lt;/font&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#FFF4C3;strokeColor=#934900;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" parent="g9hKPX_Nhj4qqDtB2use-4" vertex="1">
          <mxGeometry x="329.11" y="139.08999999999997" width="224.89" height="36.82" as="geometry" />
        </mxCell>
        <mxCell id="xSRcWVKo4n5UiK_yiS4F-36" value="&lt;font style=&quot;font-size: 10px; line-height: 140%;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Home Candy&amp;quot;;&quot;&gt;1.&amp;nbsp;&lt;/span&gt;Results can be &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;hard to evaluate&lt;/font&gt; objectively&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px; line-height: 140%;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Home Candy&amp;quot;; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2.&amp;nbsp;&lt;/span&gt;Clusters or &lt;font style=&quot;color: rgb(0, 0, 204);&quot;&gt;patterns&lt;/font&gt; found may &lt;font style=&quot;color: rgb(0, 0, 204);&quot;&gt;not be useful&lt;/font&gt;&lt;br&gt;&lt;span style=&quot;font-family: &amp;quot;Home Candy&amp;quot;;&quot;&gt;3.&amp;nbsp;&lt;/span&gt;Often requires &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;human interpretation&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#FFF4C3;strokeColor=#934900;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" parent="g9hKPX_Nhj4qqDtB2use-4" vertex="1">
          <mxGeometry x="329.11" y="175.91000000000003" width="224.89" height="64.09" as="geometry" />
        </mxCell>
        <mxCell id="xSRcWVKo4n5UiK_yiS4F-38" value="&lt;font&gt;&lt;span&gt;Reinforcement&amp;nbsp;Learning&lt;/span&gt;&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#A76A90;strokeColor=#794C69;fontColor=#ffffff;container=0;fontSize=12;fontFamily=Fustat;fontStyle=1" parent="g9hKPX_Nhj4qqDtB2use-4" vertex="1">
          <mxGeometry x="554.0050000000001" width="239.11" height="28.63" as="geometry" />
        </mxCell>
        <mxCell id="xSRcWVKo4n5UiK_yiS4F-39" value="An agent learns by &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;interacting with environment&lt;/font&gt;, receiving rewards or penalties for its actions" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#E6D0DE;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" parent="g9hKPX_Nhj4qqDtB2use-4" vertex="1">
