        <mxCell id="xSRcWVKo4n5UiK_yiS4F-12" value="Learn a &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;mapping&lt;/font&gt; from inputs to outputs to &lt;font style=&quot;color: rgb(0, 0, 204);&quot;&gt;make predictions&lt;/font&gt; on new data" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" parent="g9hKPX_Nhj4qqDtB2use-4" vertex="1">
