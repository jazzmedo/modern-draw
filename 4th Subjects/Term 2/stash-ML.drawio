        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-16" parent="KX4MmI35KY4r6R5Pd4ZA-32" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#cdeb8b;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=0;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="1.Supervised" vertex="1">
