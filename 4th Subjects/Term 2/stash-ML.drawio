        </mxCell>
        <mxCell id="dkQl99vo6uP7NWvQIqdY-9" parent="dkQl99vo6uP7NWvQIqdY-28" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#E9E7FF;strokeColor=#56517e;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Big datasets frequently include sensitive personal information, leading to privacy violations during human review." vertex="1">
          <mxGeometry height="60" width="265" as="geometry" />
        </mxCell>
        <mxCell id="dkQl99vo6uP7NWvQIqdY-17" parent="dkQl99vo6uP7NWvQIqdY-28" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#E9E7FF;strokeColor=#56517e;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Human labellers naturally embed societal biases, leading to bias amplification once scaled through training." vertex="1">
          <mxGeometry height="60" width="265" y="60" as="geometry" />
        </mxCell>
        <mxCell id="dkQl99vo6uP7NWvQIqdY-18" parent="dkQl99vo6uP7NWvQIqdY-28" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#E9E7FF;strokeColor=#56517e;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Data-labelling tasks often rely on the labour exploitation of low-wage workers in developing regions." vertex="1">
          <mxGeometry height="60" width="265" y="120" as="geometry" />
        </mxCell>
        <mxCell id="dkQl99vo6uP7NWvQIqdY-29" parent="1" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Fustat;fontStyle=0;textDirection=rtl;fontSize=12;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;" value="مميزات الـ labeled data هي إن لما الموديل بيتمرن عليها بتطلع دقة عالية في الأنماط الصعبة، وبتدي ضمان إن الـ data دي صحيحة وعلى أساس ده بتقيم الموديل بشكل أوضح، وكمان الـ data دي بنعرف نعالجها بسرعة بفضل الـ distributed frameworks اللي متاحة حاليًا، والشركات بتقدر تطلع منها عائد مادي بشكل أسرع.&lt;div&gt;&lt;br&gt;عيوبها بقى بتكمن في إن عشان نعمل labeling للـ data دي الموضوع مكلف وبطيء جدًا؛ لأن العنصر البشري بيتدخل عشان تطلع data كويسة وما ينفعش معاها automation. وبعد حجم معين من الـ data، أي data جديدة بتقدم تحسينات طفيفة تكاد تكون لا تُذكر. ده غير بقى إن لو الـ labeling فيه noise أو مش حيادي مش هتطلع دقة عالية. ولو الـ data اللي هيتمرن عليها الـ model ضخمة، بيبقى في فرصة إن يحصل overfitting بمعنى إن الموديل بيحفظ الـ data مش بيفهمها، فعند التوقع مش هيطلع نتائج كويسة. فوق كل ده، بيحتاج resources قوية ومكلفة، ده غير إن الـ data مش بتبقى متحدثة ومواكبة للأحداث اللي بتحصل.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;برضو من الحاجات اللي لازم تبقى في الحسبان إن الـ data دي ممكن يكون فيها معلومات حساسة لأشخاص وده بيخترق قوانين الخصوصية. غير كده، ممكن تكون الـ data دي اأشخاص اللي عملوا لها labeling ليهم انحيازات أو توجهات معينة، عشان إحنا بطبيعتنا كبشر مش محايدين 100%. غير كده بيحصل إن الشركات بتستغل الناس اللي بتعمل labeling بمرتبات ضئيلة في الدول النامية.&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="800" x="18.25" y="1840" as="geometry" />
        </mxCell>
        <mxCell id="dkQl99vo6uP7NWvQIqdY-30" connectable="0" parent="1" style="group;fontFamily=thmanyah serif text;" value="" vertex="1">
          <mxGeometry height="55.5" width="790" x="17" y="2030" as="geometry" />
