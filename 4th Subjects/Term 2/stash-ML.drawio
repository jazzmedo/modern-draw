        <mxCell id="CG8b47xFTE-a7-1MDE-e-166" parent="CG8b47xFTE-a7-1MDE-e-164" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Handlee;strokeWidth=1;fillColor=#A9D3E6;strokeColor=default;fontSize=17;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=2;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DHandlee;spacingBottom=0;spacingTop=3;" value="Gini" vertex="1">
          <mxGeometry height="24" width="60.99949164972166" x="206.00517783926125" as="geometry" />
