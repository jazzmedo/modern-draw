        <mxCell id="CG8b47xFTE-a7-1MDE-e-121" parent="CG8b47xFTE-a7-1MDE-e-119" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Simple Linear Regression" vertex="1">
