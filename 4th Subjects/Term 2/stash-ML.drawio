        <mxCell id="NQuZShNWxpy8CxApDY1Y-269" parent="NQuZShNWxpy8CxApDY1Y-281" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#F9EBFF;strokeColor=#9673a6;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="&lt;div&gt;Avoids expensive high-dimensional calculations.&lt;/div&gt;" vertex="1">
