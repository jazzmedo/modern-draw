        <mxCell id="NQuZShNWxpy8CxApDY1Y-49" parent="NQuZShNWxpy8CxApDY1Y-59" style="text;whiteSpace=wrap;html=1;fontStyle=0;verticalAlign=middle;fontSize=11;" value="`\text{Gini} = 1 - \sum_{k=1}^{K} p_k^2`" vertex="1">
          <mxGeometry height="50" width="99.02" x="317.48" y="68" as="geometry" />
