        <mxCell id="NQuZShNWxpy8CxApDY1Y-3" parent="1" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Fustat;fontStyle=0;textDirection=rtl;fontSize=10;" value="الموديل بيبدأ من الـ root node ومعاه الـ dataset كلها، وبيشوف أفضل split أو feature بتقسم الـ tree، وبعدين بنقسم الـ data في الفرعين يمين وشمال بحيث نحقق أعلى purity أو نقاوة، وبعدين بنكرر نفس الخطوات لغاية لما نوصل للمعيار اللي على أساسه هنقف عنده، وبعدين عند الوصول للـ leaf node؛ في الـ classification بناخد برأي الأغلبية، إنما في الـ regression بناخد متوسط القيم." vertex="1">
          <mxGeometry height="80" width="256" x="25.75" y="3030" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-28" connectable="0" parent="1" style="group;fontFamily=Handlee;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DHandlee;" value="" vertex="1">
          <mxGeometry height="130" width="280.0000000000001" x="20" y="3120" as="geometry" />
