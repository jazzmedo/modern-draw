        <mxCell id="CG8b47xFTE-a7-1MDE-e-310" parent="CG8b47xFTE-a7-1MDE-e-308" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="5" vertex="1">
          <mxGeometry height="30" width="30" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-311" parent="CG8b47xFTE-a7-1MDE-e-308" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#F9EBFF;strokeColor=#9673a6;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="&lt;div&gt;Kernel and parameter selection require tuning.&lt;/div&gt;" vertex="1">
          <mxGeometry height="50" width="210" x="30" y="30" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-312" parent="CG8b47xFTE-a7-1MDE-e-308" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="Limitations" vertex="1">
          <mxGeometry height="30" width="210" x="30" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-313" parent="CG8b47xFTE-a7-1MDE-e-1" style="text;whiteSpace=wrap;html=1;fontFamily=Fustat;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;textDirection=rtl;align=right;fontStyle=0" value="&lt;p data-path-to-node=&quot;0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;الـ SVM في أصله هو موديل تصنيف خطي ذكي، فكرته إنه بيدور على أفضل خط أو مستوى يفصل بين مجموعتين من البيانات، وبيحاول يخلي الخط ده في النص بالظبط عشان يسيب أكبر مسافة أمان ممكنة بينه وبين أقرب نقط من الطرفين واللي بنسميها الجيران المؤثرة.&lt;/p&gt;&lt;p data-path-to-node=&quot;0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;الـ Kernel Trick بقى هي صياعة الرياضة في الـ SVM؛ بدل ما تكون البيانات متلغبطة ومعقدة في البعد الحالي ونروح نرفعها فعلياً لأبعاد أعلى بحسابات مكلفة ومعقدة عشان نعرف نفصلها بخط، الـ Kernel بيختصر اللفة دي كلها ويحسب الضرب القياسي المستهدف للبيانات في البعد العالي وهي واقفة في مكانها الأصلي باستخدام دالة ذكية؛ وده بيخلي الموديل يتعلم حدود فصل معقدة وغير خطية بسرعة وكفاءة عالية جداً وبأقل مجهود حسابي، بس عيبه الأساسي إنه بيحتاج تظبيط بارامترات كتير وبيهنج لو حجم البيانات ضخم جداً.&lt;/p&gt;" vertex="1">
          <mxGeometry height="110" width="780" x="30" y="5190" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-314" parent="CG8b47xFTE-a7-1MDE-e-1" style="triangle;whiteSpace=wrap;html=1;dashed=0;direction=south;fillColor=#e51400;fontColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Kufam;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DKufam;verticalAlign=top;spacingTop=5;fontStyle=1;fontSize=16;rounded=1;arcSize=6;" value="" vertex="1">
