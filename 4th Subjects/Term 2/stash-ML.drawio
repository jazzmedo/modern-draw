        </mxCell>
        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-40" parent="KX4MmI35KY4r6R5Pd4ZA-51" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffcccc;strokeColor=#666666;fontSize=14;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Strengths" vertex="1">
          <mxGeometry height="30" width="242.33" x="242.33000000000004" as="geometry" />
        </mxCell>
        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-41" parent="KX4MmI35KY4r6R5Pd4ZA-51" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffcccc;strokeColor=#666666;fontSize=14;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Weaknesses" vertex="1">
          <mxGeometry height="30" width="242.33" x="484.6700000000001" as="geometry" />
        </mxCell>
        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-42" parent="KX4MmI35KY4r6R5Pd4ZA-51" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#FFE8E8;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Provides explicit guidance and precise optimization by training on the direct mapping from inputs to outputs by minimizing loss functions, and the algorithm adjusts its parameters based on clear feedback." vertex="1">
          <mxGeometry height="100" width="242.33" y="30" as="geometry" />
        </mxCell>
        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-44" parent="KX4MmI35KY4r6R5Pd4ZA-51" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#FFE8E8;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Delivers high accuracy when high-quality data is available." vertex="1">
          <mxGeometry height="40" width="242.33333333333334" x="242.33333333333337" y="30" as="geometry" />
        </mxCell>
        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-45" parent="KX4MmI35KY4r6R5Pd4ZA-51" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#FFE8E8;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Scales reliably with more labeled data." vertex="1">
          <mxGeometry height="30" width="242.33" x="242.33000000000004" y="70" as="geometry" />
        </mxCell>
        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-47" parent="KX4MmI35KY4r6R5Pd4ZA-51" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#FFE8E8;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Easy to evaluate against test data." vertex="1">
          <mxGeometry height="30" width="242.33" x="242.32" y="100" as="geometry" />
        </mxCell>
        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-48" parent="KX4MmI35KY4r6R5Pd4ZA-51" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#FFE8E8;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Performance bottleneck where too little data causes overfitting, noisy or biased lables make errors, and it is expensive because it requires human experts to label the data for good quality." vertex="1">
          <mxGeometry height="100" width="242.33" x="484.6700000000001" y="30" as="geometry" />
        </mxCell>
        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-52" parent="1" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Fustat;fontStyle=0;textDirection=rtl;fontSize=12;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;" value="&lt;div&gt;الـ labeled data هي لما يكون عندي data الـ target بتاعها متوضح وتعتبر أساس الـ supervised learning. ليها دور في إنها بتعلم الموديل العلاقة المباشرة بين الـ input والـ output وتقليل نسبة الخطأ قدر الإمكان، بالإضافة لـ ده هي بتوفر للموديل feedback لتصحيح توقعاته الخطأ عكس الـ unlabeled data.&lt;/div&gt;&lt;div&gt;طيب إيه نقط القوة بتاعتها؟ إنها بتوفر دقة عالية جدًا لو جودة الـ data دي عالية، وكل ما زادت الـ data كل ما زادت قدرة الموديل على الفهم، غير إن تقييم الموديل بيبقى دقيق وسهل لأن عندك الإجابات اللي بتقيس على أساسها.&lt;/div&gt;&lt;div&gt;بالنسبة بقى لعيوبها، إن لو الـ data قليلة بيحصل overfitting، غير كده بقى تجميع الـ data بيبقى صعب ومكلف لأنه عشان تجيب data جودتها عالية لازم تعتمد على العنصر البشري.&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="757" x="39.75" y="1430" as="geometry" />
        </mxCell>
        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-57" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/jpeg,;rounded=1;imageBorder=default;arcSize=12;fontFamily=thmanyah serif text;" value="" vertex="1">
          <mxGeometry height="64.6" width="87" x="724" y="1550" as="geometry" />
        </mxCell>
        <mxCell id="dkQl99vo6uP7NWvQIqdY-10" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Fustat;fontStyle=0;fontSize=12;textDirection=rtl;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;" value="نصيحة بس قبل ما تبدأ وتتخض من حجم الأسئلة، الدكتور قال افهم السؤال واكتب اللي فهمته، مش مطلوب منك تحفظ كل ده، افهمه واكتب بطريقتك. حاولت أشرح الأسئلة - على حسب فهمي - بالعربي عشان نحاول نفهم الأسئلة ما نحفظهاش." vertex="1">
          <mxGeometry height="40" width="747.67" x="44.41" y="70" as="geometry" />
        </mxCell>
