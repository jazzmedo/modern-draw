        <mxCell id="5cy4-kSeaGVhRb9U9V7c-2" parent="5cy4-kSeaGVhRb9U9V7c-9" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#FFFBF2;strokeColor=#d6b656;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="&lt;div&gt;Uses one independent variable (predictor) to predict one&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;dependent variable (outcome).&lt;/span&gt;&lt;/div&gt;" vertex="1">
