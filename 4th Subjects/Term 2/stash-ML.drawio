        <mxCell id="NQuZShNWxpy8CxApDY1Y-122" parent="NQuZShNWxpy8CxApDY1Y-158" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;container=0;fontSize=11;fontStyle=0;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;align=left;spacingLeft=3;" value="Straight-line distance; sensitive to outliers and scale; best for continuous, low-medium dimensions" vertex="1">
