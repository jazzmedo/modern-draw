        <mxCell id="CG8b47xFTE-a7-1MDE-e-67" parent="CG8b47xFTE-a7-1MDE-e-61" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mali;fontStyle=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Semi-Supervised Learning" vertex="1">
