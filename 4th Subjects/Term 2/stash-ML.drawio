        <mxCell id="CG8b47xFTE-a7-1MDE-e-124" parent="CG8b47xFTE-a7-1MDE-e-1" style="html=1;points=[[0,0,0,0,5],[0,1,0,0,-5],[1,0,0,0,5],[1,1,0,0,-5]];perimeter=orthogonalPerimeter;outlineConnect=0;targetShapes=umlLifeline;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};strokeWidth=1;fillColor=#FFFBF2;strokeColor=#D6B656;fontFamily=thmanyah serif text;rounded=1;arcSize=50;" value="" vertex="1">
