        <mxCell id="NQuZShNWxpy8CxApDY1Y-268" parent="NQuZShNWxpy8CxApDY1Y-281" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="Advantages" vertex="1">
