          <mxGeometry height="28.32964367603725" width="286.7683836646334" x="113.11008842634376" y="76.67999999999984" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-131" parent="NQuZShNWxpy8CxApDY1Y-158" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;container=0;fontSize=11;fontStyle=0;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;align=left;spacingLeft=3;" value="&lt;div&gt;Generalization of Euclidean and Manhattan&lt;/div&gt;" vertex="1">
          <mxGeometry height="28.32964367603725" width="286.7683836646334" x="113.11008842634376" y="105.00964367603683" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-144" parent="NQuZShNWxpy8CxApDY1Y-158" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;container=0;fontSize=11;fontStyle=0;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;align=left;spacingLeft=3;" value="&lt;font face=&quot;Helvetica&quot;&gt;Best for high-dimensional text/sparse data&lt;/font&gt;" vertex="1">
          <mxGeometry height="28.32964367603725" width="286.7683836646334" x="113.11008842634376" y="133.34071264792556" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-145" parent="NQuZShNWxpy8CxApDY1Y-158" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;container=0;fontSize=11;fontStyle=0;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;align=left;spacingLeft=3;" value="Accounts for feature correlations and scale" vertex="1">
          <mxGeometry height="28.32964367603725" width="286.7683836646334" x="113.11008842634376" y="161.67035632396255" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-162" parent="NQuZShNWxpy8CxApDY1Y-163" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=9;" value="&lt;div&gt;Predicting house prices with features size (sq. ft.) and distance to city centre (km).&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Without scaling, Euclidean distance will be dominated by house size. Using Mahalanobis&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;would handle correlations.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="343.25" x="425.7" y="120" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-164" parent="NQuZShNWxpy8CxApDY1Y-163" style="text;whiteSpace=wrap;align=right;textDirection=rtl;fontFamily=Fustat;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;" value="الـ Distance Metrics هي المسطرة اللي الموديل بيقيس بيها مين النقط القريبة والشبيهة ببعض عشان يحدد جيرانها، والمشكلة هنا إن لو عندك ميزات بأرقام كبيرة وميزات بأرقام صغيرة (زي مساحة بيت بآلاف الأقدام مقابل بعده عن السنتر بكام كيلومتر بس)، الميزة الكبيرة هتبلع الصغيرة وتسيطر على الحسابات تماماً؛ وعشان كده الـ Example ده بيوضح إنك لو قست بـ Euclidean من غير ما تنسق الأرقام الموديل هيعمى ومش هيشوف غير مساحة البيت، لكن لو استخدمت Mahalanobis هيظبط العلاقات والنسب دي لوحده ويطلع الحسابات صح ومظبوطة." vertex="1">
          <mxGeometry height="120" width="348.95" x="420" y="200" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-165" parent="1" style="text;whiteSpace=wrap;html=1;textDirection=rtl;align=right;fontFamily=Fustat;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;fontStyle=0" value="الـ &lt;span data-index-in-node=&quot;4&quot; data-path-to-node=&quot;0&quot;&gt;KNN&lt;/span&gt; بيخزن بيانات التدريب وأول ما تديله نقطة جديدة يروح يدور على أقرب جيران ليها (&lt;span data-index-in-node=&quot;112&quot; data-path-to-node=&quot;0&quot;&gt;neighbours&lt;/span&gt;) بناءً على المسافة. وبعدها بيتوقع قيمتها؛ لو تصنيف (&lt;span data-index-in-node=&quot;175&quot; data-path-to-node=&quot;0&quot;&gt;Classification&lt;/span&gt;) بياخد رأي الأغلبية، ولو رقم (&lt;span data-index-in-node=&quot;220&quot; data-path-to-node=&quot;0&quot;&gt;Regression&lt;/span&gt;) بيحسب متوسط قيم الجيران دول." vertex="1">
          <mxGeometry height="70" width="317" x="479.76" y="3620" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-193" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="300" width="783" x="22" y="4040" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-167" parent="NQuZShNWxpy8CxApDY1Y-193" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Handlee;strokeWidth=1;fillColor=#ffcc99;strokeColor=#36393d;fontSize=17;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DHandlee;spacingBottom=0;spacingTop=2;" value="Role of K-Value Selection" vertex="1">
          <mxGeometry height="30" width="193" x="295" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-168" parent="NQuZShNWxpy8CxApDY1Y-193" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fillColor=none;arcSize=3;strokeWidth=1;dashed=1;dashPattern=8 4 1 4;" value=" " vertex="1">
          <mxGeometry height="270" width="783" y="30" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-169" parent="NQuZShNWxpy8CxApDY1Y-193" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=9;" value="&lt;div&gt;k is the number of neighbours considered. It is a hyper parameter that controls the bias-&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;variance tradeoff.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="755.59" x="12.200000000000003" y="50" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-183" parent="NQuZShNWxpy8CxApDY1Y-193" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=9;" value="Small k (e.g., k=1 or 3): Captures local patterns well. High variance, low bias. Sensitive to noise/outliers that causes overfitting." vertex="1">
          <mxGeometry height="40" width="397.8" x="372.2" y="110" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-185" parent="NQuZShNWxpy8CxApDY1Y-193" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=9;" value="Large k (e.g., k=20 or more): Smoother decision surface. High bias, low variance. Can underfit by including distant, irrelevant neighbours." vertex="1">
          <mxGeometry height="40" width="397.8" x="372.2" y="160" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-191" parent="NQuZShNWxpy8CxApDY1Y-193" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="&lt;div&gt;Weighted KNN (optional improvement):&lt;/div&gt;&lt;div&gt;Give closer neighbours higher weight (e.g., `\text{weight} = \frac{1}{\text{distance}}`).&lt;/div&gt;" vertex="1">
          <mxGeometry height="50" width="360" x="12.200000000000045" y="240" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-184" parent="NQuZShNWxpy8CxApDY1Y-193" style="text;whiteSpace=wrap;align=right;textDirection=rtl;fontFamily=Fustat;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;" value="الـ `k` هو عدد الجيران اللي الموديل بياخد رأيهم؛ لو اخترت `k` صغير أوي الموديل هيبقى حساس للـ Noise ويحفظ الداتا (Overfitting)، ولو كبّرته زيادة عن اللزوم هياخد رأي جيران بعاد ملهمش دعوة ويبقى بليد (Underfitting). وعشان تختار الـ `k` الصح المثالية بتجرب الـ Cross-validation أو الـ Elbow method، وممكن تطور الموديل بـ Weighted KNN عشان تدّي النقط الأقرب وزن وتأثير أكبر في القرار." vertex="1">
          <mxGeometry height="80" width="377.79" x="392.21" y="210" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-192" connectable="0" parent="NQuZShNWxpy8CxApDY1Y-193" style="group" value="" vertex="1">
          <mxGeometry height="130" width="220" x="18" y="90" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-187" parent="NQuZShNWxpy8CxApDY1Y-192" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="Optimal `k` Selection Methods" vertex="1">
          <mxGeometry height="25" width="170" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-188" parent="NQuZShNWxpy8CxApDY1Y-192" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="Cross-validation (most reliable)." vertex="1">
          <mxGeometry height="25" width="192" x="28" y="25" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-189" parent="NQuZShNWxpy8CxApDY1Y-192" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="Elbow method: Plot error rate vs. `k` and look for the &quot;elbow&quot;." vertex="1">
          <mxGeometry height="40" width="192" x="28" y="50" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-190" parent="NQuZShNWxpy8CxApDY1Y-192" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="Rule of thumb: Start with `k = \sqrt{n}` , (`n` = number of samples)." vertex="1">
          <mxGeometry height="40" width="192" x="28" y="90" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-194" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="330" width="783" x="22.000000000000004" y="4360" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-195" parent="NQuZShNWxpy8CxApDY1Y-194" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Handlee;strokeWidth=1;fillColor=#ffcc99;strokeColor=#36393d;fontSize=17;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DHandlee;spacingBottom=0;spacingTop=2;" value="Classification vs Regression in KNN" vertex="1">
          <mxGeometry height="30" width="277" x="253" as="geometry" />
