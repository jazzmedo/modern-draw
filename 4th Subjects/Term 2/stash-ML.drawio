        <mxCell id="NQuZShNWxpy8CxApDY1Y-113" parent="1" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=9;" value="K-Nearest Neighbours (KNN) is a simple supervised learning algorithm used for both classification and regression. It makes predictions by finding the k most similar training examples (neighbours) to a new data point and aggregating their values." vertex="1">
