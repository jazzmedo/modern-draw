        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-23" connectable="0" parent="KX4MmI35KY4r6R5Pd4ZA-32" style="group;fontFamily=thmanyah serif text;" value="" vertex="1">
          <mxGeometry height="50" width="452" x="1" y="105" as="geometry" />
