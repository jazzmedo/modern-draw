        <mxCell id="NQuZShNWxpy8CxApDY1Y-153" parent="NQuZShNWxpy8CxApDY1Y-163" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=9;" value="Distance metrics determine which points are considered &quot;nearest.&quot; The choice directly affects neighbour selection and final predictions, especially in datasets with varying scales, dimensions, or data types." vertex="1">
