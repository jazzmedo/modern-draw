        <mxCell id="CG8b47xFTE-a7-1MDE-e-125" parent="CG8b47xFTE-a7-1MDE-e-1" style="text;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontFamily=thmanyah serif text;fontSize=14;fillColor=#FFFBF2;rounded=1;arcSize=17;strokeColor=none;" value="`&quot;Sales&quot; = 50 + 3 \times &quot;Ad Spend&quot; + \epsilon`" vertex="1">
          <mxGeometry height="30" width="228" x="53" y="1995" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-126" parent="CG8b47xFTE-a7-1MDE-e-1" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;fontFamily=Mali;fillColor=#FFFBF2;strokeColor=#d6b656;align=center;spacingLeft=0;rounded=1;arcSize=9;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;Single Linear Regression&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="200.5" x="56.5" y="1940" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-127" parent="CG8b47xFTE-a7-1MDE-e-1" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Fustat;fontStyle=0;textDirection=rtl;fontSize=12;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;" value="الموديل البسيط ده بيعمل prediction للـ sales بناءً على الـ advertising اللي هيتصرف بس. المثال ده بيوضح إن الـ sales بتزيد 3 أضعاف قيمة الـ advertising اللي اتصرف في المتوسط وما فيش أي عوامل تانية، وده مش منطقي لأن الـ sales بتعتمد على عوامل تانية كتير، وهنا بتكمن مشكلة الـ simple linear regression." vertex="1">
          <mxGeometry height="100" width="288" x="35" y="2040" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-128" parent="CG8b47xFTE-a7-1MDE-e-1" style="text;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;fontFamily=Mali;fillColor=#FFFBF2;strokeColor=#d6b656;align=center;spacingLeft=0;rounded=1;arcSize=9;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;Multi Linear Regression&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="187.98" x="525.02" y="1940" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-129" parent="CG8b47xFTE-a7-1MDE-e-1" style="text;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontFamily=thmanyah serif text;fontSize=14;fillColor=#FFFBF2;rounded=1;arcSize=17;strokeColor=none;" value="\begin{aligned} Sales = &amp;amp; 25 + 2.5 \text{ Ad Spend} - 1.8 \text{ Our Price} \\ &amp;amp; + 1.2 \text{ Competitor Price} + 0.4 \text{ Consumer Confidence} + \epsilon \end{aligned}" vertex="1">
          <mxGeometry height="48" width="469.73" x="353.27" y="1986" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-130" parent="CG8b47xFTE-a7-1MDE-e-1" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Fustat;fontStyle=0;textDirection=rtl;fontSize=12;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;" value="الموديل ده بقى بيعتمد على أكتر من عامل؛ بدل ما يعتمد على الـ advertising بس، لا هو دخل في المعادلة سعرنا إحنا وسعر المنافس وثقة العميل. وبكده بعد ما دخلت أكتر من عامل في المعادلة، الـ prediction والـ decision making هيكون أفضل، بس بما إن في أكتر من عامل فالعملية بتبقى أصعب عشان عايزين data أكتر وصحيحة عشان نطلع دقة مظبوطة." vertex="1">
          <mxGeometry height="70" width="478.25" x="343" y="2040" as="geometry" />
        </mxCell>
