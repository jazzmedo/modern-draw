        <mxCell id="5cy4-kSeaGVhRb9U9V7c-36" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/jpeg,;rounded=1;imageBorder=default;arcSize=9;" value="" vertex="1">
