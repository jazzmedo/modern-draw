        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-68" parent="CG8b47xFTE-a7-1MDE-e-1" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Fustat;fontStyle=0;textDirection=rtl;fontSize=12;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;" value="الـ Semi-Supervised بيشتغل عن طريق إن الموديل بيبدأ يعمل training على كمية صغيرة من الـ labeled data، وبعدين الموديل بيحاول يشوف أنماط أو هيكل متكرر على كمية كبيرة من الـ unlabeled data، وبنكرر الـ training لغاية لما الـ accuracy بتاعة الموديل تتحسن." vertex="1">
          <mxGeometry height="120" width="297.14" x="499.03" y="627" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-69" connectable="0" parent="CG8b47xFTE-a7-1MDE-e-1" style="group;fontFamily=thmanyah serif text;" value="" vertex="1">
          <mxGeometry height="155" width="453" x="17" y="617" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-70" parent="CG8b47xFTE-a7-1MDE-e-69" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#d5e8d4;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="In the beginning,&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;the model is trained on a limited amount of labeled data.&lt;/span&gt;" vertex="1">
          <mxGeometry height="35" width="340" x="113" y="35" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-71" parent="CG8b47xFTE-a7-1MDE-e-69" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#cdeb8b;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=0;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="1.Supervised" vertex="1">
          <mxGeometry height="35" width="90" x="23.5" y="35" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-72" parent="CG8b47xFTE-a7-1MDE-e-69" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#cdeb8b;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=4;verticalAlign=middle;spacingTop=0;spacingRight=0;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="A semi-supervised model bridges the gap between supervised and unsupervised approaches. It is applied in the following steps." vertex="1">
          <mxGeometry height="35" width="453" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-73" parent="CG8b47xFTE-a7-1MDE-e-69" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#d5e8d4;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Then the model tries to extract hidden structures and patterns from a large amount of unlabeled data" vertex="1">
          <mxGeometry height="35" width="340" x="113" y="70" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-74" parent="CG8b47xFTE-a7-1MDE-e-69" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#cdeb8b;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=0;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="2.Unsupervised" vertex="1">
          <mxGeometry height="35" width="90" x="23.5" y="70" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-75" connectable="0" parent="CG8b47xFTE-a7-1MDE-e-69" style="group;fontFamily=thmanyah serif text;" value="" vertex="1">
          <mxGeometry height="50" width="452" x="1" y="105" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-76" parent="CG8b47xFTE-a7-1MDE-e-75" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#d5e8d4;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="&lt;div&gt;The model learns from the labeled data first, then uses its own predictions&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(pseudo-labels) or consistency rules on unlabeled data to improve itself iteratively.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="50" width="402" x="50" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-77" parent="CG8b47xFTE-a7-1MDE-e-75" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#cdeb8b;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=0;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Key&lt;br&gt;Idea" vertex="1">
          <mxGeometry height="50" width="50" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-78" parent="CG8b47xFTE-a7-1MDE-e-69" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;opacity=5;fontFamily=thmanyah serif text;" value="" vertex="1">
          <mxGeometry height="143" width="143" x="310" y="6.5" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-79" connectable="0" parent="CG8b47xFTE-a7-1MDE-e-1" style="group" value="" vertex="1">
          <mxGeometry height="55.5" width="790" x="18" y="830" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-80" parent="CG8b47xFTE-a7-1MDE-e-79" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;arcSize=5;hachureGap=4;align=left;spacingRight=2;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontFamily=Mali;fontSize=15;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;fontStyle=2" value="Discuss the role of labeled data in supervised learning and how it impacts model performance compared to other ML types." vertex="1">
          <mxGeometry height="55" width="763.39" x="26.61" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-81" parent="CG8b47xFTE-a7-1MDE-e-79" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#666666;fontFamily=Mali;fontStyle=1;fontSize=22;spacingTop=3;fontColor=#333333;rounded=1;fillStyle=hachure;align=center;verticalAlign=middle;spacingLeft=0;spacingBottom=3;arcSize=14;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;spacingRight=2;" value="3" vertex="1">
          <mxGeometry height="55.5" width="55.5" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-92" parent="CG8b47xFTE-a7-1MDE-e-1" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Fustat;fontStyle=0;textDirection=rtl;fontSize=12;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;" value="&lt;div&gt;الـ labeled data هي لما يكون عندي data الـ target بتاعها متوضح وتعتبر أساس الـ supervised learning. ليها دور في إنها بتعلم الموديل العلاقة المباشرة بين الـ input والـ output وتقليل نسبة الخطأ قدر الإمكان، بالإضافة لـ ده هي بتوفر للموديل feedback لتصحيح توقعاته الخطأ عكس الـ unlabeled data.&lt;/div&gt;&lt;div&gt;طيب إيه نقط القوة بتاعتها؟ إنها بتوفر دقة عالية جدًا لو جودة الـ data دي عالية، وكل ما زادت الـ data كل ما زادت قدرة الموديل على الفهم، غير إن تقييم الموديل بيبقى دقيق وسهل لأن عندك الإجابات اللي بتقيس على أساسها.&lt;/div&gt;&lt;div&gt;بالنسبة بقى لعيوبها، إن لو الـ data قليلة بيحصل overfitting، غير كده بقى تجميع الـ data بيبقى صعب ومكلف لأنه عشان تجيب data جودتها عالية لازم تعتمد على العنصر البشري.&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="757" x="41.75" y="1040" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-93" parent="CG8b47xFTE-a7-1MDE-e-1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/jpeg,;rounded=1;imageBorder=default;arcSize=12;fontFamily=thmanyah serif text;" value="" vertex="1">
          <mxGeometry height="64.6" width="87" x="726" y="1180" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-94" parent="CG8b47xFTE-a7-1MDE-e-1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Fustat;fontStyle=0;fontSize=12;textDirection=rtl;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;" value="نصيحة بس قبل ما تبدأ وتتخض من حجم الأسئلة، الدكتور قال افهم السؤال واكتب اللي فهمته، مش مطلوب منك تحفظ كل ده، افهمه واكتب بطريقتك. حاولت أشرح الأسئلة - على حسب فهمي - بالعربي عشان نحاول نفهم الأسئلة ما نحفظهاش." vertex="1">
          <mxGeometry height="40" width="747.67" x="44.41" y="70" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-95" connectable="0" parent="CG8b47xFTE-a7-1MDE-e-1" style="group;fontFamily=thmanyah serif text;" value="" vertex="1">
          <mxGeometry height="55.5" width="690" x="19" y="1184.55" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-96" parent="CG8b47xFTE-a7-1MDE-e-95" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;arcSize=5;hachureGap=4;align=left;spacingRight=2;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontFamily=Mali;fontSize=15;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;fontStyle=2" value="Analyze the advantages and disadvantages of supervised learning in handling big data, including ethical considerations for labelling." vertex="1">
          <mxGeometry height="55" width="663.39" x="26.61" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-97" parent="CG8b47xFTE-a7-1MDE-e-95" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#666666;fontFamily=Mali;fontStyle=1;fontSize=22;spacingTop=3;fontColor=#333333;rounded=1;fillStyle=hachure;align=center;verticalAlign=middle;spacingLeft=0;spacingBottom=3;arcSize=14;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;spacingRight=2;" value="4" vertex="1">
          <mxGeometry height="55.5" width="55.5" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-98" parent="CG8b47xFTE-a7-1MDE-e-1" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#d0cee2;strokeColor=#56517e;fontSize=13;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Disadvantages with Labeled Big Data" vertex="1">
          <mxGeometry height="30" width="265" x="284.7496973865199" y="1260" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-99" parent="CG8b47xFTE-a7-1MDE-e-1" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#d0cee2;strokeColor=#56517e;fontSize=13;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Ethical Considerations" vertex="1">
          <mxGeometry height="30" width="265" x="549.75030261348" y="1260" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-100" parent="CG8b47xFTE-a7-1MDE-e-1" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#E9E7FF;strokeColor=#56517e;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Expensive Labeling and training" vertex="1">
          <mxGeometry height="30" width="265" x="284.7496973865199" y="1290" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-105" parent="CG8b47xFTE-a7-1MDE-e-1" style="rounded=0;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#d0cee2;strokeColor=#56517e;fontSize=13;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Advantages with Labeled Big Data" vertex="1">
          <mxGeometry height="30" width="265" x="20" y="1260" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-110" parent="CG8b47xFTE-a7-1MDE-e-1" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Fustat;fontStyle=0;textDirection=rtl;fontSize=12;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;" value="مميزات الـ labeled data هي إن لما الموديل بيتمرن عليها بتطلع دقة عالية في الأنماط الصعبة، وبتدي ضمان إن الـ data دي صحيحة وعلى أساس ده بتقيم الموديل بشكل أوضح، وكمان الـ data دي بنعرف نعالجها بسرعة بفضل الـ distributed frameworks اللي متاحة حاليًا، والشركات بتقدر تطلع منها عائد مادي بشكل أسرع.&lt;div&gt;&lt;br&gt;عيوبها بقى بتكمن في إن عشان نعمل labeling للـ data دي الموضوع مكلف وبطيء جدًا؛ لأن العنصر البشري بيتدخل عشان تطلع data كويسة وما ينفعش معاها automation. وبعد حجم معين من الـ data، أي data جديدة بتقدم تحسينات طفيفة تكاد تكون لا تُذكر. ده غير بقى إن لو الـ labeling فيه noise أو مش حيادي مش هتطلع دقة عالية. ولو الـ data اللي هيتمرن عليها الـ model ضخمة، بيبقى في فرصة إن يحصل overfitting بمعنى إن الموديل بيحفظ الـ data مش بيفهمها، فعند التوقع مش هيطلع نتائج كويسة. فوق كل ده، بيحتاج resources قوية ومكلفة، ده غير إن الـ data مش بتبقى متحدثة ومواكبة للأحداث اللي بتحصل.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;برضو من الحاجات اللي لازم تبقى في الحسبان إن الـ data دي ممكن يكون فيها معلومات حساسة لأشخاص وده بيخترق قوانين الخصوصية. غير كده، ممكن تكون الـ data دي اأشخاص اللي عملوا لها labeling ليهم انحيازات أو توجهات معينة، عشان إحنا بطبيعتنا كبشر مش محايدين 100%. غير كده بيحصل إن الشركات بتستغل الناس اللي بتعمل labeling بمرتبات ضئيلة في الدول النامية.&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="800" x="19" y="1430" as="geometry" />
        </mxCell>
        <mxCell id="CG8b47xFTE-a7-1MDE-e-111" connectable="0" parent="CG8b47xFTE-a7-1MDE-e-1" style="group;fontFamily=thmanyah serif text;" value="" vertex="1">
          <mxGeometry height="55.5" width="790" x="20" y="1610" as="geometry" />
