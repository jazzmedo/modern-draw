        <mxCell id="NQuZShNWxpy8CxApDY1Y-282" connectable="0" parent="NQuZShNWxpy8CxApDY1Y-283" style="group" value="" vertex="1">
          <mxGeometry height="210" width="260" x="30" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-253" parent="NQuZShNWxpy8CxApDY1Y-282" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#F9EBFF;strokeColor=#9673a6;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="&lt;div&gt;This replaces transformed features with a simple kernel evaluation in the original space.&lt;/div&gt;" vertex="1">
          <mxGeometry height="40" width="259.76464277332616" x="0.23535722667380318" y="170" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-250" parent="NQuZShNWxpy8CxApDY1Y-282" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#F9EBFF;strokeColor=#9673a6;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=8;spacingTop=10;" value="&lt;div&gt;The dual SVM algorithm only needs to compute inner products of the form:&lt;/div&gt;&lt;div&gt;&lt;div class=&quot;math-block&quot; data-math=&quot;\langle\phi(\mathbf{x}_i), \phi(\mathbf{x}_j)\rangle&quot; style=&quot;font-family: Google Sans Text, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;$$\langle\phi(\mathbf{x}_i), \phi(\mathbf{x}_j)\rangle$$&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="259.76464277332616" y="30" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-251" parent="NQuZShNWxpy8CxApDY1Y-282" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="The Kernel Trick – The Smart Shortcut" vertex="1">
          <mxGeometry height="30" width="259.76464277332616" x="0.23535722667380318" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-252" parent="NQuZShNWxpy8CxApDY1Y-282" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#F9EBFF;strokeColor=#9673a6;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=8;spacingTop=10;" value="&lt;div&gt;A kernel function directly evaluates this inner product without calculating `\phi(\mathbf{x})`:$$K(\mathbf{x}_i, \mathbf{x}_j) = \langle\phi(\mathbf{x}_i), \phi(\mathbf{x}_j)\rangle$$&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="259.76464277332616" y="100" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-285" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="130" width="240" x="570" y="5030" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-276" parent="NQuZShNWxpy8CxApDY1Y-285" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#F9EBFF;strokeColor=#9673a6;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="&lt;div&gt;Training becomes slow on large datasets.&lt;/div&gt;" vertex="1">
          <mxGeometry height="50" width="210" x="30" y="80" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-273" parent="NQuZShNWxpy8CxApDY1Y-285" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="5" vertex="1">
          <mxGeometry height="30" width="30" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-274" parent="NQuZShNWxpy8CxApDY1Y-285" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#F9EBFF;strokeColor=#9673a6;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="&lt;div&gt;Kernel and parameter selection require tuning.&lt;/div&gt;" vertex="1">
          <mxGeometry height="50" width="210" x="30" y="30" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-275" parent="NQuZShNWxpy8CxApDY1Y-285" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;arcSize=11;" value="Limitations" vertex="1">
          <mxGeometry height="30" width="210" x="30" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-286" parent="1" style="text;whiteSpace=wrap;html=1;fontFamily=Fustat;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;textDirection=rtl;align=right;fontStyle=0" value="&lt;p data-path-to-node=&quot;0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;الـ SVM في أصله هو موديل تصنيف خطي ذكي، فكرته إنه بيدور على أفضل خط أو مستوى يفصل بين مجموعتين من البيانات، وبيحاول يخلي الخط ده في النص بالظبط عشان يسيب أكبر مسافة أمان ممكنة بينه وبين أقرب نقط من الطرفين واللي بنسميها الجيران المؤثرة.&lt;/p&gt;&lt;p data-path-to-node=&quot;0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;الـ Kernel Trick بقى هي صياعة الرياضة في الـ SVM؛ بدل ما تكون البيانات متلغبطة ومعقدة في البعد الحالي ونروح نرفعها فعلياً لأبعاد أعلى بحسابات مكلفة ومعقدة عشان نعرف نفصلها بخط، الـ Kernel بيختصر اللفة دي كلها ويحسب الضرب القياسي المستهدف للبيانات في البعد العالي وهي واقفة في مكانها الأصلي باستخدام دالة ذكية؛ وده بيخلي الموديل يتعلم حدود فصل معقدة وغير خطية بسرعة وكفاءة عالية جداً وبأقل مجهود حسابي، بس عيبه الأساسي إنه بيحتاج تظبيط بارامترات كتير وبيهنج لو حجم البيانات ضخم جداً.&lt;/p&gt;" vertex="1">
          <mxGeometry height="110" width="780" x="30" y="5190" as="geometry" />
        </mxCell>
        <mxCell id="dKmXIdXv7CYBuSGMr946-1" parent="1" style="triangle;whiteSpace=wrap;html=1;dashed=0;direction=south;fillColor=#e51400;fontColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontFamily=Kufam;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DKufam;verticalAlign=top;spacingTop=5;fontStyle=1;fontSize=16;rounded=1;arcSize=6;" value="" vertex="1">
          <mxGeometry height="44.64" width="57" x="750" y="12.14" as="geometry" />
        </mxCell>
