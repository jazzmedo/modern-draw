        <mxCell id="5cy4-kSeaGVhRb9U9V7c-31" parent="5cy4-kSeaGVhRb9U9V7c-35" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;arcSize=5;hachureGap=4;align=left;spacingRight=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=3;fontFamily=Mali;fontSize=15;fontStyle=2;spacingTop=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Explain the process of building a decision tree, including metrics like Gini impurity and entropy, and how pruning prevents overfitting." vertex="1">
