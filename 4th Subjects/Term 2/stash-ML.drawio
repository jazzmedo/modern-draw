        <mxCell id="NQuZShNWxpy8CxApDY1Y-32" parent="NQuZShNWxpy8CxApDY1Y-44" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Handlee;strokeWidth=1;fillColor=#E5F1FF;strokeColor=#000000;fontSize=12;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DHandlee;spacingTop=1;" value="Entropy measures uncertainty or disorder:" vertex="1">
          <mxGeometry height="20" width="218" x="7" y="40" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-34" parent="NQuZShNWxpy8CxApDY1Y-44" style="text;whiteSpace=wrap;html=1;fontStyle=0;verticalAlign=middle;fontSize=12;" value="`\text{Entropy}(S) = - \sum_{k=1}^{K} p_k \log_2(p_k)`" vertex="1">
          <mxGeometry height="48" width="200" x="260" y="46" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-36" parent="NQuZShNWxpy8CxApDY1Y-44" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontFamily=Handlee;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DHandlee;fontStyle=1;fontSize=12;" value="&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Entropy = 0 → Pure node&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Higher entropy → More mixed classes&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="37" width="229.5" x="0.5" y="70" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-43" parent="NQuZShNWxpy8CxApDY1Y-44" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;rounded=0;fontFamily=Fustat;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DFustat;fontStyle=0;fontSize=11;textDirection=rtl;" value="الـ Entropy بيقيس درجة العشوائية وعدم اليقين جوه البيانات، وكل ما كانت النود صافية وكلاس واحد بيقل الـ Entropy لـ 0. الشجرة هنا بتدور على التقسيم اللي بيحقق أعلى Information Gain، وده معناه إنه بيعمل أكبر خفض ممكن في اللغبطة دي بعد التقسيم." vertex="1">
          <mxGeometry height="50.5" width="487" x="6.5" y="189.5" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-37" parent="NQuZShNWxpy8CxApDY1Y-44" style="text;whiteSpace=wrap;html=1;fontStyle=0;verticalAlign=middle;fontSize=12;align=center;" value="`\text{IG} = \text{Entropy}(\text{parent}) - \left[ \frac{N_L}{N} \cdot \text{Entropy}(\text{left}) + \frac{N_R}{N} \cdot \text{Entropy}(\text{right}) \right]`" vertex="1">
          <mxGeometry height="42" width="446.98" x="13.02" y="111" as="geometry" />
        </mxCell>
        <mxCell id="NQuZShNWxpy8CxApDY1Y-61" parent="NQuZShNWxpy8CxApDY1Y-44" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Handlee;strokeWidth=1;fillColor=#E5F1FF;strokeColor=#000000;fontSize=12;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DHandlee;spacingTop=1;" value="The best split is the one with the highest Information Gain." vertex="1">
          <mxGeometry height="20" width="295" x="89" y="160" as="geometry" />
        </mxCell>
