        <mxCell id="KX4MmI35KY4r6R5Pd4ZA-18" parent="KX4MmI35KY4r6R5Pd4ZA-32" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=1;fillColor=#d5e8d4;strokeColor=#666666;fontSize=11;fontStyle=0;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="Then the model tries to extract hidden structures and patterns from a large amount of unlabeled data" vertex="1">
