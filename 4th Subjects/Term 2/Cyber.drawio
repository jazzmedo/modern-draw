        <mxCell id="Zi2mB3NcdUUyQ67w9mh3-5" value="Availability" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#FFCACA;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=90;fillStyle=solid;" parent="Zi2mB3NcdUUyQ67w9mh3-4" vertex="1">
          <mxGeometry x="12.75" y="20" width="91" height="40" as="geometry" />
        </mxCell>
        <mxCell id="Zi2mB3NcdUUyQ67w9mh3-6" value="&lt;div&gt;&amp;nbsp;is making sure that authorized parties are able to access the information when&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;needed. &lt;/span&gt;&lt;font style=&quot;color: rgb(186, 5, 23);&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Standard Measures&amp;nbsp;&lt;/span&gt;&lt;font style=&quot;background-color: transparent; color: rgb(186, 5, 23);&quot;&gt;include:&lt;/font&gt;&lt;/font&gt;&lt;font style=&quot;background-color: transparent; color: rgb(186, 5, 23);&quot;&gt; &lt;/font&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;background-color: transparent;&quot;&gt;Backup to external devices,&amp;nbsp;&lt;/font&gt;&lt;font style=&quot;background-color: transparent;&quot;&gt;firewalls&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#F4E5E5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=100;fillStyle=solid;" parent="Zi2mB3NcdUUyQ67w9mh3-4" vertex="1">
          <mxGeometry y="60" width="620" height="50" as="geometry" />
        </mxCell>
        <mxCell id="Zi2mB3NcdUUyQ67w9mh3-7" value="" style="group;" parent="Zi2mB3NcdUUyQ67w9mh3-1" vertex="1" connectable="0">
          <mxGeometry x="21.5" y="171" width="620" height="95" as="geometry" />
        </mxCell>
        <mxCell id="Zi2mB3NcdUUyQ67w9mh3-8" value="Integrity" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#CCCCEA;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=70;fillStyle=solid;" parent="Zi2mB3NcdUUyQ67w9mh3-7" vertex="1">
          <mxGeometry x="13.75" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="Zi2mB3NcdUUyQ67w9mh3-9" value="Protection of information from modification by unauthorized users that provided by network security.&amp;nbsp;&lt;font style=&quot;color: rgb(186, 5, 23);&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Standard Measures&amp;nbsp;&lt;/span&gt;&lt;font style=&quot;background-color: transparent; color: rgb(186, 5, 23);&quot;&gt;include:&lt;/font&gt;&amp;nbsp;&lt;/font&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;Checksums, File Permissions.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#E5E5F4;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=100;fillStyle=solid;" parent="Zi2mB3NcdUUyQ67w9mh3-7" vertex="1">
          <mxGeometry y="40" width="620" height="55" as="geometry" />
        </mxCell>
        <mxCell id="Zi2mB3NcdUUyQ67w9mh3-10" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#336600&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;نمنع تسريب أو كشف البيانات لأي شخص مش مسموح له يشوفها،&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;b style=&quot;text-wrap-mode: nowrap; color: rgb(51, 102, 0); font-family: Beiruti; font-size: x-small; background-color: transparent;&quot;&gt;&amp;nbsp;كمان بتخلي هوية الأشخاص المصرح لهم بالتعامل مع البيانات مجهولة&lt;br&gt;عشان نقلل الخطر عليهم.&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;rounded=1;fillColor=none;" parent="Zi2mB3NcdUUyQ67w9mh3-1" vertex="1">
          <mxGeometry x="199.14000000000033" y="40" width="440" height="50" as="geometry" />
        </mxCell>
        <mxCell id="Zi2mB3NcdUUyQ67w9mh3-11" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#000099&quot;&gt;إننا نمنع تعديل البيانات بأي شكل من أشخاص مش مصرح لهم&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;rounded=1;fillColor=none;" parent="Zi2mB3NcdUUyQ67w9mh3-1" vertex="1">
          <mxGeometry x="442.4200000000001" y="180" width="196.72" height="30" as="geometry" />
        </mxCell>
        <mxCell id="Zi2mB3NcdUUyQ67w9mh3-12" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;color: rgb(153, 0, 0); font-family: Beiruti; font-size: x-small; background-color: transparent;&quot;&gt;إتاحة أن الناس المصرح لهم يقدروا يوصلوا للبيانات وقت ما يحتاجوها&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;rounded=1;fillColor=none;" parent="Zi2mB3NcdUUyQ67w9mh3-1" vertex="1">
          <mxGeometry x="420.5" y="297" width="217" height="16" as="geometry" />
        </mxCell>
        <mxCell id="Zi2mB3NcdUUyQ67w9mh3-13" value="Confidentiality" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#C1D1B2;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=80;fillStyle=solid;" parent="Zi2mB3NcdUUyQ67w9mh3-1" vertex="1">
          <mxGeometry x="35" y="50" width="121" height="39.63636363636364" as="geometry" />
        </mxCell>
        <mxCell id="Zi2mB3NcdUUyQ67w9mh3-14" value="&lt;div style=&quot;line-height: 124%;&quot;&gt;&amp;nbsp;is about preventing the disclosure of data to unauthorized parties, also&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;trying to keep the identity of authorized parties in sharing and holding&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;data private and anonymous.&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;color: rgb(186, 5, 23); background-color: transparent;&quot;&gt;Standard Measures&amp;nbsp;&lt;/span&gt;&lt;font style=&quot;color: rgb(186, 5, 23); background-color: transparent;&quot;&gt;include:&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: rgb(186, 5, 23);&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;Data &lt;/font&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font&gt;Encryption&lt;/font&gt;&lt;font&gt;, 2FA.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#EAEFE5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=60;fillStyle=solid;" parent="Zi2mB3NcdUUyQ67w9mh3-1" vertex="1">
          <mxGeometry x="21.25" y="89.6400000000001" width="620" height="72.36" as="geometry" />
        </mxCell>
      </root>
