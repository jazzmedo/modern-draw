        <mxCell id="416QoxgmyYfooZZkW0Gl-57" parent="hOXUQQMBu0Lae1k2kh_e-68" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(130, 81, 1);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b style=&quot;color: rgb(130, 81, 1); text-wrap-mode: nowrap;&quot;&gt;&amp;nbsp;نوع من البرامج ب&lt;/b&gt;&lt;font color=&quot;#825101&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;تنسخ نفسها بنفسها... وده من غير ما تهاجم أي برنامج تاني بشكل مباشر&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;b style=&quot;color: rgb(130, 81, 1); text-wrap-mode: nowrap;&quot;&gt;، لكنها بتستهلك موارد الجهاز لدرجة إنها ممكن تعطل النظام&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="475" x="187" y="118" as="geometry" />
        </mxCell>
        <mxCell id="416QoxgmyYfooZZkW0Gl-58" parent="hOXUQQMBu0Lae1k2kh_e-68" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(64, 16, 117);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b style=&quot;text-wrap-mode: nowrap;&quot;&gt;برنامج خبيث مستقل&amp;nbsp; يعني يقدر&amp;nbsp; يشتغل لوحده، من غير ما يحتاج يركب نفسه جوه برنامج تاني زي الـ virus. بينسخ نفسه ينتشر من جهاز لجهاز عن طريق الشبكة&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;غالبًا مش بيهاجم برامج تانية، بس وجوده مش بريء… لأنه بيستهلك موارد الشبكة&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="37" width="495" x="169" y="217" as="geometry" />
        </mxCell>
        <mxCell id="416QoxgmyYfooZZkW0Gl-59" parent="hOXUQQMBu0Lae1k2kh_e-68" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(28, 51, 38);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;هو باب سري جوا برنامج بيسمح للي عمله إنه يعدي كل الحماية ويدخل للبرنامج أو النظام من غير ما يمر على الإجراءات الطبيعية (زي الباسورد) &lt;br&gt;عشان&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#1c3326&quot;&gt;&lt;b&gt;يختبر البرنامج لكن ممكن ينسي يشيلة&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="435.11" x="220.44000000000005" y="326" as="geometry" />
        </mxCell>
