        <mxCell id="h6eXFfXM4W7l3cRYEoy7-79" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Fustat&quot; face=&quot;Fustat&quot; style=&quot;color: rgb(204, 0, 0);&quot;&gt;ا&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Kufam&quot;&gt;لتوضيح للفهم:&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;color: rgb(153, 0, 0);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b style=&quot;&quot;&gt;Private Key 🔑: سري، ومحدش يعرفه غيرك.&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#336600&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;Public Key 🔓: متاح لأي حد، ممكن تنشره عادي.&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
