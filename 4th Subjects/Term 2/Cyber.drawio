        <mxCell id="uCDAZHJack0i0X8iw5U3-88" parent="uCDAZHJack0i0X8iw5U3-1" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Fustat&quot; face=&quot;Fustat&quot; style=&quot;color: rgb(204, 0, 0);&quot;&gt;ا&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Kufam&quot;&gt;لتوضيح للفهم:&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font style=&quot;color: rgb(0, 102, 204);&quot;&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b style=&quot;&quot;&gt;الهاكرز لما بيحاولوا يخمنوا الباسورد، مش بيشتغلوا عشوائي،&lt;br&gt;&amp;nbsp;بيشتغلوا بخطة&amp;nbsp; فيها خطوات وطرق متكررة.&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;font style=&quot;background-color: transparent;&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font&gt;&lt;b&gt;&amp;nbsp;&amp;lt;/&amp;gt;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: rgb(110, 131, 123);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;يستخدموا معلومات شخصية&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;b style=&quot;text-wrap-mode: nowrap;&quot;&gt;ده ممكن يدي معلومة للهاكر عن نوع السيستم،&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot