        <mxCell id="zaUk_k8dVsGs0_1cOOlX-56" parent="zaUk_k8dVsGs0_1cOOlX-54" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#E5E5F4;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=100;fillStyle=solid;" value="&lt;div&gt;&amp;nbsp;Many systems restrict multiple&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;unsuccessful attempts to log on; Set a limit the when limit reached, system lock out user ID&lt;/span&gt;&lt;/div&gt;" vertex="1">
