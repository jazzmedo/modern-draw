          <mxGeometry x="26" y="63" width="620" height="110" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-3" value="System Messages" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=2;fillColor=#C1D1B2;strokeColor=#000000;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=7;verticalAlign=middle;fillOpacity=80;fillStyle=solid;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="zaUk_k8dVsGs0_1cOOlX-2" vertex="1">
          <mxGeometry x="9" width="191" height="40" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-4" value="Systems often show greeting messages before and after login, Admins should suppress these messages, also passwords should be not displayed when entering to prevent shoulder surfing." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#EAEFE5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=60;fillStyle=solid;" parent="zaUk_k8dVsGs0_1cOOlX-2" vertex="1">
          <mxGeometry x="-4.75" y="40" width="620" height="70" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-44" value="Password Controls" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=2;fillColor=#f5f5f5;strokeColor=#666666;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=solid;strokeOpacity=100;fillOpacity=100;fontColor=#333333;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="DJcv6TiS2SLJbePKLPNc-16" vertex="1">
          <mxGeometry x="10" y="1" width="215" height="40" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-45" value="" style="group" parent="DJcv6TiS2SLJbePKLPNc-16" connectable="0" vertex="1">
          <mxGeometry x="24" y="516" width="622" height="110" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-46" value="User Lockouts" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=2;fillColor=#B4DFDF;strokeColor=#000000;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=7;verticalAlign=middle;fillOpacity=100;fillStyle=solid;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="zaUk_k8dVsGs0_1cOOlX-45" vertex="1">
          <mxGeometry x="11" width="159" height="40" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-47" value="&lt;div&gt;allows the system administrator to&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;lock out an ID that has not been used for a long time or&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;unchanged passwords. To unlocked should user contact with Admin to re-authenticate by other methods.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#D2EBEB;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=60;fillStyle=solid;" parent="zaUk_k8dVsGs0_1cOOlX-45" vertex="1">
          <mxGeometry x="-2.75" y="40" width="620" height="70" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-48" value="" style="group" parent="DJcv6TiS2SLJbePKLPNc-16" connectable="0" vertex="1">
          <mxGeometry x="25" y="404" width="621" height="95" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-49" value="Minimum Length" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=2;fillColor=#EACCEA;strokeColor=#000000;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=7;verticalAlign=middle;fillOpacity=100;fillStyle=solid;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="zaUk_k8dVsGs0_1cOOlX-48" vertex="1">
          <mxGeometry x="10" width="170" height="40" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-50" value="&lt;div&gt;Short passwords are easier to guess than&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;long passwords, so&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;many systems require &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;minimum length of passwords.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#F4E5F4;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=100;fillStyle=solid;" parent="zaUk_k8dVsGs0_1cOOlX-48" vertex="1">
          <mxGeometry x="-3.75" y="40" width="620" height="55" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-51" value="" style="group" parent="DJcv6TiS2SLJbePKLPNc-16" connectable="0" vertex="1">
          <mxGeometry x="25" y="306" width="621" height="80" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-52" value="Password Aging" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=2;fillColor=#FFCACA;strokeColor=#000000;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=7;verticalAlign=middle;fillOpacity=90;fillStyle=solid;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="zaUk_k8dVsGs0_1cOOlX-51" vertex="1">
          <mxGeometry x="9" y="-4" width="171" height="40" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-53" value="&lt;div&gt;each password&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;has a fixed lifetime, after which the password&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;must be changed.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#F4E5E5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=100;fillStyle=solid;" parent="zaUk_k8dVsGs0_1cOOlX-51" vertex="1">
          <mxGeometry x="-3.75" y="36" width="620" height="40" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-54" value="" style="group;" parent="DJcv6TiS2SLJbePKLPNc-16" connectable="0" vertex="1">
          <mxGeometry x="25" y="189" width="629.5" height="95" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-55" value="Limited Attempts" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=2;fillColor=#CCCCEA;strokeColor=#000000;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=7;verticalAlign=middle;fillOpacity=70;fillStyle=solid;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="zaUk_k8dVsGs0_1cOOlX-54" vertex="1">
          <mxGeometry x="10" width="190" height="40" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-56" value="&lt;div&gt;&amp;nbsp;Many systems restrict multiple&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;unsuccessful attempts to log on; Set a limit the when limit reached, system lock out user ID&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#E5E5F4;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=100;fillStyle=solid;" parent="zaUk_k8dVsGs0_1cOOlX-54" vertex="1">
          <mxGeometry x="-3.75" y="40" width="620" height="55" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-79" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Fustat&quot; face=&quot;Fustat&quot; style=&quot;color: rgb(204, 0, 0);&quot;&gt;ا&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Kufam&quot;&gt;لتوضيح للفهم:&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font color=&quot;#990000&quot;&gt;&lt;b&gt;عشان نحمي السيستم من تخمين الباسورد، فيه شوية قوانين وإجراءات أمان لازم تتطبق &amp;lt;/&amp;gt;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;" parent="DJcv6TiS2SLJbePKLPNc-16" vertex="1">
          <mxGeometry x="361.27999999999975" width="277.86" height="37" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-80" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;color: rgb(51, 102, 0);&quot;&gt;&lt;font style=&quot;background-color: transparent; font-weight: normal; text-wrap-mode: wrap;&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;font&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;رسائل النظام:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; font-weight: normal;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b&gt;أوقات السيستم بيعرض رسالة ترحيب فيها اسم النظام قبل أو بعد الـ Login،&amp;nbsp;&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-weight: normal;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b&gt;ده ممكن يدي معلومة للهاكر عن&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;color: rgb(51, 102, 0);&quot;&gt;&lt;span style=&quot;background-color: transparent; font-weight: normal;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b&gt;&amp;nbsp;نوع السيستم اللي بيهجم عليه،&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-weight: normal;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b&gt;المفروض نمنع الرسائل&amp;nbsp;&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;b style=&quot;font-family: Beiruti; font-size: x-small; background-color: transparent; color: rgb(51, 102, 0);&quot;&gt;دي، وكمان لما اليوزر&amp;nbsp; يكتب الباسورد، ما يتعرضش قدام الناس، عشان&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;color: rgb(51, 102, 0);&quot;&gt;&lt;b style=&quot;font-family: Beiruti; font-size: x-small; background-color: transparent; color: rgb(51, 102, 0);&quot;&gt;&amp;nbsp;محدش يقراها من وراه&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;rounded=1;" parent="DJcv6TiS2SLJbePKLPNc-16" vertex="1">
