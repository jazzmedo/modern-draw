        <mxCell id="CnHWDV-yZXEh6JPSVFbq-2" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Fustat&quot; face=&quot;Fustat&quot; style=&quot;color: rgb(204, 0, 0);&quot;&gt;ا&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Kufam&quot;&gt;لتوضيح للفهم:&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font style=&quot;color: rgb(3, 45, 96);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;دي Function بتاخد بيانات وتعمل لها&amp;nbsp;(زي بصمة)&amp;nbsp;بتعبر عنها&amp;nbsp;بحجم ثابت اسمها message digest&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;font-weight: bold; text-wrap-mode: nowrap; background-color: transparent;&quot;&gt;و من المستحيل ترجع البيانات الأصلية منها.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
