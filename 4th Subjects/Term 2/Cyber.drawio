        <mxCell id="ypaqH-uUHXjcv0g4RAur-3" value="&lt;div&gt;Cyber security is the &lt;font style=&quot;color: rgb(0, 102, 204);&quot;&gt;body of&lt;/font&gt; technologies, processes, and practices &lt;font style=&quot;color: rgb(0, 102, 204);&quot;&gt;designed to&lt;/font&gt; protect networks, computers, programs and data from attack.&lt;/div&gt;&lt;div&gt;&amp;nbsp; - &lt;font style=&quot;color: rgb(0, 102, 204);&quot;&gt;Cyber Security&lt;/font&gt; refers to techniques and practices designed to protect digital data.&lt;/div&gt;&lt;div&gt;&amp;nbsp; - &lt;font style=&quot;color: rgb(0, 102, 204);&quot;&gt;Data &lt;/font&gt;that is stored, transmitted or used on an information system.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#FDDDE3;strokeColor=#61022A;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=2;verticalAlign=middle;fillStyle=solid;spacingLeft=2;spacingRight=2;spacingTop=0;spacingBottom=0;" parent="ypaqH-uUHXjcv0g4RAur-2" vertex="1">
          <mxGeometry y="30" width="729" height="100" as="geometry" />
        </mxCell>
