        <mxCell id="uCDAZHJack0i0X8iw5U3-63" parent="uCDAZHJack0i0X8iw5U3-61" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;" value="&lt;font face=&quot;Mina&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;generating passwords that can be used only once. After use, the onetime password becomes invalid.&lt;/span&gt;&lt;/font&gt;" vertex="1">
