          <mxGeometry x="100" y="242" width="320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="viWILsfknehf8Vpiy5tB-26" value="the subject is a user, the object is the name of a file, and the action is read, write, create." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#90D2D8;strokeColor=#281202;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;sketch=1;curveFitting=1;jiggle=2;fillOpacity=40;container=0;" parent="viWILsfknehf8Vpiy5tB-20" vertex="1">
