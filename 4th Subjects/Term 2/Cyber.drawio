        <mxCell id="h6eXFfXM4W7l3cRYEoy7-5" value="Systems often show greeting messages before and after login, Admins should suppress these messages, also passwords should be not displayed when entering to prevent shoulder surfing." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#EAEFE5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillOpacity=60;fillStyle=cross-hatch;" parent="h6eXFfXM4W7l3cRYEoy7-3" vertex="1">
          <mxGeometry x="-4.75" y="40" width="620" height="70" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-6" value="" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;arcSize=7;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;sketch=1;curveFitting=1;jiggle=2;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="10" y="114" width="749" height="270" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-7" value="&lt;span style=&quot;font-size: 20px;&quot;&gt;&amp;nbsp;Logon Process&lt;/span&gt;" style="rounded=1;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#E6E6E6;strokeColor=default;fontSize=23;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;arcSize=33;fillStyle=cross-hatch;fontColor=#000000;whiteSpace=wrap;align=center;spacingRight=8;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="25" y="74" width="170" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-8" value="&lt;div&gt;First, the user &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;select &lt;/font&gt;the application to log on.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#B9E0A5;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="19" y="124" width="400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-9" value="&lt;div&gt;When receiving the ID, the application asked user to enter the &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;password&lt;/font&gt;; The user enter the &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;password&lt;/font&gt;.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#B9E0A5;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;fillOpacity=60;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="99" y="207" width="602" height="57" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-10" value="&lt;div&gt;The application asked the user to enter an &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;ID&lt;/font&gt;; the user enters the &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;ID&lt;/font&gt;.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#B9E0A5;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;fillOpacity=80;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="99" y="165.25" width="576" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-11" value="&lt;div&gt;The application uses the ID to &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;search&lt;/font&gt; in application&amp;nbsp;&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;database &lt;/font&gt;for &lt;u&gt;IDs &lt;/u&gt;and &lt;u&gt;passwords&lt;/u&gt;.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#B9E0A5;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;fillOpacity=40;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="19" y="264" width="695" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-12" value="Now the application &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;compares&lt;/font&gt; the password that entered with that retrieved from database. If the two matches, the user is logged on; otherwise the application reject user logon." style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#B9E0A5;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;fillOpacity=20;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="19" y="304" width="695" height="70" as="geometry" />
        </mxCell>
