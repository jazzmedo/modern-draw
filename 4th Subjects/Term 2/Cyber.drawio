        <mxCell id="3EmIRpmpSdk3kt2dipBs-132" value="&lt;div&gt;is a fragment of&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;software that is set to inflict damage when a certain set&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;of conditions exist and cause delete some data or files.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#D8E6FE;strokeColor=#032D60;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="-753.1100000000001" y="1737" width="630" height="50" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-133" value="Trojan Horses" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#FFECB8;strokeColor=#000000;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="-735" y="1801" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-134" value="&amp;nbsp;is a piece of code that hides inside a program and performs a disguised function, does not exist independently." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#FFECB8;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="-753" y="1841" width="630" height="50" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-135" value="Worms" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#F2DEFE;strokeColor=#481A54;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="-735" y="1489" width="90" height="40" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-136" value="is an independent program that can replicate itself and often spreads to different sites over a network, doesn&#39;t attack programs but it consumes network resources." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#F2DEFE;strokeColor=#481A54;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="-753.1100000000001" y="1529" width="630" height="50" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-137" value="Bacteria" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#FEDFD0;strokeColor=#3E2B02;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=3;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="-735" y="1385" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-138" value="&lt;div&gt;programs that duplicate themselves.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;While these programs do not directly attack any&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;software, they consume resources simply by&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;replicating themselves.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#FEDFD0;strokeColor=#3E2B02;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="-753.1100000000001" y="1425" width="630" height="50" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-139" value="virus is not an independent program and executes when its home program executes." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;fillOpacity=60;fontColor=#333333;" parent="1" vertex="1">
          <mxGeometry x="-769" y="1341" width="638" height="40" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-140" value="" style="group" parent="1" vertex="1" connectable="0">
          <mxGeometry x="-772" y="110" width="700" height="60" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-141" value="consists of tracking and investigating the history of suspicious activity we divide it into two parts audit trail, intrusion analysis" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#F9E3B6;strokeColor=#4F2100;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=4;verticalAlign=middle;fillStyle=solid;" parent="3EmIRpmpSdk3kt2dipBs-140" vertex="1">
          <mxGeometry width="699.9999999999999" height="60" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-142" value="" style="group" parent="1" vertex="1" connectable="0">
          <mxGeometry x="-771" y="1182" width="690" height="97" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-143" value="is created when the audit record shows some abnormal behavior and it consists of 3 fields event time profile" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#CDEFC4;strokeColor=#1C3326;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=4;verticalAlign=middle;fillStyle=solid;container=0;" parent="3EmIRpmpSdk3kt2dipBs-142" vertex="1">
          <mxGeometry x="-1" y="40" width="700" height="57" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-144" value="Anomaly record" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#CDEFC4;strokeColor=#1C3326;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=solid;" parent="3EmIRpmpSdk3kt2dipBs-142" vertex="1">
          <mxGeometry x="18" width="190" height="42" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-145" value="Audit Trail" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#FFDED5;strokeColor=#4A2413;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="-753" y="184" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-146" value="Workstation monitoring" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#F9E3B6;strokeColor=#4F2100;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="-753" y="70" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-147" value="There are important events that should be recorded ex: system being hacked with intruder who tries passwords periodically to bypass system checks audit help detecting these threats&amp;nbsp;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#FFDED5;strokeColor=#4A2413;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="-772" y="224" width="700" height="60" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-148" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" parent="1" source="3EmIRpmpSdk3kt2dipBs-149" target="3EmIRpmpSdk3kt2dipBs-156" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="-731" y="846" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-149" value="characterize the behavior of a subject on an object. Profiles include the description of normal behavior of subjects with respect to the objects. So, profiles can be detect and report any abnormal activity" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#e1d5e7;strokeColor=#281202;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=4;verticalAlign=middle;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="-772" y="732" width="700" height="82" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-150" value="Profiles" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#e1d5e7;strokeColor=#281202;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="-753" y="692" width="110" height="42" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-151" value="the subject as a user, the object as the name of the program, and the action is execute. Measures for these profiles include execution frequency, resource usage, and execution denied." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#dae8fc;strokeColor=#281202;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;fillOpacity=60;" parent="1" vertex="1">
          <mxGeometry x="-691" y="969" width="570" height="72" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-152" value="Command/Program Execution" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#dae8fc;strokeColor=#281202;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=solid;fillOpacity=60;" parent="1" vertex="1">
          <mxGeometry x="-671" y="929" width="320" height="42" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-153" value="the subject is a user, the object is the name of a file, and the action is read, write, create." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#90D2D8;strokeColor=#281202;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;fillOpacity=40;container=0;" parent="1" vertex="1">
          <mxGeometry x="-692" y="1093" width="570" height="60" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-154" value="File Access Activity" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#90D2D8;strokeColor=#281202;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=solid;fillOpacity=40;" parent="1" vertex="1">
          <mxGeometry x="-672" y="1053" width="220" height="42" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-155" value="The subject is the user, the object is the user&#39;s logon location, and action is log on or log off" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#d5e8d4;strokeColor=#281202;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;fillOpacity=80;" parent="1" vertex="1">
          <mxGeometry x="-693" y="866" width="570" height="52" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-156" value="Logon and Session Activity" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#d5e8d4;strokeColor=#281202;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=solid;fillOpacity=80;" parent="1" vertex="1">
          <mxGeometry x="-673" y="826" width="300" height="42" as="geometry" />
        </mxCell>
