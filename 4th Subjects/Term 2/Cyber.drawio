        <mxCell id="416QoxgmyYfooZZkW0Gl-15" value="a virus is self-reproducing automation. It is not an independent program — it executes when its host program executes; makes one or more copies of itself." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#f5f5f5;strokeColor=default;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;fillOpacity=60;fontColor=#000000;" parent="SBeR2EUBm2XXKJ5nG4GS-1" vertex="1">
