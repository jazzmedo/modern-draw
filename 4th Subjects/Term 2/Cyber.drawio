        </mxCell>
        <mxCell id="ZheG6RXCc56P20cuBf9t-21" value="Someone can steal or destroy the information that is stored on the private network." style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;" parent="ZheG6RXCc56P20cuBf9t-19" vertex="1">
