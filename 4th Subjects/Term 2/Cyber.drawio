        <mxCell id="zaUk_k8dVsGs0_1cOOlX-25" value="&lt;div&gt;&amp;nbsp;Users given a something secret to memorize only users and system known it,&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;such as a password.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#99CCFF;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=20;fillStyle=solid;" parent="zaUk_k8dVsGs0_1cOOlX-18" vertex="1">
