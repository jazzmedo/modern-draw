        <mxCell id="h6eXFfXM4W7l3cRYEoy7-55" value="Password Aging" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#FFCACA;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillOpacity=90;fillStyle=cross-hatch;" parent="h6eXFfXM4W7l3cRYEoy7-54" vertex="1">
          <mxGeometry x="9" y="-4" width="150" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-56" value="&lt;div&gt;each password&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;has a fixed lifetime, after which the password&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;must be changed.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#F4E5E5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillOpacity=100;fillStyle=cross-hatch;" parent="h6eXFfXM4W7l3cRYEoy7-54" vertex="1">
          <mxGeometry x="-3.75" y="36" width="620" height="40" as="geometry" />
        </mxCell>
