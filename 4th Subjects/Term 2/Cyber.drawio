        <mxCell id="ypaqH-uUHXjcv0g4RAur-22" value="&lt;div&gt;These are the attacks which are intended to compromise a computer.&lt;/div&gt;&lt;div&gt;Some of the important system-based attacks are as follows:&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#B7DED2;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=solid;align=left;spacingLeft=2;fillOpacity=80;spacingRight=2;spacing=2;spacingTop=0;container=0;" parent="ypaqH-uUHXjcv0g4RAur-6" vertex="1">
