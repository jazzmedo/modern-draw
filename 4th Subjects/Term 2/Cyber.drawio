            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="viWILsfknehf8Vpiy5tB-22" value="characterize the behavior of a subject on an object. Profiles include the description of normal behavior of subjects with respect to the objects. So, profiles can be detect and report any abnormal activity" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#e1d5e7;strokeColor=#281202;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;sketch=1;curveFitting=1;jiggle=2;" parent="viWILsfknehf8Vpiy5tB-20" vertex="1">
          <mxGeometry x="43" y="40" width="473" height="90" as="geometry" />
        </mxCell>
        <mxCell id="viWILsfknehf8Vpiy5tB-23" value="Profiles" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#e1d5e7;strokeColor=#281202;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=cross-hatch;sketch=1;curveFitting=1;jiggle=2;" parent="viWILsfknehf8Vpiy5tB-20" vertex="1">
          <mxGeometry x="70" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="viWILsfknehf8Vpiy5tB-24" value="the subject as a user, the object as the name of the program, and the action is execute. Measures for these profiles include execution frequency, resource usage, and execution denied." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#dae8fc;strokeColor=#281202;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;sketch=1;curveFitting=1;jiggle=2;fillOpacity=60;" parent="viWILsfknehf8Vpiy5tB-20" vertex="1">
