        <mxCell id="_G8JK7yloafIOdI4ARxt-2" value="Encryption&amp;nbsp;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#ECE1F9;strokeColor=#401075;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;fillStyle=cross-hatch;" parent="_G8JK7yloafIOdI4ARxt-1" vertex="1">
          <mxGeometry x="20" width="130" height="40" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-3" value="is the process of transforming data into an unintelligible from in such a way that the original data can be obtained only by using the decryption process and the encryption key." style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#ECE1F9;strokeColor=#401075;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;" parent="_G8JK7yloafIOdI4ARxt-1" vertex="1">
          <mxGeometry y="40" width="700" height="70" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-4" value="" style="group" parent="1" vertex="1" connectable="0">
          <mxGeometry x="854" y="-984" width="700" height="110" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-5" value="Data Integrity" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#ECE1F9;strokeColor=#401075;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;fillStyle=cross-hatch;" parent="_G8JK7yloafIOdI4ARxt-4" vertex="1">
          <mxGeometry x="16" width="170" height="40" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-6" value="&lt;div&gt;ensures information is protected from unauthorized modifications.&lt;br&gt;Security&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;measures must guard data both in storage and during transmission, as intruders may alter unprotected information.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#ECE1F9;strokeColor=#401075;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=4;verticalAlign=middle;fillStyle=cross-hatch;" parent="_G8JK7yloafIOdI4ARxt-4" vertex="1">
          <mxGeometry y="40" width="700" height="70" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-7" value="" style="group" parent="1" vertex="1" connectable="0">
          <mxGeometry x="854" y="-724" width="700" height="110" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-8" value="Digital Signature" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#ECE1F9;strokeColor=#401075;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;fillStyle=cross-hatch;" parent="_G8JK7yloafIOdI4ARxt-7" vertex="1">
          <mxGeometry x="30" width="190" height="40" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-9" value="&lt;div&gt;proves data authenticity and origin. Unlike encryption, which ensures&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;confidentiality, digital signatures focus on verification. They often use public key schemes&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;along with options like data integrity and one-way hash functions.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#ECE1F9;strokeColor=#401075;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=4;verticalAlign=middle;fillStyle=cross-hatch;" parent="_G8JK7yloafIOdI4ARxt-7" vertex="1">
          <mxGeometry y="40" width="700" height="70" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-10" value="" style="group" parent="1" vertex="1" connectable="0">
          <mxGeometry x="854" y="-864" width="700" height="110" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-11" value="&lt;div&gt;have long been used to detect message changes. In the 1970s,&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;analog links often caused transmission errors, so link layer protocols used checksums to&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;detect such changes.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#ECE1F9;strokeColor=#401075;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=4;verticalAlign=middle;fillStyle=cross-hatch;" parent="_G8JK7yloafIOdI4ARxt-10" vertex="1">
          <mxGeometry y="40" width="700" height="70" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-12" value="One-Way Hash Functions" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#ECE1F9;strokeColor=#401075;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;fillStyle=cross-hatch;" parent="_G8JK7yloafIOdI4ARxt-10" vertex="1">
          <mxGeometry x="26" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-13" value="&lt;div&gt;The one-way hash function H can be applied to a data block M of arbitrary size.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#F9E3B6;strokeColor=#4F2100;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillStyle=cross-hatch;" parent="1" vertex="1">
          <mxGeometry x="903.5" y="-544" width="610" height="40" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-14" value="&amp;nbsp;requirements to be satisfied by one-way hash functions" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#F9E3B6;strokeColor=#4F2100;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=2;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;sketch=1;curveFitting=1;jiggle=2;fillStyle=cross-hatch;" parent="1" vertex="1">
          <mxGeometry x="863.5" y="-584" width="600" height="40" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-15" value="&lt;div&gt;The result message digest, `d`, is of fixed size, the message digest size is usually `128`&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;or `160` bits&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#F9E3B6;strokeColor=#4F2100;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillStyle=cross-hatch;" parent="1" vertex="1">
          <mxGeometry x="903.5" y="-504" width="721" height="40" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-16" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;easy to implement in both hardware and software.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#F9E3B6;strokeColor=#4F2100;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillStyle=cross-hatch;" parent="1" vertex="1">
          <mxGeometry x="903.5" y="-464" width="400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-17" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Given the message digest `d`, it is very hard to find the original message `M`.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;when the one&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;way hash function is applied to the data -&amp;gt; only the message digest is sent.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#F9E3B6;strokeColor=#4F2100;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillStyle=cross-hatch;" parent="1" vertex="1">
          <mxGeometry x="903.5" y="-424" width="680" height="60" as="geometry" />
        </mxCell>
        <mxCell id="_G8JK7yloafIOdI4ARxt-18" value="Given the message `M`, it is very hard to find a data block N such that `H (N) = H (M)`" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#F9E3B6;strokeColor=#4F2100;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillStyle=cross-hatch;" parent="1" vertex="1">
