        <mxCell id="416QoxgmyYfooZZkW0Gl-19" value="is created when the &lt;i style=&quot;&quot;&gt;audit record&lt;/i&gt; shows &lt;font style=&quot;color: rgb(1, 118, 211);&quot;&gt;some abnormal behavior&lt;/font&gt; and it consists of 3 fields &lt;u&gt;event&lt;/u&gt; &lt;u&gt;time&lt;/u&gt; &lt;u&gt;profile&lt;/u&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#CDEFC4;strokeColor=#1C3326;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=4;verticalAlign=middle;fillStyle=solid;container=0;" parent="DJcv6TiS2SLJbePKLPNc-61" vertex="1">
