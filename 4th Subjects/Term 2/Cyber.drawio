        <mxCell id="KyuPeIGdNS5OEiElJCXm-35" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font color=&quot;#336600&quot; face=&quot;Beiruti&quot; size=&quot;1&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;الكارت ده والسيستم بينهم &quot;سر مشترك&quot; بيستخدموه عشان يطلعوا أرقام متغيرة كل شوية. الفكرة إن الساعة في الكارت والسيستم بيبقوا&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font color=&quot;#336600&quot; face=&quot;Beiruti&quot; size=&quot;1&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;&amp;nbsp;متظبطين مع بعض عشان الرقم اللي يظهرلك يكون هو نفس الرقم اللي السيستم مستنيه في اللحظة دي.&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;rounded=1;" parent="DJcv6TiS2SLJbePKLPNc-17" vertex="1">
          <mxGeometry x="282" y="580" width="435" height="40" as="geometry" />
        </mxCell>
        <mxCell id="KyuPeIGdNS5OEiElJCXm-37" value="Token Cards" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=2;fillColor=#C1D1B2;strokeColor=#000000;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=7;verticalAlign=middle;fillOpacity=80;fillStyle=solid;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="DJcv6TiS2SLJbePKLPNc-17" vertex="1">
          <mxGeometry x="80.75" y="460" width="139.25" height="41" as="geometry" />
        </mxCell>
        <mxCell id="KyuPeIGdNS5OEiElJCXm-38" value="The user is given a token card sharing a secret key with the system. The card displays a number that changes over time using the shared secret key. The system clock is approximately synchronized with the card&#39;s clock." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#EAEFE5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=60;fillStyle=solid;" parent="DJcv6TiS2SLJbePKLPNc-17" vertex="1">
          <mxGeometry x="20" y="501" width="720" height="79" as="geometry" />
        </mxCell>
