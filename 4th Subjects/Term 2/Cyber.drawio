        <mxCell id="1jSB9UTQtr0Iap5kisdN-21" value="&lt;div&gt;These are the &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;attacks &lt;/font&gt;which are intended to compromise a computer.&lt;/div&gt;&lt;div&gt;Some of the important system-based attacks are as follows:&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#B9E0A5;strokeColor=#000000;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;align=left;spacingLeft=2;fillOpacity=80;spacingRight=2;spacing=2;spacingTop=0;" parent="1jSB9UTQtr0Iap5kisdN-18" vertex="1">
          <mxGeometry x="24.5" y="40" width="720" height="60" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-22" value="Virus" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#E8F5E9;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;align=center;" parent="1jSB9UTQtr0Iap5kisdN-18" vertex="1">
          <mxGeometry x="88.5" y="107" width="70" height="34" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-23" value="&lt;div style=&quot;direction: ltr;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;A virus is a type of malicious software program, not independent program and&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;also execute&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;instructions that cause harm to system&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#E8F5E9;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;align=left;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;" parent="1jSB9UTQtr0Iap5kisdN-18" vertex="1">
          <mxGeometry x="73.5" y="141" width="687" height="61" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-24" value="Worm" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#CFF5D0;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;align=center;" parent="1jSB9UTQtr0Iap5kisdN-18" vertex="1">
