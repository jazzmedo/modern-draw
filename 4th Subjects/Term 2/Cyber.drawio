        <mxCell id="uCDAZHJack0i0X8iw5U3-66" parent="uCDAZHJack0i0X8iw5U3-1" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#eeeeee;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;container=0;" value="&lt;div&gt;User A encrypts a message using User B’s public key, and only User B can decrypt it using&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;their private key. No one else can decrypt the message since only User B knows the private&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;key.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;" vertex="1">
