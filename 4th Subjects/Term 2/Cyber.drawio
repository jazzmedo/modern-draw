        </mxCell>
        <mxCell id="viWILsfknehf8Vpiy5tB-15" value="virus is not an independent program and&amp;nbsp; executes when its home program executes." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;sketch=1;curveFitting=1;jiggle=2;fillOpacity=60;fontColor=#333333;" parent="1" vertex="1">
