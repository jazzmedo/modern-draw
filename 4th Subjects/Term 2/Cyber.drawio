        <mxCell id="zaUk_k8dVsGs0_1cOOlX-46" parent="zaUk_k8dVsGs0_1cOOlX-45" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=2;fillColor=#B4DFDF;strokeColor=#000000;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=7;verticalAlign=middle;fillOpacity=100;fillStyle=solid;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" value="User Lockouts" vertex="1">
