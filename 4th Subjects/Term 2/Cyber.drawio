        <mxCell id="8s1uBqA9vXEwEWGlCemx-8" value="" style="group;fillColor=none;fillStyle=solid;" parent="1" vertex="1" connectable="0">
          <mxGeometry x="43" y="89" width="740" height="100" as="geometry" />
        </mxCell>
        <mxCell id="8s1uBqA9vXEwEWGlCemx-4" value="Encryption" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#CDEFC4;strokeColor=#1C3326;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;fillStyle=solid;aspect=fixed;" parent="8s1uBqA9vXEwEWGlCemx-8" vertex="1">
          <mxGeometry x="16" width="131.25" height="42" as="geometry" />
        </mxCell>
        <mxCell id="8s1uBqA9vXEwEWGlCemx-3" value="is the process of transforming data into an unintelligible from in such a way that the original data can be obtained only by using the decryption process and the encryption key." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#CDEFC4;strokeColor=#1C3326;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=4;verticalAlign=middle;fillStyle=solid;" parent="8s1uBqA9vXEwEWGlCemx-8" vertex="1">
          <mxGeometry y="40" width="740" height="60" as="geometry" />
        </mxCell>
        <mxCell id="CnHWDV-yZXEh6JPSVFbq-4" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Fustat&quot; face=&quot;Fustat&quot; style=&quot;color: rgb(204, 0, 0);&quot;&gt;ا&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Kufam&quot;&gt;لتوضيح للفهم:&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font style=&quot;color: rgb(28, 51, 38);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;إنت عندك بيانات واضحة (زي رسالة) وعايز تحوّلها لشكل ميبقاش مفهوم أو ما يتقريش إلا من خلال شخص معين معاه المفتاح هو ده التشفير.&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="8s1uBqA9vXEwEWGlCemx-8" vertex="1">
          <mxGeometry x="295" y="5" width="445" height="32" as="geometry" />
        </mxCell>
        <mxCell id="8s1uBqA9vXEwEWGlCemx-39" value="&lt;div&gt;The one-way hash function `H` can be applied to a data block `M` of with any size.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#90D2D8;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=80;" parent="1" vertex="1">
          <mxGeometry x="67" y="585" width="606" height="40" as="geometry" />
        </mxCell>
        <mxCell id="8s1uBqA9vXEwEWGlCemx-40" value="Requirements to be satisfied by one-way hash functions" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#90D2D8;strokeColor=#000000;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=2;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="59" y="545" width="580" height="40" as="geometry" />
        </mxCell>
        <mxCell id="8s1uBqA9vXEwEWGlCemx-41" value="&lt;div&gt;The result message digest, `d`, is of fixed size usually `128`&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;or `160` bits&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#90D2D8;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=70;" parent="1" vertex="1">
          <mxGeometry x="67" y="625" width="516" height="40" as="geometry" />
        </mxCell>
        <mxCell id="8s1uBqA9vXEwEWGlCemx-42" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;easy to implement in both hardware and software.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#90D2D8;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=60;" parent="1" vertex="1">
          <mxGeometry x="67" y="665" width="388" height="40" as="geometry" />
        </mxCell>
        <mxCell id="8s1uBqA9vXEwEWGlCemx-43" value="&lt;div style=&quot;direction: ltr;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Given the message digest `d`, it is very hard to find the original message `M`&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#90D2D8;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=50;" parent="1" vertex="1">
          <mxGeometry x="67" y="705" width="562" height="40" as="geometry" />
        </mxCell>
        <mxCell id="8s1uBqA9vXEwEWGlCemx-44" value="Given the message `M`, it is very hard to find a data block `N` such that `H (N) = H (M)`" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#90D2D8;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=40;" parent="1" vertex="1">
          <mxGeometry x="67" y="745" width="656" height="40" as="geometry" />
        </mxCell>
        <mxCell id="8s1uBqA9vXEwEWGlCemx-45" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=2;fillColor=#90D2D8;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=6;verticalAlign=middle;fillStyle=solid;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;glass=0;shadow=0;opacity=80;" parent="1" vertex="1">
          <mxGeometry x="43" y="585" width="24" height="40" as="geometry" />
        </mxCell>
        <mxCell id="8s1uBqA9vXEwEWGlCemx-46" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=2;fillColor=#90D2D8;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=6;verticalAlign=middle;fillStyle=solid;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;glass=0;shadow=0;opacity=70;" parent="1" vertex="1">
