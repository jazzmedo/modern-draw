        <mxCell id="h6eXFfXM4W7l3cRYEoy7-83" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;color: rgb(51, 102, 0);&quot;&gt;&lt;font style=&quot;background-color: transparent; font-weight: normal; text-wrap-mode: wrap;&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;font&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;رسائل النظام:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; font-weight: normal;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b&gt;أوقات السيستم بيعرض رسالة ترحيب فيها اسم النظام قبل أو بعد الـ Login،&amp;nbsp;&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-weight: normal;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b&gt;ده ممكن يدي معلومة للهاكر عن نوع السيستم &lt;br&gt;اللي بيهجم عليه،&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-weight: normal;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b&gt;المفروض نمنع الرسائل&amp;nbsp;&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;b style=&quot;font-family: Beiruti; font-size: x-small; background-color: transparent; color: rgb(51, 102, 0);&quot;&gt;دي، وكمان لما اليوزر&amp;nbsp; يكتب الباسورد، ما يتعرضش قدام الناس، عشان محدش يقراها من وراه&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;rounded=1;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="234.13999999999987" y="1189" width="435" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-84" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;color: rgb(0, 0, 153); font-family: Beiruti; font-size: x-small; background-color: transparent;&quot;&gt;عدد محاولات محدود: معظم الأنظمة بتسمح&amp;nbsp; بعدد محاولات قليل لو خلصواـ الid بيتوقف&amp;nbsp;&lt;/b&gt;&lt;b style=&quot;color: rgb(0, 0, 153); font-family: Beiruti; font-size: x-small; background-color: transparent;&quot;&gt;&amp;nbsp;و لازم يكلم أدمن عشان يرجع تاني&lt;br&gt;&amp;nbsp;ده بيمنع ال bruteforce attack&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;rounded=1;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
