        </mxCell>
        <mxCell id="ypaqH-uUHXjcv0g4RAur-10" value="&lt;div&gt;It is the attack in which some data will be injected into a web app to manipulate the&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;application and fetch the required information.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#FFECB3;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=solid;align=left;spacingRight=2;spacingLeft=2;fillOpacity=80;spacing=2;spacingTop=0;container=0;" parent="ypaqH-uUHXjcv0g4RAur-6" vertex="1">
