        </mxCell>
        <mxCell id="viWILsfknehf8Vpiy5tB-19" value="consists of tracking and investigating the history of suspicious activity we divide it into two parts audit trail, intrusion analysis" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#ffe6cc;strokeColor=#281202;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;sketch=1;curveFitting=1;jiggle=2;" parent="viWILsfknehf8Vpiy5tB-18" vertex="1">
