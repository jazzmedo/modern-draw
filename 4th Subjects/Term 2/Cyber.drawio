        <mxCell id="416QoxgmyYfooZZkW0Gl-37" value="is the process of &lt;font style=&quot;color: rgb(1, 118, 211);&quot;&gt;detecting and identifying&lt;/font&gt; &lt;font style=&quot;color: rgb(182, 5, 84);&quot;&gt;unauthorized or unusual activity&lt;/font&gt; on the system by using &lt;u&gt;audit records&lt;/u&gt; it should identify any undesirable activity" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#fff2cc;strokeColor=#281202;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;" parent="416QoxgmyYfooZZkW0Gl-35" vertex="1">
