        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-26" value="&amp;nbsp;User may be given item such as keys that help system to authenticate them or devices like Credit card &amp;amp; Token Card" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#99CCFF;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=20;fillStyle=solid;" parent="zaUk_k8dVsGs0_1cOOlX-18" vertex="1">
