        <mxCell id="3EmIRpmpSdk3kt2dipBs-173" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Fustat&quot; face=&quot;Fustat&quot; style=&quot;color: rgb(204, 0, 0);&quot;&gt;ا&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Kufam&quot;&gt;لتوضيح للفهم:&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font style=&quot;color: rgb(140, 75, 2);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;مراقبة الـ workstation معناها إننا بنعمل tracking (تتبع) و investigating&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;b style=&quot;text-wrap-mode: nowrap;&quot;&gt;تحليل&lt;/b&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;&amp;nbsp;للأحداث المهمة اللي حصلت على الجهاز.&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#8c4b02&quot;&gt;&lt;b&gt;زي مين دخل عالجهاز و امتي؟؟ أو ايه التغيرات اللي حصلت في الملفات&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-462" y="50" width="390" height="60" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-174" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(138, 3, 62);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;ده ببساطة سجل الأحداث — زي &quot;دفتر حضور&amp;nbsp; و انصراف&quot; لأي حاجة بتحصل على الجهاز.&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-332" y="189" width="260" height="30" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-175" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(160, 108, 1);&quot;&gt;&lt;font style=&quot;&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;ده الجزء اللي بنحلل فيه لو فيه intrusion (اختراق أو محاولة اختراق).&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;b style=&quot;text-wrap-mode: nowrap; font-family: Beiruti; font-size: x-small; background-color: transparent;&quot;&gt;يعني بنستخدم المعلومات اللي جمعناها من الـ audit trail علشان نعرف:&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(160, 108, 1);&quot;&gt;&lt;font style=&quot;&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;هل اللي حصل ده طبيعي&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;font style=&quot;background-color: transparent;&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;هل دي محاولة تهكير؟&amp;nbsp;&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;b style=&quot;background-color: transparent; text-wrap-mode: nowrap; font-family: Beiruti; font-size: x-small;&quot;&gt;لو فيه خطر، جاي منين؟ وازاي حصل؟&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-509" y="569" width="439" height="44" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-176" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Fustat&quot; face=&quot;Fustat&quot; style=&quot;color: rgb(204, 0, 0);&quot;&gt;ا&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Kufam&quot;&gt;لتوضيح للفهم:&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font style=&quot;color: rgb(64, 16, 117);&quot;&gt;&lt;font style=&quot;&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;ببساطة، هو وصف لـ &quot;التصرفات العادية&quot; لأي شخص على النظام.&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;b style=&quot;text-wrap-mode: nowrap; font-family: Beiruti; font-size: x-small; background-color: transparent;&quot;&gt;لو حد خرج برا النمط ده — النظام يقدر يعرف إن فيه حاجة غلط أو abnormal activity من خلال الـ audit records.&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-622" y="678" width="550" height="52" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-177" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(25, 78, 49);&quot;&gt;&lt;font style=&quot;&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;ده بيتابع إمتى اليوزر&amp;nbsp; ب&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;font style=&quot;background-color: transparent;&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;يسجل دخول و ب&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;b style=&quot;background-color: transparent; text-wrap-mode: nowrap; font-family: Beiruti; font-size: x-small;&quot;&gt;يخرج من السيستم&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-251" y="831" width="179" height="32" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-178" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(1, 68, 134);&quot;&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b style=&quot;&quot;&gt;ده بيراقب إيه البرامج اللي اليوزر&amp;nbsp; بيشغلها،&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;font style=&quot;&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font&gt;عدد المرات اللي شغّل فيها البرنامج&lt;/font&gt;&lt;br&gt;&lt;font&gt;&amp;nbsp;&lt;/font&gt;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;font style=&quot;&quot;&gt;&lt;font style=&quot;background-color: transparent;&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;استهلاك الموارد&amp;nbsp; &amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;b style=&quot;background-color: transparent; text-wrap-mode: nowrap; font-family: Beiruti; font-size: x-small;&quot;&gt;وهل حصل execution denied&lt;/b&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-311" y="916" width="239" height="52" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-179" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(2, 52, 52);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;ده بيتابع كل تفاعل مع الملفات&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-177" y="1058" width="104" height="32" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-180" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#014486&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;لو النظام لقى إن فيه تصرف مش طبيعي (يعني مختلف عن الـ profile بتاع اليوزر) في الـ audit records — بيعمل حاجة اسمها Anomaly Record.&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#014486&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;يعني زي تقرير&amp;nbsp; بيقول: &quot;أن فيه حاجة غريبة حصلت بالتوقيت و ايه الprofile اللي مطابقهوش.&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-521" y="1168" width="449" height="52" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-181" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(130, 81, 1);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b style=&quot;color: rgb(130, 81, 1); text-wrap-mode: nowrap;&quot;&gt;&amp;nbsp;نوع من البرامج ب&lt;/b&gt;&lt;font color=&quot;#825101&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;تنسخ نفسها بنفسها... وده من غير ما تهاجم أي برنامج تاني بشكل مباشر&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;b style=&quot;color: rgb(130, 81, 1); text-wrap-mode: nowrap;&quot;&gt;، لكنها بتستهلك موارد الجهاز لدرجة إنها ممكن تعطل النظام&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-598" y="1390" width="475" height="30" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-182" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(64, 16, 117);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b style=&quot;text-wrap-mode: nowrap;&quot;&gt;برنامج خبيث مستقل&amp;nbsp; يعني يقدر&amp;nbsp; يشتغل لوحده، من غير ما يحتاج يركب نفسه جوه برنامج تاني زي الـ virus. بينسخ نفسه ينتشر من جهاز لجهاز عن طريق الشبكة&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;غالبًا مش بيهاجم برامج تانية، بس وجوده مش بريء… لأنه بيستهلك موارد الشبكة&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-616" y="1489" width="495" height="37" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-183" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(28, 51, 38);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;هو باب سري جوا برنامج بيسمح للي عمله إنه يعدي كل الحماية ويدخل للبرنامج أو النظام من غير ما يمر على الإجراءات الطبيعية (زي الباسورد) &lt;br&gt;عشان&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#1c3326&quot;&gt;&lt;b&gt;يختبر البرنامج لكن ممكن ينسي يشيلة&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-564.56" y="1598" width="435.11" height="30" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-184" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(3, 45, 96);&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;هي كود خبيث موجود جوا برنامج تاني، ومستني شرط معين يحصل علشان ينفجر ويعمل ضرر. و ممكن&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b style=&quot;&quot;&gt;يمسح ملفات&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-490.8899999999999" y="1702" width="361.45" height="30" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-185" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#032d60&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;هو كود خبيث بيتخبى جوا برنامج شكله عادي أو مفيد.&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#032d60&quot;&gt;&lt;b&gt;ما بيشتغلش لوحده (لازم يكون جوا برنامج)&amp;nbsp; و ممكن يسرق داتا او يتحكم فجهازك&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-554.56" y="1806" width="425.11" height="30" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-186" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Fustat&quot; face=&quot;Fustat&quot; style=&quot;color: rgb(204, 0, 0);&quot;&gt;ا&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Kufam&quot;&gt;لتوضيح للفهم:&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#401075&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;1) حدد أول Instruction (تعليمة تنفيذ) في البرنامج الأصلي.&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#401075&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;2)&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#401075&quot;&gt;&lt;b&gt;الأمر&amp;nbsp; ده هيخلي التنفيذ يروح على طول لنهاية البرنامج، اللي فيها الفيروس&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#401075&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;3)&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#401075&quot;&gt;&lt;b&gt;حط كود الفيروس في آخر البرنامج&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#401075&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;4)&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#401075&quot;&gt;&lt;b&gt;بعد ما الفيروس يخلص، حط تعليمة تعيد تنفيذ أول Instruction اللي احنا شيلناها في خطوة 2.(ك&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;b style=&quot;text-wrap-mode: nowrap; color: rgb(64, 16, 117); font-family: Beiruti; font-size: x-small; background-color: transparent;&quot;&gt;أنك بتقول للبرنامج: &quot;آسف على التأخير، خُد نفّذ اللي كنت ناوي تعمله&quot;)&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;b style=&quot;text-wrap-mode: nowrap; color: rgb(64, 16, 117); font-family: Beiruti; font-size: x-small; background-color: transparent;&quot;&gt;5)&amp;nbsp;&lt;/b&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#401075&quot;&gt;&lt;b&gt;أخيرًا، حط أمر jump ترجع للأوامر العادية&amp;nbsp;(البرنامج بتاعي)&amp;nbsp;&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#401075&quot;&gt;&lt;b&gt;بكده البرنامج يكمل شغله كأنه مفيش حاجة حصلت&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-577" y="2183" width="524" height="120" as="geometry" />
        </mxCell>
        <mxCell id="nE1Fr7ITnr2DWF81ayit-15" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="-780" y="301" width="680" height="254" as="geometry" />
        </mxCell>
        <mxCell id="nE1Fr7ITnr2DWF81ayit-1" value="&lt;div&gt;Automatically collects information on all the&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;security-sensitive activities that often&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;selected by the administrator&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#BCCFFF;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=80;" vertex="1" parent="nE1Fr7ITnr2DWF81ayit-15">
          <mxGeometry x="24" y="40" width="536" height="54" as="geometry" />
        </mxCell>
        <mxCell id="nE1Fr7ITnr2DWF81ayit-2" value="Audit Requirements" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#BCCFFF;strokeColor=#36393d;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=2;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=solid;" vertex="1" parent="nE1Fr7ITnr2DWF81ayit-15">
          <mxGeometry x="16" width="207" height="40" as="geometry" />
        </mxCell>
        <mxCell id="nE1Fr7ITnr2DWF81ayit-3" value="&lt;div&gt;Stores the information using a standard&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;record format.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#BCCFFF;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=70;" vertex="1" parent="nE1Fr7ITnr2DWF81ayit-15">
          <mxGeometry x="24" y="94" width="417" height="40" as="geometry" />
        </mxCell>
        <mxCell id="nE1Fr7ITnr2DWF81ayit-4" value="&lt;div&gt;Create and save audit records&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;automatically without requiring any action by&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;the admin.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#BCCFFF;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=60;" vertex="1" parent="nE1Fr7ITnr2DWF81ayit-15">
          <mxGeometry x="24" y="134" width="645" height="40" as="geometry" />
        </mxCell>
        <mxCell id="nE1Fr7ITnr2DWF81ayit-5" value="&lt;div style=&quot;direction: ltr;&quot;&gt;&lt;div style=&quot;direction: ltr;&quot;&gt;Protects the audit records log under&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;some security scheme (e.g encryption).&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#BCCFFF;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=50;" vertex="1" parent="nE1Fr7ITnr2DWF81ayit-15">
          <mxGeometry x="24" y="174" width="579" height="40" as="geometry" />
        </mxCell>
        <mxCell id="nE1Fr7ITnr2DWF81ayit-6" value="&lt;div&gt;Minimally affects the normal computer&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;system operation and performance.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#BCCFFF;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=40;" vertex="1" parent="nE1Fr7ITnr2DWF81ayit-15">
