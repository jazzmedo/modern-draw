          <mxGeometry x="37" y="635" width="670" height="650" as="geometry" />
        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-1" value=" " style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fillColor=none;arcSize=2;strokeWidth=2;" parent="DJcv6TiS2SLJbePKLPNc-16" vertex="1">
          <mxGeometry y="41" width="670" height="609" as="geometry" />
