        <mxCell id="uU0IHdjwgiejwzPI_jMc-1" value="&lt;div&gt;The one-way hash function `H` can be applied to a data block `M` of with any size.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#90D2D8;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=80;" parent="hOXUQQMBu0Lae1k2kh_e-74" vertex="1">
          <mxGeometry x="24" y="40" width="606" height="40" as="geometry" />
        </mxCell>
        <mxCell id="uU0IHdjwgiejwzPI_jMc-2" value="Requirements to be satisfied by one-way hash functions" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=2;fillColor=#90D2D8;strokeColor=#000000;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=2;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=solid;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;" parent="hOXUQQMBu0Lae1k2kh_e-74" vertex="1">
          <mxGeometry x="16" width="626" height="40" as="geometry" />
        </mxCell>
        <mxCell id="uU0IHdjwgiejwzPI_jMc-3" value="&lt;div&gt;The result message digest, `d`, is of fixed size usually `128`&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;or `160` bits&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#90D2D8;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=70;" parent="hOXUQQMBu0Lae1k2kh_e-74" vertex="1">
          <mxGeometry x="24" y="80" width="536" height="40" as="geometry" />
        </mxCell>
        <mxCell id="uU0IHdjwgiejwzPI_jMc-4" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;easy to implement in both hardware and software.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#90D2D8;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=60;" parent="hOXUQQMBu0Lae1k2kh_e-74" vertex="1">
