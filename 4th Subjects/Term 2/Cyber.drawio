        <mxCell id="h6eXFfXM4W7l3cRYEoy7-25" value="is the process of verifying something, Such as a user&#39;s identity, a network address, establishes an association between two entities" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#99CCFF;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillOpacity=50;fillStyle=cross-hatch;" parent="h6eXFfXM4W7l3cRYEoy7-20" vertex="1">
