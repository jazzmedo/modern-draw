        </mxCell>
        <mxCell id="416QoxgmyYfooZZkW0Gl-61" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#032d60&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;هو كود خبيث بيتخبى جوا برنامج شكله عادي أو مفيد.&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot; color=&quot;#032d60&quot;&gt;&lt;b&gt;ما بيشتغلش لوحده (لازم يكون جوا برنامج)&amp;nbsp; و ممكن يسرق داتا او يتحكم فجهازك&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="hOXUQQMBu0Lae1k2kh_e-68" vertex="1">
