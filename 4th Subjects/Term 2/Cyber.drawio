        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-7" value="Web-based attacks" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#FFF9C4;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;" parent="1jSB9UTQtr0Iap5kisdN-6" vertex="1">
          <mxGeometry x="58.5" width="205" height="40" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-8" value="&lt;div&gt;These are the &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;attacks &lt;/font&gt;which occur &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;on a website&lt;/font&gt; or web applications.&lt;br&gt;Some of the important&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;web-based attacks are as follows&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#FFF9C4;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;align=left;spacingRight=2;spacingLeft=2;fillOpacity=80;spacing=2;spacingTop=0;" parent="1jSB9UTQtr0Iap5kisdN-6" vertex="1">
          <mxGeometry x="30.5" y="40" width="710" height="63" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-9" value="Injection attacks" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#FFECB3;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;" parent="1jSB9UTQtr0Iap5kisdN-6" vertex="1">
          <mxGeometry x="79.5" y="121" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-10" value="&lt;div&gt;It is the attack in which some data will be injected into a web app to manipulate the&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;application and fetch the required information.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#FFECB3;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;align=left;spacingRight=2;spacingLeft=2;fillOpacity=80;spacing=2;spacingTop=0;" parent="1jSB9UTQtr0Iap5kisdN-6" vertex="1">
          <mxGeometry x="58.5" y="151" width="712" height="63" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-11" value="Phishing" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#FFE0B2;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;" parent="1jSB9UTQtr0Iap5kisdN-6" vertex="1">
          <mxGeometry x="79.5" y="228" width="100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-12" value="&lt;div&gt;&amp;nbsp;type of attack which attempts to steal sensitive information like user login&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;credentials and credit card number.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#FFE0B2;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;align=left;spacingRight=2;spacingLeft=2;fillOpacity=80;spacing=2;spacingTop=0;" parent="1jSB9UTQtr0Iap5kisdN-6" vertex="1">
          <mxGeometry x="58.5" y="258" width="716" height="63" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-13" value="Session Hijacking" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#FFCCBC;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;" parent="1jSB9UTQtr0Iap5kisdN-6" vertex="1">
          <mxGeometry x="79.5" y="334" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-14" value="&lt;div&gt;&amp;nbsp;Security attack on a user session over a protected network. When web apps create&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;cookies to store user sessions, by stealing the cookies the attacker can have access&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;to all of the user data.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#FFCCBC;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;align=left;spacingRight=2;spacingLeft=2;fillOpacity=80;spacing=2;spacingTop=0;" parent="1jSB9UTQtr0Iap5kisdN-6" vertex="1">
          <mxGeometry x="58.5" y="364" width="722" height="90" as="geometry" />
        </mxCell>
