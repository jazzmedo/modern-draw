        <mxCell id="zaUk_k8dVsGs0_1cOOlX-62" value="Known to everyone and published or shared." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#666666;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;gradientColor=none;container=0;" parent="DJcv6TiS2SLJbePKLPNc-17" vertex="1">
