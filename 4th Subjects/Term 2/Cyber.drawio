        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-26" value="Authentication" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#99CCFF;strokeColor=#000000;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=cross-hatch;sketch=1;curveFitting=1;jiggle=2;strokeOpacity=100;fillOpacity=80;" parent="h6eXFfXM4W7l3cRYEoy7-20" vertex="1">
          <mxGeometry x="30" width="170" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-27" value="&lt;div&gt;&amp;nbsp;Users given a something secret to memorize only users and system known it,&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;such as a password.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#99CCFF;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillOpacity=20;fillStyle=cross-hatch;" parent="h6eXFfXM4W7l3cRYEoy7-20" vertex="1">
          <mxGeometry x="140" y="133" width="580" height="47" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-28" value="&amp;nbsp;User may be given item such as keys that help system to authenticate them or devices like Credit card" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#99CCFF;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillOpacity=20;fillStyle=cross-hatch;" parent="h6eXFfXM4W7l3cRYEoy7-20" vertex="1">
          <mxGeometry x="140" y="220" width="580" height="48" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-29" value="&lt;div&gt;&amp;nbsp;Every user has some unique physiological and&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;behavioral characteristics that can be recorded&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;and compared.&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp; - Physiological characteristics which include&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;fingerprints.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; -&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Behavioral characteristics like&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;signature&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#99CCFF;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillOpacity=20;fillStyle=cross-hatch;" parent="h6eXFfXM4W7l3cRYEoy7-20" vertex="1">
          <mxGeometry x="140" y="310" width="580" height="90" as="geometry" />
        </mxCell>
