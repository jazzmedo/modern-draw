        </mxCell>
        <mxCell id="ypaqH-uUHXjcv0g4RAur-28" value="&lt;div style=&quot;direction: ltr;&quot;&gt;&lt;div style=&quot;direction: ltr;&quot;&gt;&amp;nbsp;is a&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;piece of code that hides inside a program and&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;performs a disguised function,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;does not exist independently.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#C4EDE1;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=solid;align=left;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;container=0;" parent="ypaqH-uUHXjcv0g4RAur-6" vertex="1">
