        <mxCell id="CjQmsrEuOwg8r-tlR_oF-17" value="&lt;div&gt;Protection of &lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;information from &lt;u&gt;modification by unauthorized&lt;/u&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;u&gt;&amp;nbsp;users&lt;/u&gt; that provided by network security. This is done using hash functions to make sure that the data is not changed.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#FFECB8;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=4;verticalAlign=middle;fillStyle=solid;" parent="uU0IHdjwgiejwzPI_jMc-30" vertex="1">
          <mxGeometry x="42.88999999999987" y="388" width="684" height="60" as="geometry" />
        </mxCell>
        <mxCell id="CjQmsrEuOwg8r-tlR_oF-18" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;line-height: 130%;&quot;&gt;Used to detect any &lt;u&gt;&lt;font style=&quot;color: rgb(3, 45, 96);&quot;&gt;unauthorized changes on message&lt;/font&gt;&lt;/u&gt;.&lt;/div&gt;&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;font style=&quot;color: rgb(234, 0, 30);&quot;&gt;Purpose&lt;/font&gt;: provide the means for the receiver to detect whether the message has been modified by unauthorized means, also should produce a fingerprint of messages.&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#FFECB8;strokeColor=#023248;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=4;verticalAlign=middle;fillStyle=solid;" parent="uU0IHdjwgiejwzPI_jMc-30" vertex="1">
