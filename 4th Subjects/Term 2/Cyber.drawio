        <mxCell id="jYJ7SZwmHjdRUawJQQ35-3" parent="H3stWV2xd4NMoBnClgeH-66" style="text;html=1;align=right;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=1" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Fustat&quot; data-font-src=&quot;https://fonts.googleapis.com/css?family=Fustat&quot; style=&quot;color: rgb(204, 0, 0);&quot;&gt;ا&lt;span&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Kufam&quot;&gt;لتوضيح للفهم:&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;لما أي subject يحاول يدخل على object، الـ Access Control بيشتغل ويتأكد من إنه يطبق القوانين دي.&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;فيه طريقتين مشهورين علشان السيستم يعرف مين له حق يعمل إيه:&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;ACL&amp;nbsp; دي عبارة عن &quot;ليستة&quot; مرتبطة بكل Object&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;بتقول: كل Subject يقدر يعمل إيه على الـ Object ده&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;CL&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;دي العكس!&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;زي &quot;ليستة&quot; مرتبطة بكل Subject&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;بتقول: الـ Subject ده يقدر&amp;nbsp; يوصل لأنهي Objects ويعمل عليهم إيه&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="380" x="344" y="362" as="geometry" />
        </mxCell>
        <mxCell id="jYJ7SZwmHjdRUawJQQ35-4" parent="H3stWV2xd4NMoBnClgeH-66" style="text;html=1;align=right;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=1" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Fustat&quot; data-font-src=&quot;https://fonts.googleapis.com/css?family=Fustat&quot; style=&quot;color: rgb(204, 0, 0);&quot;&gt;ا&lt;span&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Kufam&quot;&gt;لتوضيح للفهم:&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Beiruti&quot; face=&quot;Beiruti&quot; style=&quot;font-size: 9px;&quot;&gt;المبدأ الأساسي هنا هو: مين يقدر يعمل إيه على إيه؟&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Beiruti&quot; face=&quot;Beiruti&quot; style=&quot;font-size: 9px;&quot;&gt;يعني لما حد زي يوزر أو برنامج (subject) يحاول يدخل على حاجة زي فايل أو قاعدة بيانات(object)، لازم النظام يقرر:&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Beiruti&quot; face=&quot;Beiruti&quot; style=&quot;font-size: 9px;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Katibeh&quot; style=&quot;&quot;&gt;هل الشخص ده فعلاً مسموح له يوصل للحاجة دي؟ ولو مسموح، يقدر يعمل إيه بالظبط؟ يقرأ؟ يكتب؟ &lt;/font&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Mali&quot; style=&quot;&quot;&gt;(Access Control)&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
