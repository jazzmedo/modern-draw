        <mxCell id="8s1uBqA9vXEwEWGlCemx-12" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;line-height: 130%;&quot;&gt;Used to detect any &lt;u&gt;&lt;font style=&quot;color: rgb(3, 45, 96);&quot;&gt;unauthorized changes on message&lt;/font&gt;&lt;/u&gt;.&lt;/div&gt;&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;font style=&quot;color: rgb(234, 0, 30);&quot;&gt;Purpose&lt;/font&gt;: provide the means for the receiver to detect whether the message has been modified by unauthorized means, also should produce a fingerprint of messages.&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#CFE9FE;strokeColor=#023248;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=4;verticalAlign=middle;fillStyle=solid;" parent="1" vertex="1">
