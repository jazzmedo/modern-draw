        </mxCell>
        <mxCell id="viWILsfknehf8Vpiy5tB-17" value="There are important events that should be recorded ex: system being hacked with intruder who tries passwords periodically to bypass system checks audit help detecting these threats&amp;nbsp;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#f8cecc;strokeColor=#281202;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;sketch=1;curveFitting=1;jiggle=2;" parent="viWILsfknehf8Vpiy5tB-16" vertex="1">
