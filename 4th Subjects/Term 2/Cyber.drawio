        <mxCell id="416QoxgmyYfooZZkW0Gl-12" value="is &lt;font style=&quot;color: light-dark(rgb(8, 7, 7), rgb(216, 58, 0));&quot;&gt;an&lt;/font&gt;&lt;font style=&quot;color: light-dark(rgb(216, 58, 0), rgb(216, 58, 0));&quot;&gt;&amp;nbsp;&lt;i style=&quot;color: rgb(234, 14, 14); font-size: 12px;&quot;&gt;*&amp;nbsp;&lt;/i&gt;independent program&lt;/font&gt; that can replicate itself and often spreads to different sites over a network,&lt;font style=&quot;color: light-dark(rgb(1, 118, 211), rgb(255, 255, 255));&quot;&gt;&lt;i style=&quot;color: rgb(234, 14, 14); font-size: 12px;&quot;&gt;*&amp;nbsp;&lt;/i&gt;doesn&#39;t attack&lt;/font&gt; programs but it&lt;font style=&quot;color: light-dark(rgb(216, 58, 0), rgb(216, 58, 0));&quot;&gt;&lt;i style=&quot;color: rgb(234, 14, 14); font-size: 12px;&quot;&gt;*&amp;nbsp;&lt;/i&gt;consumes network resources&lt;/font&gt;." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#F2DEFE;strokeColor=#481A54;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;" parent="hOXUQQMBu0Lae1k2kh_e-68" vertex="1">
