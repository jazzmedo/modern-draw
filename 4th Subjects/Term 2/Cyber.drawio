        <mxCell id="ypaqH-uUHXjcv0g4RAur-16" value="&lt;div&gt;These are the &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;attacks &lt;/font&gt;which occur &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;on a website&lt;/font&gt; or web applications.&lt;br&gt;Some of the important&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;web-based attacks are as follows&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#FFF9C4;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=solid;align=left;spacingRight=2;spacingLeft=2;fillOpacity=80;spacing=2;spacingTop=0;container=0;" parent="ypaqH-uUHXjcv0g4RAur-6" vertex="1">
