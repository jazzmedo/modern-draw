        <mxCell id="zaUk_k8dVsGs0_1cOOlX-47" parent="zaUk_k8dVsGs0_1cOOlX-45" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#D2EBEB;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=60;fillStyle=solid;" value="&lt;div&gt;allows the system administrator to&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;lock out an ID that has not been used for a long time or&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;unchanged passwords. To unlocked should user contact with Admin to re-authenticate by other methods.&lt;/span&gt;&lt;/div&gt;" vertex="1">
