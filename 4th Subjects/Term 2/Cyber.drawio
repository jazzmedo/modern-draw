        </mxCell>
        <mxCell id="viWILsfknehf8Vpiy5tB-12" value="is an independent program that can replicate itself and often spreads to different sites over a network, doesn&#39;t attack programs but it consumes network resources." style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#F2DEFE;strokeColor=#481A54;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;" parent="1" vertex="1">
