        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-79" parent="DJcv6TiS2SLJbePKLPNc-16" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Fustat&quot; face=&quot;Fustat&quot; style=&quot;color: rgb(204, 0, 0);&quot;&gt;ا&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Kufam&quot;&gt;لتوضيح للفهم:&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font color=&quot;#990000&quot;&gt;&lt;b&gt;عشان نحمي السيستم من تخمين الباسورد، فيه شوية قوانين وإجراءات أمان لازم تتطبق &amp;lt;/&amp;gt;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="37" width="277.86" x="361.27999999999975" as="geometry" />
