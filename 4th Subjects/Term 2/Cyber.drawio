        <mxCell id="h6eXFfXM4W7l3cRYEoy7-49" value="User Lockouts" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#B4DFDF;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillOpacity=100;fillStyle=cross-hatch;" parent="h6eXFfXM4W7l3cRYEoy7-48" vertex="1">
          <mxGeometry x="11" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-50" value="&lt;div&gt;allows the system administrator to&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;lock out an ID that has not been used for a long time or&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;unchanged passwords. To unlocked should user contact with Admin to re-authenticate by other methods.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#D2EBEB;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillOpacity=60;fillStyle=cross-hatch;" parent="h6eXFfXM4W7l3cRYEoy7-48" vertex="1">
          <mxGeometry x="-2.75" y="40" width="620" height="70" as="geometry" />
        </mxCell>
