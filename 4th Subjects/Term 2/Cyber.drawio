        <mxCell id="zaUk_k8dVsGs0_1cOOlX-35" value="Pass***word&lt;sup&gt;&lt;font color=&quot;#ff0000&quot;&gt;*&lt;/font&gt;&lt;/sup&gt;" style="fillColor=none;strokeColor=none;html=1;fontSize=11;fontStyle=0;align=left;fontColor=#596780;fontStyle=1;fontSize=11;verticalAlign=middle;" parent="zaUk_k8dVsGs0_1cOOlX-34" vertex="1">
