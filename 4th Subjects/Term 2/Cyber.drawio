        <mxCell id="ypaqH-uUHXjcv0g4RAur-23" value="Virus" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#BFE8DC;strokeColor=#000000;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=solid;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;align=center;container=0;" parent="ypaqH-uUHXjcv0g4RAur-6" vertex="1">
          <mxGeometry x="69" y="554" width="70" height="34" as="geometry" />
        </mxCell>
        <mxCell id="ypaqH-uUHXjcv0g4RAur-24" value="&lt;div style=&quot;direction: ltr;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;A virus is a type of malicious software program, not independent program and&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;also execute&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;instructions that cause harm to system&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#BFE8DC;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=solid;align=left;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;container=0;" parent="ypaqH-uUHXjcv0g4RAur-6" vertex="1">
          <mxGeometry x="48" y="588" width="666.5" height="51" as="geometry" />
        </mxCell>
        <mxCell id="ypaqH-uUHXjcv0g4RAur-25" value="Worm" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#C8F0E6;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=solid;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;align=center;container=0;" parent="ypaqH-uUHXjcv0g4RAur-6" vertex="1">
          <mxGeometry x="69" y="740" width="70" height="34" as="geometry" />
        </mxCell>
        <mxCell id="ypaqH-uUHXjcv0g4RAur-26" value="&lt;div style=&quot;direction: ltr;&quot;&gt;&lt;div style=&quot;direction: ltr; line-height: 130%;&quot;&gt;is an independent program that can&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;replicate itself and often spreads to different&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;sites over a network, doesn&#39;t attack programs but it consumes network resources.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#C8F0E6;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=solid;align=left;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;container=0;" parent="ypaqH-uUHXjcv0g4RAur-6" vertex="1">
          <mxGeometry x="48" y="774" width="666.5" height="54" as="geometry" />
        </mxCell>
        <mxCell id="ypaqH-uUHXjcv0g4RAur-27" value="Trojan horse" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#C4EDE1;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=solid;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;align=center;container=0;" parent="ypaqH-uUHXjcv0g4RAur-6" vertex="1">
