        </mxCell>
        <mxCell id="zaUk_k8dVsGs0_1cOOlX-53" parent="zaUk_k8dVsGs0_1cOOlX-51" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#F4E5E5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillOpacity=100;fillStyle=solid;" value="&lt;div&gt;each password&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;has a fixed lifetime, after which the password&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;must be changed.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;" vertex="1">
