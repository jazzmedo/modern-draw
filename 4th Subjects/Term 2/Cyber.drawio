        <mxCell id="h6eXFfXM4W7l3cRYEoy7-88" value="&lt;div style=&quot;line-height: 130%;&quot;&gt;&lt;div style=&quot;font-weight: 700; text-wrap-mode: nowrap;&quot;&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Fustat&quot; face=&quot;Fustat&quot; style=&quot;color: rgb(204, 0, 0);&quot;&gt;ا&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Kufam&quot;&gt;لتوضيح للفهم:&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font style=&quot;color: rgb(0, 102, 204);&quot;&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b style=&quot;&quot;&gt;الهاكرز لما بيحاولوا يخمنوا الباسورد، مش بيشتغلوا عشوائي،&lt;br&gt;&amp;nbsp;بيشتغلوا بخطة&amp;nbsp; فيها خطوات وطرق متكررة.&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;font style=&quot;background-color: transparent;&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font&gt;&lt;b&gt;&amp;nbsp;&amp;lt;/&amp;gt;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: rgb(110, 131, 123);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;يستخدموا معلومات شخصية&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;b style=&quot;text-wrap-mode: nowrap;&quot;&gt;ده ممكن يدي معلومة للهاكر عن نوع السيستم،&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b style=&quot;color: rgb(164, 108, 117); font-family: Beiruti; font-size: x-small; background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;يعني ياخدوا كلمة ويغيروا فيها شوية حاجات (تبديل حروف، يزود ارقام، ...)&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(170, 133, 103), rgb(75, 41, 14));&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b style=&quot;&quot;&gt;يجربوا تغييرات في الـ Capitalization&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font style=&quot;color: rgb(170, 157, 119);&quot; size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b style=&quot;&quot;&gt;لو اليوزر أجنبي أو معروف إنه بيستخدم لغة معينة، يجربوا كلمات من اللغة دي.&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(101, 148, 152);&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;&quot;&gt;يجمعوا كلمتين مع بعض&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap;&quot;&gt;&lt;font size=&quot;1&quot; face=&quot;Beiruti&quot;&gt;&lt;b style=&quot;&quot;&gt;Cyber Security&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;textShadow=0;labelBorderColor=none;strokeOpacity=100;fillOpacity=60;strokeColor=none;fillColor=none;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="502" y="960" width="257" height="150" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-1" value="" style="group" parent="1" vertex="1" connectable="0">
          <mxGeometry x="844" y="20" width="800" height="1120" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-2" value=" " style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fillColor=#f5f5f5;arcSize=4;strokeWidth=2;fontColor=#333333;strokeColor=#666666;" parent="1jSB9UTQtr0Iap5kisdN-1" vertex="1">
          <mxGeometry y="190" width="800" height="930" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-3" value="&lt;div&gt;Cyber security is the &lt;font style=&quot;color: rgb(0, 102, 204);&quot;&gt;body of&lt;/font&gt; technologies, processes, and practices &lt;font style=&quot;color: rgb(0, 102, 204);&quot;&gt;designed to&lt;/font&gt; protect networks, computers, programs and data from attack.&lt;/div&gt;&lt;div&gt;&amp;nbsp; - &lt;font style=&quot;color: rgb(0, 102, 204);&quot;&gt;Cyber Security&lt;/font&gt; refers to techniques and practices designed to protect digital data.&lt;/div&gt;&lt;div&gt;&amp;nbsp; - &lt;font style=&quot;color: rgb(0, 102, 204);&quot;&gt;Data &lt;/font&gt;that is stored, transmitted or used on an information system.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#FFF4C3;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=2;verticalAlign=middle;fillStyle=cross-hatch;spacingLeft=2;spacingRight=2;spacingTop=0;spacingBottom=0;" parent="1jSB9UTQtr0Iap5kisdN-1" vertex="1">
          <mxGeometry x="40" y="30" width="729" height="100" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-4" value="What is cyber security?" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#FFF4C3;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;" parent="1jSB9UTQtr0Iap5kisdN-1" vertex="1">
          <mxGeometry x="55" width="260" height="30" as="geometry" />
        </mxCell>
        <mxCell id="1jSB9UTQtr0Iap5kisdN-5" value="Types of Cyber Attacks" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#C0D0C7;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;shadow=0;sketch=1;curveFitting=1;jiggle=2;glass=0;fillOpacity=80;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;" parent="1jSB9UTQtr0Iap5kisdN-1" vertex="1">
          <mxGeometry x="56" y="150" width="250" height="40" as="geometry" />
