        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-62" value="One-Time Passwords" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=bottom;spacingBottom=3;fillStyle=cross-hatch;" parent="h6eXFfXM4W7l3cRYEoy7-61" vertex="1">
          <mxGeometry x="20" y="6" width="220" height="30" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-63" value="&lt;div&gt;generating passwords that can be used only&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;once. After use, the onetime password&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;becomes invalid.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;" parent="h6eXFfXM4W7l3cRYEoy7-61" vertex="1">
          <mxGeometry y="36" width="640" height="60" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-64" value="Public Key" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#B9E0A5;strokeColor=#000000;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;fillStyle=cross-hatch;gradientColor=#97d077;fillOpacity=80;container=0;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="258" y="1994" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-65" value="Known to everyone and published or shared." style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#666666;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;gradientColor=#b3b3b3;container=0;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="24" y="2034" width="370" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-66" value="&lt;div&gt;User A encrypts a message using User B’s public key, and only User B can decrypt it using&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;their private key. No one else can decrypt the message since only User B knows the private&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;key.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#eeeeee;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;container=0;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="403" y="1964" width="337" height="110" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-67" value="Two-party authentication" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=bottom;spacingBottom=3;fillStyle=cross-hatch;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="57" y="1832" width="260" height="30" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-68" value="&lt;div&gt;used for achieving&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;one-way authentication as well as two-way&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;authentication.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#D5E8D4;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="36" y="1862" width="650" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-69" value="Private Key" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#F19C99;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;fillStyle=cross-hatch;fillOpacity=80;container=0;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
          <mxGeometry x="34" y="1945" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-70" value="Known only to the user." style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#F8CECC;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=cross-hatch;container=0;" parent="jrUWaQdueoaqCH9xm50B-1" vertex="1">
