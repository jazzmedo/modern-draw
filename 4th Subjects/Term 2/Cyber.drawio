        </mxCell>
        <mxCell id="ypaqH-uUHXjcv0g4RAur-18" value="&amp;nbsp;Security attack on a user session over a protected network. When web apps create cookies to store user sessions, by stealing the cookies the attacker can have access to all of the user data." style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMina;strokeWidth=2;fillColor=#FFCCBC;strokeColor=#36393d;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=solid;align=left;spacingRight=1;spacingLeft=1;fillOpacity=80;spacing=3;spacingTop=0;container=0;" parent="ypaqH-uUHXjcv0g4RAur-6" vertex="1">
