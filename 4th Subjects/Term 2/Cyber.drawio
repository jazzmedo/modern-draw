          <mxGeometry x="55" y="1302" width="629.5" height="95" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-58" value="Limited Attempts" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#CCCCEA;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillOpacity=70;fillStyle=cross-hatch;" parent="h6eXFfXM4W7l3cRYEoy7-57" vertex="1">
          <mxGeometry x="10" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h6eXFfXM4W7l3cRYEoy7-59" value="&lt;div&gt;&amp;nbsp;Many systems restrict multiple&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;unsuccessful attempts to log on; Set a limit the when limit reached, system lock out user ID&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#E5E5F4;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;sketch=1;curveFitting=1;jiggle=2;fillOpacity=100;fillStyle=cross-hatch;" parent="h6eXFfXM4W7l3cRYEoy7-57" vertex="1">
