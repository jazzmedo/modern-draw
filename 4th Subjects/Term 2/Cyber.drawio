        <mxCell id="416QoxgmyYfooZZkW0Gl-25" value="characterize the behavior of a &lt;font style=&quot;color: rgb(182, 5, 84);&quot;&gt;subject &lt;/font&gt;on an &lt;font style=&quot;color: rgb(1, 118, 211);&quot;&gt;object&lt;/font&gt;. Profiles include the description of normal behavior of subjects with respect to the objects. So, profiles can be detect and report any abnormal activity" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#e1d5e7;strokeColor=#281202;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=4;verticalAlign=middle;fillStyle=solid;" parent="hOXUQQMBu0Lae1k2kh_e-69" vertex="1">
