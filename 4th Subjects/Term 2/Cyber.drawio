          <mxGeometry x="-770" y="575" width="699" height="100" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-160" value="Intrusion detection" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#fff2cc;strokeColor=#281202;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=5;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=solid;" parent="3EmIRpmpSdk3kt2dipBs-159" vertex="1">
          <mxGeometry x="19" width="197" height="40" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-161" value="is the process of detecting and identifying unauthorized or unusual activity on the system by using audit records it should identify any undesirable activity" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#fff2cc;strokeColor=#281202;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;fillStyle=solid;" parent="3EmIRpmpSdk3kt2dipBs-159" vertex="1">
          <mxGeometry y="40" width="700" height="60" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-162" value="&lt;div&gt;Locate the first executable instruction in the target program&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#E3D6F5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=90;" parent="1" vertex="1">
          <mxGeometry x="-742" y="1953" width="470" height="40" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-163" value="Designing a virus" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#E3D6F5;strokeColor=#000000;fontSize=22;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=2;verticalAlign=middle;spacingTop=0;spacingRight=2;container=0;fillStyle=solid;" parent="1" vertex="1">
          <mxGeometry x="-753" y="1913" width="186" height="40" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-164" value="Replace that instruction with a jump to the memory location next to the last instruction of the target program" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#E3D6F5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=85;" parent="1" vertex="1">
          <mxGeometry x="-742" y="1993" width="488" height="50" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-165" value="Insert the virus code at the end of the target program" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#E3D6F5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=80;" parent="1" vertex="1">
          <mxGeometry x="-742" y="2043" width="406" height="40" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-166" value="&lt;div style=&quot;direction: ltr;&quot;&gt;Insert an instruction at the end of the virus program to simulate the original first instruction of the target program&amp;nbsp;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#E3D6F5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=75;" parent="1" vertex="1">
          <mxGeometry x="-742" y="2083" width="481" height="50" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-167" value="Add another instruction at the end of the virus code to jump back to the second instruction of the target program" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#E3D6F5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=5;verticalAlign=middle;fillStyle=solid;glass=0;shadow=0;opacity=70;" parent="1" vertex="1">
          <mxGeometry x="-742" y="2133" width="651" height="50" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-168" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=2;fillColor=#E3D6F5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=6;verticalAlign=middle;fillStyle=solid;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;glass=0;shadow=0;opacity=90;" parent="1" vertex="1">
          <mxGeometry x="-766" y="1953" width="24" height="40" as="geometry" />
        </mxCell>
        <mxCell id="3EmIRpmpSdk3kt2dipBs-169" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;strokeWidth=2;fillColor=#E3D6F5;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=center;spacing=6;verticalAlign=middle;fillStyle=solid;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;glass=0;shadow=0;opacity=85;" parent="1" vertex="1">
