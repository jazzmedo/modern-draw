        <mxCell id="1jSB9UTQtr0Iap5kisdN-19" value="System-based attacks" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#B9E0A5;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=cross-hatch;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;" parent="1jSB9UTQtr0Iap5kisdN-18" vertex="1">
