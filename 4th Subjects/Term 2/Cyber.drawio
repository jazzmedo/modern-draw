        <mxCell id="ypaqH-uUHXjcv0g4RAur-17" value="Session Hijacking" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mali;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DMali;strokeWidth=2;fillColor=#FFCCBC;strokeColor=#36393d;fontSize=20;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;verticalAlign=middle;spacingBottom=0;fillStyle=solid;spacingLeft=2;spacingRight=2;spacing=2;spacingTop=0;container=0;" parent="ypaqH-uUHXjcv0g4RAur-6" vertex="1">
