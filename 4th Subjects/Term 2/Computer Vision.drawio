        <mxCell id="884ghLyyQ0BHEjxoMT_p-4" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;detecting parametric shapes (lines, circles)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" parent="884ghLyyQ0BHEjxoMT_p-0" vertex="1">
