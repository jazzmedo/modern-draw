        <mxCell id="otqSc2QbHW-ShUpMu0wC-34" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;sorts the pixel values in a neighborhood and &lt;font style=&quot;color: rgb(0, 0, 153);&quot;&gt;*selects the middle value&lt;/font&gt;, effective because&amp;nbsp;removes the outlier and&amp;nbsp;selects an existing value&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" vertex="1" parent="otqSc2QbHW-ShUpMu0wC-30">
          <mxGeometry x="89.89" y="28.63" width="614.11" height="41.37" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-35" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;averages extreme values with their neighbors, which only &lt;font style=&quot;color: rgb(0, 0, 153);&quot;&gt;*reduce the noise&lt;/font&gt; with blending the edges, causing blur.&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#E6D0DE;strokeColor=#36393D;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;spacingTop=-8;" vertex="1" parent="1">
          <mxGeometry x="149.89" y="852" width="614.11" height="30" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-36" value="&lt;font&gt;Mean Filter&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#A76A90;strokeColor=#36393D;container=0;fontStyle=1;fontSize=11;fontFamily=Fustat;fontColor=#FFFFFF;" vertex="1" parent="1">
