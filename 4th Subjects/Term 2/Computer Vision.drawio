        <mxCell id="VNpo0fs7QPe-CX1pk3Da-51" value="&lt;div style=&quot;line-height: 110%;&quot;&gt;&lt;font face=&quot;Lexend&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Why does the Canny edge detector uses the &quot;best attributes&quot; of both the gradient and Laplacian operators?&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;fontFamily=Mina;arcSize=5;hachureGap=4;align=left;spacingRight=5;fontStyle=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;fontColor=#333333;" parent="VNpo0fs7QPe-CX1pk3Da-50" vertex="1">
