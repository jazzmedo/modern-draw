        <mxCell id="HRr4-yyZ22-AxMjcjl-L-21" value="&lt;div style=&quot;line-height: 110%;&quot;&gt;&lt;font color=&quot;#000000&quot; face=&quot;Lexend&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Name at least three applications of SIFT and briefly explain how SIFT is used in each&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;fontFamily=Mina;arcSize=5;hachureGap=4;align=left;spacingRight=5;fontStyle=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;fontColor=#333333;" parent="HRr4-yyZ22-AxMjcjl-L-20" vertex="1">
