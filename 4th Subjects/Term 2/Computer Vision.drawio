        <mxCell id="Yi-lkMOcxAk4wUI-1sxm-103" value="&lt;font&gt;Spatial Domain&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#4C7E74;strokeColor=#3D506C;container=0;fontStyle=1;fontSize=11;fontFamily=Fustat;fontColor=#FFFFFF;" parent="Yi-lkMOcxAk4wUI-1sxm-101" vertex="1">
