        <mxCell id="otqSc2QbHW-ShUpMu0wC-58" value="&lt;font&gt;Spatial Domain&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#4C7E74;strokeColor=#3D506C;container=0;fontStyle=1;fontSize=11;fontFamily=Fustat;fontColor=#FFFFFF;" vertex="1" parent="otqSc2QbHW-ShUpMu0wC-56">
