        </mxCell>
        <mxCell id="2VT8IgdAOZ9plX4UFobo-61" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry x="470" y="1855.5" width="255.83" height="78" as="geometry" />
        </mxCell>
        <mxCell id="2VT8IgdAOZ9plX4UFobo-62" value="&lt;div style=&quot;text-align: center; direction: rtl; font-family: Helvetica; font-weight: 400;&quot;&gt;&lt;span style=&quot;color: rgb(234, 107, 102); font-size: 11px; font-family: Aviny; background-color: transparent;&quot;&gt;شوية نقط:&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: center; direction: rtl; font-family: Helvetica; font-weight: 400;&quot;&gt;&lt;font face=&quot;Aviny&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;- ايه شروط الـ edge detector الشاطر؟&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 11px;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;High detection rate, good localization, low noise sensitivity&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl; font-family: Helvetica; font-weight: 400;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 11px;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;- في الـ edge detection ، عندك المشتقة الاولي بتبقي local maximum&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;font-family: Helvetica; font-weight: 400; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 11px;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;-&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 11px; font-weight: 400;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;في الـ edge detection ، عندك المشتقة التانية بتطلعلي zero crossing&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl; font-family: Helvetica; font-weight: 400;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 11px;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;-&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 11px;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;الـ Gradient Operators:&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1" vertex="1" parent="1">
