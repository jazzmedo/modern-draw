        <mxCell id="yhAgFun6bCtzyW4o2Wya-74" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot; style=&quot;color: rgb(0, 0, 153);&quot;&gt;&lt;span style=&quot;font-weight: 400; line-height: 180%;&quot;&gt;ولا تنسونا من صالح دعواتـكم&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;fontSize=21;" vertex="1" parent="1">
          <mxGeometry x="329.75" y="6670" width="190" height="50" as="geometry" />
