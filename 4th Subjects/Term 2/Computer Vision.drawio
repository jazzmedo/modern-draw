          <mxGeometry x="467" y="171" width="255.83" height="78" as="geometry" />
        </mxCell>
        <mxCell id="bTlQdCpNz1z2zX7aI6I1-1" value="&lt;div style=&quot;text-align: center; direction: rtl; font-family: Helvetica; font-weight: 400;&quot;&gt;&lt;span style=&quot;color: rgb(234, 107, 102); font-size: 11px; font-family: Aviny; background-color: transparent;&quot;&gt;شوية نقط:&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: center; direction: rtl; font-family: Helvetica; font-weight: 400;&quot;&gt;&lt;font face=&quot;Aviny&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;- ايه شروط الـ edge detector الشاطر؟&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 11px;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;High detection rate, good localization, low noise sensitivity&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl; font-family: Helvetica; font-weight: 400;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 11px;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;- في الـ edge detection ، عندك المشتقة الاولي بتبقي local maximum&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;font-family: Helvetica; font-weight: 400; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 11px;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;-&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 11px; font-weight: 400;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;في الـ edge detection ، عندك المشتقة التانية بتطلعلي zero crossing&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl; font-family: Helvetica; font-weight: 400;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 11px;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;-&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 11px;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;الـ Gradient Operators:&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1" parent="VNpo0fs7QPe-CX1pk3Da-1" vertex="1">
          <mxGeometry x="347" y="100" width="456" height="70" as="geometry" />
        </mxCell>
        <mxCell id="bTlQdCpNz1z2zX7aI6I1-2" value="&lt;div style=&quot;text-align: center; direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot; style=&quot;color: rgb(0, 0, 153);&quot;&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;font style=&quot;font-size: 5px;&quot;&gt;كل ما يزيد الـ kernel ، &lt;br&gt;&lt;/font&gt;أقل حساسية للـ noise&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontSize=7;" parent="VNpo0fs7QPe-CX1pk3Da-1" vertex="1">
          <mxGeometry x="663" y="237" width="46" height="20" as="geometry" />
        </mxCell>
        <mxCell id="bTlQdCpNz1z2zX7aI6I1-3" value="&lt;div style=&quot;text-align: center; direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot; style=&quot;color: rgb(0, 0, 153);&quot;&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font style=&quot;font-size: 5px;&quot;&gt;كل ما يقل الـ kernel ،&lt;/font&gt;&lt;/div&gt;احسن localization&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontSize=7;" parent="VNpo0fs7QPe-CX1pk3Da-1" vertex="1">
          <mxGeometry x="475.99999999999994" y="237" width="46" height="20" as="geometry" />
        </mxCell>
        <mxCell id="bTlQdCpNz1z2zX7aI6I1-5" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;font style=&quot;font-weight: 400; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;- الـ&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; font-size: 11px; font-weight: 400;&quot;&gt;Hysteresis&amp;nbsp; عبارة عن 2 threshold `T_0`&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 11px; font-weight: 400;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; - و `T_1`، لو الـ&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font face=&quot;Aviny&quot; style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 11px; font-weight: 400;&quot;&gt;Magnitude&amp;gt;`T_1`&amp;nbsp;يبقي ده edge،&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 11px; font-weight: 400;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font face=&quot;Aviny&quot; style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 11px; font-weight: 400;&quot;&gt;لو&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font face=&quot;Aviny&quot; style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 11px; font-weight: 400;&quot;&gt;`T_0`&amp;lt;Magnitude&amp;lt;`T_1`&amp;nbsp;يبقي اللي بينهم edge ،&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 11px; font-weight: 400;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font face=&quot;Aviny&quot; style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 11px; font-weight: 400;&quot;&gt;انما لو&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font face=&quot;Aviny&quot; style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 11px; font-weight: 400;&quot;&gt;Magnitude&amp;lt;`T_0`&amp;nbsp;يبقي ده noise و مع السلامة&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font face=&quot;Aviny&quot; style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 11px; font-weight: 400;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl; font-weight: 400;&quot;&gt;&lt;font style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;- الـ laplacian بتحدد الـ edges عند zero crossing&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl; font-weight: 400;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 11px;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;- الـ canny ده عبارة عن smoothing و gradient و 1D laplacian ،، و اللي بيتحكم في الـ scale or resolution هو `\sigma`&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-weight: 400; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 11px;&quot;&gt;- في الـ harris موجود `\lamda_1` و&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 11px; font-weight: 400;&quot;&gt;`\lamda_2` و ده لازم يكون الاتنين عاليين عشان يبقي corner&lt;br&gt;- الـ&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 11px; font-weight: 400;&quot;&gt;&amp;nbsp;Non-maximal suppression ده بيشوف كل القيم اللي في الصورة ولو مش اعلي واحدة بيتجاهلها و بياخد اعلي واحدة بس دي هي الـ corner&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1" parent="VNpo0fs7QPe-CX1pk3Da-1" vertex="1">
          <mxGeometry x="17" y="90" width="313" height="173" as="geometry" />
        </mxCell>
