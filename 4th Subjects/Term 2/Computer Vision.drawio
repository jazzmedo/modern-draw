        <mxCell id="otqSc2QbHW-ShUpMu0wC-11" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;aim to &lt;font style=&quot;color: rgb(0, 0, 153);&quot;&gt;*suppress low-frequency noise&lt;/font&gt;,&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;which effectively &lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 153), rgb(255, 255, 255));&quot;&gt;*highlights&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; and&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 153), rgb(255, 255, 255));&quot;&gt;sharpens edges&lt;/font&gt;&lt;/span&gt;.&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#E6D0DE;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" vertex="1" parent="otqSc2QbHW-ShUpMu0wC-5">
