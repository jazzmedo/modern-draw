        </mxCell>
        <mxCell id="2VT8IgdAOZ9plX4UFobo-58" value="&lt;div style=&quot;line-height: 110%;&quot;&gt;&lt;font face=&quot;Lexend&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;What is non-maximal suppression and why is it necessary after computing the Harris corner response?&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;fontFamily=Mina;arcSize=5;hachureGap=4;align=left;spacingRight=5;fontStyle=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;fontColor=#333333;" vertex="1" parent="2VT8IgdAOZ9plX4UFobo-57">
          <mxGeometry x="26.61" width="763.39" height="55" as="geometry" />
        </mxCell>
        <mxCell id="2VT8IgdAOZ9plX4UFobo-59" value="5" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#666666;fontFamily=Mina;fontStyle=1;fontSize=20;spacingTop=3;fontColor=#333333;rounded=1;fillStyle=hachure;align=center;verticalAlign=middle;spacingLeft=0;spacingBottom=3;arcSize=14;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;" vertex="1" parent="2VT8IgdAOZ9plX4UFobo-57">
          <mxGeometry width="55.5" height="55.5" as="geometry" />
        </mxCell>
        <mxCell id="2VT8IgdAOZ9plX4UFobo-60" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;LoG is a single filter of &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;applying the Laplacian to a Gaussian&lt;/font&gt;. It&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(204, 0, 0), rgb(255, 255, 255));&quot;&gt;combines smoothing and second-derivative&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; computation into one convolution, better than apply 2 operations.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#C9D9E4;strokeColor=#23445d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" vertex="1" parent="1">
