        <mxCell id="eUIRvmHIikGdS-Din99n-3" value="" style="group" parent="eUIRvmHIikGdS-Din99n-1" vertex="1" connectable="0">
          <mxGeometry x="19" y="93" width="790" height="55.5" as="geometry" />
        </mxCell>
        <mxCell id="eUIRvmHIikGdS-Din99n-4" value="&lt;div style=&quot;line-height: 110%;&quot;&gt;&lt;font face=&quot;Lexend&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;What are the three energy terms in an active contour (snake) formulation? Explain the physical meaning of each.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;fontFamily=Mina;arcSize=5;hachureGap=4;align=left;spacingRight=5;fontStyle=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;fontColor=#333333;" parent="eUIRvmHIikGdS-Din99n-3" vertex="1">
          <mxGeometry x="26.61" width="763.39" height="55" as="geometry" />
        </mxCell>
        <mxCell id="eUIRvmHIikGdS-Din99n-5" value="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#666666;fontFamily=Mina;fontStyle=1;fontSize=20;spacingTop=3;fontColor=#333333;rounded=1;fillStyle=hachure;align=center;verticalAlign=middle;spacingLeft=0;spacingBottom=3;arcSize=14;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;" parent="eUIRvmHIikGdS-Din99n-3" vertex="1">
          <mxGeometry width="55.5" height="55.5" as="geometry" />
