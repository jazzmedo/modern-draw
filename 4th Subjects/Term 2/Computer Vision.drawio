        <mxCell id="VdCi_wQfxeVMJgqdMlPL-25" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;مناسب مع&amp;nbsp; الاشكال العشوائية و الـsmooth&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" parent="eUIRvmHIikGdS-Din99n-1" vertex="1">
