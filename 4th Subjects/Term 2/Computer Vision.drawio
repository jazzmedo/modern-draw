        <mxCell id="SRILQBK0KkNz0mj0Yv_H-10" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;font style=&quot;line-height: 140%;&quot; face=&quot;Aviny&quot;&gt;&lt;div&gt;البتاع ده بـيحسن الـ contrast(اختلاف درجات اللون في الصورة)&lt;br&gt;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(77, 77, 77), rgb(171, 171, 171));&quot;&gt;عن طريق انه بيوزع الإضاءة علي مساحة اكبر&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;verticalAlign=middle;horizontal=1;strokeColor=none;fillColor=none;rounded=0;glass=0;shadow=0;arcSize=6;spacingLeft=2;fontSize=10;fontColor=#4D4D4D;" parent="1" vertex="1">
