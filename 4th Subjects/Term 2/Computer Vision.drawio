        <mxCell id="otqSc2QbHW-ShUpMu0wC-31" value="&lt;span style=&quot;&quot;&gt;-&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#7EA6E0;strokeColor=#3D506C;fontColor=#ffffff;container=0;fontSize=12;fontFamily=Fustat;fontStyle=0" vertex="1" parent="otqSc2QbHW-ShUpMu0wC-30">
