          <mxGeometry x="19" y="4270" width="790" height="55.5" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-41" value="&lt;div style=&quot;line-height: 110%;&quot;&gt;&lt;font face=&quot;Lexend&quot;&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;Compare between the Hough transform and active contours (snakes) for boundary detection. What types of problems is each best suited for?&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;fontFamily=Mina;arcSize=5;hachureGap=4;align=left;spacingRight=5;fontStyle=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;fontColor=#333333;" vertex="1" parent="ucWEhtidr9BQ_HSIXQms-40">
