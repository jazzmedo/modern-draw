        <mxCell id="otqSc2QbHW-ShUpMu0wC-59" value="Role" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D4E1F5;strokeColor=#005700;fontColor=#36393D;container=0;fontSize=12;fontFamily=Fustat;fontStyle=1" vertex="1" parent="otqSc2QbHW-ShUpMu0wC-56">
          <mxGeometry x="89.89" width="614.11" height="28.63" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-60" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;normal &lt;/font&gt;representation of an image we are used to, where the image is&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(204, 0, 0), rgb(255, 255, 255));&quot;&gt;defined by pixels at locations&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; (x, y coordinates).&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" vertex="1" parent="otqSc2QbHW-ShUpMu0wC-56">
          <mxGeometry x="89.89" y="28.63" width="614.11" height="41.37" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-61" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;alternative &lt;/font&gt;representation of same image, where it is &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;defined&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;by the amplitudes and phases&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; of the sinusoidal frequencies that make up the image.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#e1d5e7;strokeColor=#9673a6;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="146.89" y="1572.5" width="614.11" height="41.37" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-62" value="&lt;font&gt;Frequency Domain&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#966AAF;strokeColor=#4D3C55;container=0;fontStyle=1;fontSize=11;fontFamily=Fustat;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="57" y="1572.5" width="90" height="41.37" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-63" value="&lt;font&gt;Fourier Transform&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#A76A90;strokeColor=#36393D;container=0;fontStyle=1;fontSize=11;fontFamily=Fustat;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="57" y="1613.87" width="90" height="41.37" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-64" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;mathematical tool that allows us to &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;convert &lt;/font&gt;an image &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;from &lt;span style=&quot;background-color: transparent;&quot;&gt;spatial to frequency&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; domain.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#E6D0DE;strokeColor=#36393D;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="146.89" y="1613.87" width="614.11" height="41.37" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-65" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Inverse Fourier Transform&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#C8974F;strokeColor=#604500;container=0;fontStyle=1;fontSize=11;fontFamily=Fustat;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="57" y="1655.2399999999998" width="90" height="41.37" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-66" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;does the opposite, converting the frequency representation back&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;into a spatial image.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#ffe6cc;strokeColor=#604500;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="146.89" y="1655.2399999999998" width="614.11" height="41.37" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-67" value="&lt;font style=&quot;color: rgb(230, 230, 230);&quot;&gt;2.0&lt;/font&gt;" style="whiteSpace=wrap;html=1;strokeColor=none;fillColor=#FFF2CC99;" vertex="1" parent="1">
          <mxGeometry x="789" y="3" width="33" height="14.5" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-68" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color: rgb(234, 107, 102); font-size: 11px; font-family: Aviny; background-color: transparent;&quot;&gt;شوية نقط:&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 11px; font-family: Aviny; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- الصورة بنـتـعامل معاها mathematically بالـ f(x, y)، عشان نعملها processing و بنعمله عشان نحول الصورة لـ form تـقدر نـ analyze it من خلالها.&lt;/span&gt;&lt;/div&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 11px; line-height: 140%;&quot;&gt;- الـ&amp;nbsp; Blur للصورة هو box filter بيعمل smoothing فـبيقلل الـ noise فيها، و&amp;nbsp; بتحافظ علي الـ high frequencies منها &lt;/span&gt;&lt;font style=&quot;font-size: 11px; line-height: 140%;&quot;&gt;و بيضيع&amp;nbsp; تفاصيل الصورة الصغيرة&lt;/font&gt;&lt;span style=&quot;font-size: 11px; line-height: 140%;&quot;&gt;، و من الفلاتر بتاعته الـ Gaussian.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 11px; line-height: 140%;&quot;&gt;- الـ Convolution ده بيستخدموا في الـ filtering، والـ operations بتاعته فيها summation و multiplication.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;verticalAlign=middle;horizontal=1;strokeColor=none;fillColor=#b0e3e6;rounded=1;glass=0;shadow=1;arcSize=6;spacingLeft=2;" vertex="1" parent="1">
          <mxGeometry x="339" y="240" width="469" height="90" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-69" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px; line-height: 140%;&quot; color=&quot;#1a1a1a&quot; face=&quot;Aviny&quot;&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- الـ Fourier ده بيحول الـ signals من spatial (الصور اللي بنشوفها و نفهمها) لـ frequency (ترددات الصور، صيغة منقدرش نتعرف عالصورة لو شوفناها بيها)&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#1a1a1a&quot; face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 11px; line-height: 140%;&quot;&gt;- الـ Linear Filters زي الـ mean اللي مشكلتها انها بتـ&amp;nbsp; blur sharp edges، و الـ averaging filters زي الـ Gaussian.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#1a1a1a&quot; face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 11px; line-height: 140%;&quot;&gt;-&amp;nbsp; الـ non Linear Filters زي الـ median اللي مشكلته انه بيحتاج ترتيب الpixels و ده بيستهلك وقت اكــتر.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;verticalAlign=middle;horizontal=1;strokeColor=none;fillColor=#b0e3e6;rounded=1;glass=0;shadow=1;arcSize=6;spacingLeft=2;" vertex="1" parent="1">
          <mxGeometry x="16" y="240" width="314" height="90" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-70" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div&gt;&lt;font style=&quot;line-height: 140%;&quot; face=&quot;Aviny&quot;&gt;&lt;div&gt;الصورة عادي جدا بالشكـل اللي بنشوفه و بنمثلها بـ pixels مكان كــل واحدة فيهم&amp;nbsp; علي محور x,y&lt;/div&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;verticalAlign=middle;horizontal=1;strokeColor=none;fillColor=none;rounded=0;glass=0;shadow=0;arcSize=6;spacingLeft=2;fontSize=10;fontColor=#4D4D4D;" vertex="1" parent="1">
