        <mxCell id="2VT8IgdAOZ9plX4UFobo-64" value="&lt;div style=&quot;text-align: center; direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot; style=&quot;color: rgb(0, 0, 153);&quot;&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font style=&quot;font-size: 5px;&quot;&gt;كل ما يقل الـ kernel ،&lt;/font&gt;&lt;/div&gt;احسن localization&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontSize=7;" vertex="1" parent="1">
