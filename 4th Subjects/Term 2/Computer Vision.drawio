        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-10" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="21" y="3530" width="790" height="55.5" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-11" value="&lt;div style=&quot;line-height: 110%;&quot;&gt;&lt;font face=&quot;Lexend&quot;&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;Why is the (`\rho, \theta`) parameterization preferred over (`m, c`) for the Hough transform? What are the ranges of&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;font-family: Lexend; font-size: 13px;&quot;&gt;`\rho` and `\theta`&lt;/span&gt;&lt;font face=&quot;Lexend&quot;&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;?&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;fontFamily=Mina;arcSize=5;hachureGap=4;align=left;spacingRight=5;fontStyle=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;fontColor=#333333;" vertex="1" parent="ucWEhtidr9BQ_HSIXQms-10">
          <mxGeometry x="26.61" width="763.39" height="55" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-12" value="3" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#666666;fontFamily=Mina;fontStyle=1;fontSize=20;spacingTop=3;fontColor=#333333;rounded=1;fillStyle=hachure;align=center;verticalAlign=middle;spacingLeft=0;spacingBottom=3;arcSize=14;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;" vertex="1" parent="ucWEhtidr9BQ_HSIXQms-10">
