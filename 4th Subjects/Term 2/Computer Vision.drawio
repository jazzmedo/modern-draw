        <mxCell id="ucWEhtidr9BQ_HSIXQms-50" value="&lt;font&gt;?&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D4E1F5;strokeColor=#3D506C;container=0;fontStyle=1;fontSize=11;fontFamily=Fustat;" vertex="1" parent="1">
          <mxGeometry x="61" y="4400" width="90" height="54" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-51" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;Works on disconnected edges, robust to noise.&lt;/div&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;Does not require initialization.&lt;/div&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;Cannot easily handle arbitrary non-parametric shapes.&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="150.89" y="4400" width="307.11" height="54" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-52" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;Require&amp;nbsp;shape priors and smoothness.&lt;/div&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;Require good initialization.&lt;/div&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;Good for medical imaging and object tracking.&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#E6D0DE;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="458" y="4400" width="307.11" height="54" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-53" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;font-family: Aviny; font-weight: normal; background-color: transparent;&quot;&gt;&lt;font&gt;ديه energy جايه من الـ edges بتاعت الصورة نفسها، كأنها بتشد الـ contour.&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="578" y="3221" width="203.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-54" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;font-family: Aviny; font-weight: normal; background-color: transparent; line-height: 90%;&quot;&gt;&lt;font style=&quot;color: rgb(51, 51, 51);&quot;&gt;ديه energy&amp;nbsp; داخلية من الـ contour نفسه مبنية علي المشتقة الأولي، بتخليه زي الأستـــك كده عشان يبقي مرن و مشدود دايما.&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="496" y="3242" width="285.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-55" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;font-family: Aviny; font-size: 8px; font-weight: 400;&quot;&gt;ديه energy&amp;nbsp; داخلية من الـ contour نفسه مبنية علي المشتقة التانية، بتمنع التعرجات و بتخليه smooth.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="512" y="3263" width="269.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-56" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;font-family: Aviny; font-size: 8px; font-weight: 400;&quot;&gt;يبقي&amp;nbsp; total of energy اللي بتأثر علي الـ contour هي في المعادلة ديه (الـ `\alpha` بتتحكم في قوة الـ&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 8px; font-weight: 400;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;elastic و الـ `\beta` في الـ smoothing&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;font-family: Aviny; font-size: 8px; font-weight: 400; background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;).&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="512" y="3284" width="269.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-57" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;font-family: Aviny; font-size: 8px; font-weight: 400;&quot;&gt;فيه 3 عوامل بتأثر علي الـ contour هما ايه و ليه؟&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="688" y="3162" width="120" height="11.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-58" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;font-family: Aviny; font-size: 8px; font-weight: 400;&quot;&gt;ايه العلاقة المتبادلة بين الـ parameter space والـ image space؟ و ازاي بيـ map لبعض؟&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="512" y="3385" width="269.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-59" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;font-family: Aviny; font-size: 8px; font-weight: 400;&quot;&gt;الـ&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 8px; font-weight: 400;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;Image Space ده مكان الصورة الطبيعي ك `x,y` لكن الـ&amp;nbsp;&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 8px; font-weight: 400;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;parameter space ده بيتخزن فيه الـ params نفسها زي الـ `m,c` في معادلة الخط المستقيم -&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 8px; font-weight: 400;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;`(y=mx+c)`&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 8px; font-weight: 400;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;الخط في الـ parameter space بيتمثل كـ point في image space&amp;nbsp; وهما ليهم نفس الـ `m,c`، ولما اجي احول من&amp;nbsp; image ل parameter space بعمل voting لكل الـlines اللي بتمثل نقطة&amp;nbsp; و في الاخر بعمل voting عشان اختار الـ line الحقيقي&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="277" y="3479" width="504.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-60" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;font-family: Aviny; font-size: 8px; font-weight: 400;&quot;&gt;ليه بيفضلوا الـ&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 8px; font-weight: 400;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&amp;nbsp;(`\rho, \theta`) علي&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 8px; font-weight: 400;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&amp;nbsp;(`m, c`)؟&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="511.86" y="3581.4300000000003" width="269.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-61" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;عشان في حالة الـ vertical line&amp;nbsp; &amp;nbsp;بيعمل مشاكل مع الـ slope&amp;nbsp; ف مش هنعرف نعمل voting&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="512" y="3642" width="269.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-62" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;الـ voting بيتعمل ازاي في الدواير&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="532" y="3712" width="269.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-63" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;لو احنا عارفين الـ r بكام وقتها هنجرب كل الـ lines الممكنة عشان نحدد نص الدايرة فيه بالظبط و مش بس كده هنعمل voting عليهم .&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="492" y="3791" width="292.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-64" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;ازاي لو احنا عارفين الـ edge direction هنعرف نحدد الـcircle بـ resources اقل؟ و ازاي نتـ trade off بينهم؟&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="508" y="3860" width="292.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-65" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400; font-family: Aviny; background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;لو حسبنا&amp;nbsp; الـ edge direction هنلاقي ان عندنا اتجاه عمودي علي الـ edge&amp;nbsp; &amp;nbsp;و طولة r ، ف كده بقي عندي احتمالين بس و ده هيقلل الـ voting&amp;nbsp; اللي بيحصل، عشان كده الحل الامثل اننا نستعمل الـ edge direction&amp;nbsp; و بعديها نروح لـ parameter space براحتنا&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="262" y="3958" width="534.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-66" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;ايه هدف البتاع ده و ازاي اتعمل و بيعمل detect لايه&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="507" y="4009" width="292.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-67" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;الباشا ده بيعمل processing offline&amp;nbsp; و بيخزن&amp;nbsp; الـ edge direction لـ&amp;nbsp; النقط عشان لما اجي اعمل voting اكون قللت عدد الاحتمالات كتير لأني عارف ان ال point دي هتبقي في اي اتجاه&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="392" y="4087" width="390.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-68" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;ايه اللي هيحصل لو استخدمنا البتاع ده في اشكال ممكن تكبر او تـ rotate مكانها؟ و ليه صعب؟&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="415" y="4165" width="390.14" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-69" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;وقتها هحتاج امثل الكلام ده في 4 اتجاهات ، يعني الـ x, y, و كمان هحتاج اعرف الـ scale و الـ rotation value و ده هيحتاج ميموري كبيرة جدا و computation عنيف&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="390" y="4229.43" width="390.14" height="20.57" as="geometry" />
        </mxCell>
