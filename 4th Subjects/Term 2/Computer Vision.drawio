        <mxCell id="yhAgFun6bCtzyW4o2Wya-46" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;font color=&quot;#cc0000&quot;&gt;Measures overlap between histograms&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#e1d5e7;strokeColor=#9673a6;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="294" y="5750" width="157" height="60" as="geometry" />
        </mxCell>
        <mxCell id="yhAgFun6bCtzyW4o2Wya-47" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;font color=&quot;#cc0000&quot;&gt;Computes the difference between two descriptors&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#e1d5e7;strokeColor=#9673a6;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="294" y="5689" width="157" height="61" as="geometry" />
        </mxCell>
        <mxCell id="yhAgFun6bCtzyW4o2Wya-48" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;في الـ object recognition، SIFT يطابق features بين object وصورة جديدة عشان يتعرف عليه حتى لو متدوّر أو حجمه مختلف. وفي الـ panorama stitching بيستخدم الـ matches بين الصور عشان يركبهم صح، وفي scene collages يساعد على محاذاة الصور فوق بعض بالـ rotation والـ scaling المناسب.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="454" y="6055" width="330.5" height="26" as="geometry" />
        </mxCell>
        <mxCell id="yhAgFun6bCtzyW4o2Wya-49" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;الـ L2 distance يقيس الفرق بين descriptorين، فكل ما القيمة تصغر يبقى الـ match أحسن. أما الـ Intersection فيقيس قد إيه الـ histograms متشابهين، فكل ما القيمة تكبر يبقى الـ match أفضل.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="505.86" y="5810" width="288.14" height="26" as="geometry" />
        </mxCell>
        <mxCell id="yhAgFun6bCtzyW4o2Wya-50" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;are detected in &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;overlapping &lt;/font&gt;images,&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(204, 0, 0), rgb(255, 255, 255));&quot;&gt;matched&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;, and used to geometrically warp images to align them.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="155" y="5989" width="620" height="37" as="geometry" />
        </mxCell>
        <mxCell id="yhAgFun6bCtzyW4o2Wya-51" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Image Stitching&amp;nbsp; &amp;nbsp; &amp;nbsp;/&lt;br&gt;Panorama Creation&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D4E1F5;strokeColor=#3D506C;container=0;fontStyle=1;fontSize=11;fontFamily=Fustat;" vertex="1" parent="1">
          <mxGeometry x="45" y="5989" width="110" height="37" as="geometry" />
        </mxCell>
        <mxCell id="yhAgFun6bCtzyW4o2Wya-52" value="&lt;font&gt;Scene collages&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D4E1F5;strokeColor=#3D506C;container=0;fontStyle=1;fontSize=11;fontFamily=Fustat;" vertex="1" parent="1">
          <mxGeometry x="45" y="6025.37" width="110" height="21.37" as="geometry" />
        </mxCell>
        <mxCell id="yhAgFun6bCtzyW4o2Wya-53" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;matches between images &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;allow them to be overlaid&lt;/font&gt;&lt;font face=&quot;ukij qolyazma yantu&quot; style=&quot;color: rgb(0, 0, 204);&quot;&gt;&amp;nbsp;يركب الصور &lt;/font&gt;(translated, scaled,&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;rotated) to create a &lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(204, 0, 0), rgb(255, 255, 255));&quot;&gt;composite visualization&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" vertex="1" parent="1">
