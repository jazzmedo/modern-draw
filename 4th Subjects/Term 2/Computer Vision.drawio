          <mxGeometry x="18" y="897" width="790" height="55.5" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-38" value="&lt;div style=&quot;line-height: 110%;&quot;&gt;&lt;font face=&quot;Lexend&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;What is the primary disadvantage of the median filter regarding computational speed and image details?&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;fontFamily=Mina;arcSize=5;hachureGap=4;align=left;spacingRight=5;fontStyle=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;fontColor=#333333;" vertex="1" parent="otqSc2QbHW-ShUpMu0wC-37">
          <mxGeometry x="26.61" width="763.39" height="55" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-39" value="4" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#666666;fontFamily=Mina;fontStyle=1;fontSize=20;spacingTop=3;fontColor=#333333;rounded=1;fillStyle=hachure;align=center;verticalAlign=middle;spacingLeft=0;spacingBottom=3;arcSize=14;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;" vertex="1" parent="otqSc2QbHW-ShUpMu0wC-37">
          <mxGeometry width="55.5" height="55.5" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-40" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;- more &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;*time-consuming&lt;/font&gt; operation, it requires &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;sorting all the pixel values&lt;/font&gt; within a&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;neighborhood to find the median&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;erase fine details&lt;/font&gt; in the image,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;because these &lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(204, 0, 0), rgb(255, 255, 255));&quot;&gt;features may not constitute&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; the majority&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;of the pixels in a given neighborhood&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D4E1F5;strokeColor=#582826;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;spacingTop=-15;" vertex="1" parent="1">
          <mxGeometry x="60" y="967" width="704" height="50" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-41" value="" style="group;spacingTop=-4;" vertex="1" connectable="0" parent="1">
          <mxGeometry x="18" y="1032" width="790" height="55.5" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-42" value="&lt;div style=&quot;line-height: 110%;&quot;&gt;&lt;font face=&quot;Lexend&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;What is an image histogram? If an image is very dark, what would you expect its histogram to look like?&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;fontFamily=Mina;arcSize=5;hachureGap=4;align=left;spacingRight=5;fontStyle=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;fontColor=#333333;spacingTop=-7;" vertex="1" parent="otqSc2QbHW-ShUpMu0wC-41">
          <mxGeometry x="26.61" width="763.39" height="55" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-43" value="5" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#666666;fontFamily=Mina;fontStyle=1;fontSize=20;spacingTop=3;fontColor=#333333;rounded=1;fillStyle=hachure;align=center;verticalAlign=middle;spacingLeft=0;spacingBottom=3;arcSize=14;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;" vertex="1" parent="otqSc2QbHW-ShUpMu0wC-41">
          <mxGeometry width="55.5" height="55.5" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-44" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;is a graph or plot that &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;shows the frequency&lt;/font&gt; distribution of all the pixel intensity,&amp;nbsp; x-axis represents the intensity values (e.g., 0 to 255), &lt;u&gt;y-axis&lt;/u&gt; represents the &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;number of pixels&lt;/font&gt; that have specific intensity value, If an image is very dark, most of its pixels will have low intensity values&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#E1D5E7;strokeColor=#582826;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;spacingTop=-11;" vertex="1" parent="1">
          <mxGeometry x="60" y="1102" width="704" height="50" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-45" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="18" y="1180" width="790" height="55.5" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-46" value="&lt;div style=&quot;line-height: 110%;&quot;&gt;&lt;font face=&quot;Lexend&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;What does it mean that a histogram provides &quot;global information&quot; about an image?&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;fontFamily=Mina;arcSize=5;hachureGap=4;align=left;spacingRight=5;fontStyle=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;fontColor=#333333;" vertex="1" parent="otqSc2QbHW-ShUpMu0wC-45">
          <mxGeometry x="26.61" width="763.39" height="55" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-47" value="6" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#666666;fontFamily=Mina;fontStyle=1;fontSize=20;spacingTop=3;fontColor=#333333;rounded=1;fillStyle=hachure;align=center;verticalAlign=middle;spacingLeft=0;spacingBottom=3;arcSize=14;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;" vertex="1" parent="otqSc2QbHW-ShUpMu0wC-45">
          <mxGeometry width="55.5" height="55.5" as="geometry" />
        </mxCell>
        <mxCell id="otqSc2QbHW-ShUpMu0wC-48" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;histogram summarizes information from the entire image as a whole,&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;u&gt;without information&lt;/u&gt; about where the dark or bright pixels are &lt;u&gt;located&lt;/u&gt;, that means maybe if 2 completely different images have same histogram.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#FFF2CC;strokeColor=#582826;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;spacingTop=-8;" vertex="1" parent="1">
