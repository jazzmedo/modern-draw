        <mxCell id="ucWEhtidr9BQ_HSIXQms-78" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;شغال&amp;nbsp; في الصور الطبية و مراقبة تحركات الـ objects&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="540" y="4495.14" width="179.07" height="20.57" as="geometry" />
