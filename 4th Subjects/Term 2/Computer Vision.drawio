        <mxCell id="Yi-lkMOcxAk4wUI-1sxm-99" value="&lt;div style=&quot;line-height: 110%;&quot;&gt;&lt;font face=&quot;Lexend&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Explain the relationship between the &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;spatial domain&lt;/font&gt; and the &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;frequency domain&lt;/font&gt; as presented in the context of the Fourier Transform.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;fontFamily=Mina;arcSize=5;hachureGap=4;align=left;spacingRight=5;fontStyle=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;fontColor=#333333;" parent="Yi-lkMOcxAk4wUI-1sxm-98" vertex="1">
