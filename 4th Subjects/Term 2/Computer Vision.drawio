        <mxCell id="Yi-lkMOcxAk4wUI-1sxm-102" value="&lt;span style=&quot;&quot;&gt;-&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#7EA6E0;strokeColor=#3D506C;fontColor=#ffffff;container=0;fontSize=12;fontFamily=Fustat;fontStyle=0" parent="Yi-lkMOcxAk4wUI-1sxm-101" vertex="1">
