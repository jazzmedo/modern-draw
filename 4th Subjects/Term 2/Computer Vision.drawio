        <mxCell id="--FEQ5IAB1aUqq-TujF8-6" value="&lt;font&gt;Object recognition&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D4E1F5;strokeColor=#3D506C;container=0;fontStyle=1;fontSize=11;fontFamily=Fustat;" parent="KfrxztiE6OfKk03DvFlC-1" vertex="1">
