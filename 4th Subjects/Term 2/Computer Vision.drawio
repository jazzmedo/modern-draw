        <mxCell id="4ziYMLe8eve76E32E5-x-50" value="&lt;div style=&quot;line-height: 110%;&quot;&gt;&lt;font face=&quot;Lexend&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Explain the concept of &quot;scale space&quot; in the context of the Canny edge detector. How does changing `\sigma` affect the output?&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=22;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;fontFamily=Mina;arcSize=5;hachureGap=4;align=left;spacingRight=5;fontStyle=0;fillStyle=hachure;verticalAlign=middle;spacingLeft=29;spacingBottom=0;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;fontColor=#333333;" parent="4ziYMLe8eve76E32E5-x-49" vertex="1">
          <mxGeometry x="26.61" width="763.39" height="55" as="geometry" />
        </mxCell>
        <mxCell id="4ziYMLe8eve76E32E5-x-51" value="4" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=1;fillColor=#FFFFFF;strokeColor=#666666;fontFamily=Mina;fontStyle=1;fontSize=20;spacingTop=3;fontColor=#333333;rounded=1;fillStyle=hachure;align=center;verticalAlign=middle;spacingLeft=0;spacingBottom=3;arcSize=14;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;" parent="4ziYMLe8eve76E32E5-x-49" vertex="1">
          <mxGeometry width="55.5" height="55.5" as="geometry" />
        </mxCell>
        <mxCell id="4ziYMLe8eve76E32E5-x-52" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;Scale space refers to the idea that edges &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;exist at different levels of detail or resolution&lt;/font&gt;, &lt;font style=&quot;color: rgb(204, 0, 0);&quot;&gt;small&amp;nbsp;`\sigma`&amp;nbsp;saves fine details&lt;/font&gt;, which &lt;i&gt;larger `\sigma` ignore fine details&lt;/i&gt; and only save the structure.&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;fillColor=#b0e3e6;strokeColor=#074044;" parent="VNpo0fs7QPe-CX1pk3Da-1" vertex="1">
