        <mxCell id="eUIRvmHIikGdS-Din99n-2" value="Rev. Sheet #3" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;fixedSize=1;size=16;fontFamily=ADLaM Display;fontSize=20;strokeWidth=1;align=center;spacingLeft=0;spacingBottom=4;fillStyle=hachure;fontStyle=1;rounded=1;arcSize=50;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DADLaM%2BDisplay;" parent="eUIRvmHIikGdS-Din99n-1" vertex="1">
