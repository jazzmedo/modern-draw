          <mxGeometry x="250" y="4454" width="129.07" height="20.57" as="geometry" />
        </mxCell>
        <mxCell id="ucWEhtidr9BQ_HSIXQms-72" value="&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;div style=&quot;direction: rtl;&quot;&gt;&lt;font face=&quot;Aviny&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;يقدر يعمل نفسه من الصفر ف مش عايز initialization&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Mina;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="250" y="4481" width="129.07" height="20.57" as="geometry" />
