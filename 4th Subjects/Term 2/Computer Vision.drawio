        <mxCell id="Yi-lkMOcxAk4wUI-1sxm-65" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;sorts the pixel values in a neighborhood and &lt;font style=&quot;color: rgb(0, 0, 153);&quot;&gt;*selects the middle value&lt;/font&gt;, effective because&amp;nbsp;removes the outlier and&amp;nbsp;selects an existing value&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D5E8D4;strokeColor=#36393d;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;" parent="Yi-lkMOcxAk4wUI-1sxm-61" vertex="1">
