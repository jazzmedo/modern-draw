        <mxCell id="SRILQBK0KkNz0mj0Yv_H-14" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;font style=&quot;line-height: 140%;&quot; face=&quot;Aviny&quot;&gt;&lt;div&gt;ده رسم بيقولي توزيع درجات الإضاءة في الصورة ،&amp;nbsp; و&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;لو معظم الصورة غامقة (&lt;/span&gt;&lt;font face=&quot;Aviny&quot; style=&quot;background-color: transparent; color: light-dark(rgb(77, 77, 77), rgb(171, 171, 171));&quot;&gt;تبقى قريبة من 0)،&amp;nbsp;&lt;/font&gt;&lt;font face=&quot;Aviny&quot; style=&quot;background-color: transparent; color: light-dark(rgb(77, 77, 77), rgb(171, 171, 171));&quot;&gt;لو الصورة فاتحة&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(77, 77, 77), rgb(171, 171, 171));&quot;&gt;(تبقى ناحية 255).&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;align=right;textDirection=rtl;verticalAlign=middle;horizontal=1;strokeColor=none;fillColor=none;rounded=0;glass=0;shadow=0;arcSize=6;spacingLeft=2;fontSize=10;fontColor=#4D4D4D;" parent="1" vertex="1">
