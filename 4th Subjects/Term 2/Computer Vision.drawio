        <mxCell id="otqSc2QbHW-ShUpMu0wC-33" value="Salt and pepper" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#D4E1F5;strokeColor=#005700;fontColor=#36393D;container=0;fontSize=12;fontFamily=Fustat;fontStyle=1" vertex="1" parent="otqSc2QbHW-ShUpMu0wC-30">
