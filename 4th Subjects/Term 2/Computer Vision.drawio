        <mxCell id="VNpo0fs7QPe-CX1pk3Da-49" value="&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;is a technique where a &lt;font style=&quot;color: rgb(0, 0, 153);&quot;&gt;window slides over the image&lt;/font&gt;, and only&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;pixels that are the &lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 153), rgb(255, 255, 255));&quot;&gt;maximum value within that window are retained&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 140%;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;necessary because the Harris response produces large values not only the exact corner locations, also around it, NMS finds local peak.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=0.5;fillColor=#FFF2CC;strokeColor=#582826;container=0;fontSize=11;fontStyle=0;fontFamily=Fustat;spacingLeft=2;align=left;spacingTop=-20;" parent="VNpo0fs7QPe-CX1pk3Da-1" vertex="1">
