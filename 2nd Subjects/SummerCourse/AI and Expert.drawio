        <mxCell id="-yXsvrhgGh--1ZpngYir-119" parent="-yXsvrhgGh--1ZpngYir-125" style="rounded=1;whiteSpace=wrap;html=1;hachureGap=4;fontFamily=Mina;strokeWidth=2;fillColor=#ffcccc;strokeColor=#000000;fontSize=16;fontStyle=1;labelBorderColor=none;textShadow=0;labelBackgroundColor=none;align=left;spacing=7;verticalAlign=middle;" value="&lt;div&gt;Performance measuring success&lt;/div&gt;" vertex="1">
